  "dailyGraceCopiedToast": "آیت کلیپ بورڈ میں نقل ہو گئی",

  "dailyScripture0Text": "یقیناً نیک لوگ باغات اور نہروں میں ہوں گے، ایک طاقتور بادشاہ کے پاس اعزاز کی جگہ میں۔",
  "dailyScripture0Ref": "قرآن 54:54-55",
  "dailyScripture1Text": "اور ہم نے آپ کو (محمد) دنیا کے لیے صرف رحمت کے طور پر بھیجا ہے۔",
  "dailyScripture1Ref": "قرآن 21:107",
  "dailyScripture2Text": "کیا الله اپنے بندے کے لیے کافی نہیں ہے؟ پھر بھی وہ آپ کو اس کے علاوہ دوسروں سے ڈراتے ہیں۔",
  "dailyScripture2Ref": "قرآن 39:36",
  "dailyScripture3Text": "شاید تاسو چې کوم شی نه غواړئ اچھی ہے تاسو کې لپاره؛ اور شاید تاسو چې محبت کړئ کوم شی برا ہے تاسو کې لپاره. اور الله جانتا ہے، جبکہ تاسو نہ جانتے ہو۔",
  "dailyScripture3Ref": "قرآن 2:216",
  "dailyScripture4Text": "یقیناً الله صبر کرنے والوں کے ساتھ ہے۔",
  "dailyScripture4Ref": "قرآن 2:153",
  "dailyScripture5Text": "پس مجھے یاد کرو؛ میں تاسو کو یاد کروں گا۔ اور میرا شکر ادا کرو اور میرا انکار مت کرو۔",
  "dailyScripture5Ref": "قرآن 2:152",
  "dailyScripture6Text": "یقیناً الله کی نظر میں تاسو میں سب سے زیادہ شریف وہ ہے جو سب سے زیادہ نیک ہے۔",
  "dailyScripture6Ref": "قرآن 49:13",
  "dailyScripture7Text": "اور تاسو کے رب نے فیصلہ دیا ہے کہ تاسو اس کے علاوہ کسی کی عبادت مت کرو، اور اپنے والدین کے ساتھ بھلائی کریں۔",
  "dailyScripture7Ref": "قرآن 17:23",
  "dailyScripture8Text": "یقیناً، مشکل کے ساتھ آسانی ہے۔",
  "dailyScripture8Ref": "قرآن 94:6",
  "dailyScripture9Text": "اور وہ تاسو کے ساتھ ہے جہاں کہیں تاسو ہو۔ اور الله، جو تاسو کریں، وہ دیکھ رہا ہے۔",
  "dailyScripture9Ref": "قرآن 57:4",
  "dailyScripture10Text": "الله کسی نفس کو اس سے زیادہ بوجھ نہیں دیتا جو وہ برداشت کر سکتا ہے۔",
  "dailyScripture10Ref": "قرآن 2:286",
  "dailyScripture11Text": "اور جو الله پر توکل کرتے ہیں — تو وہی ان کے لیے کافی ہے۔",
  "dailyScripture11Ref": "قرآن 65:3",
  "dailyScripture12Text": "میری رحمت تمام چیزوں کو احاطہ کرتی ہے۔",
  "dailyScripture12Ref": "قرآن 7:156",
  "dailyScripture13Text": "اور جب میرے بندے تاسو سے میرے بارے میں سوال کریں — یقیناً میں قریب ہوں۔ میں جواب دیتا ہوں اس کی دعا کو جو مجھ سے دعا کرتا ہے۔",
  "dailyScripture13Ref": "قرآن 2:186",
  "dailyScripture14Text": "جو کوئی بھی نیکی کرے، خواہ وہ مرد ہو یا عورت، جبکہ ایماندار ہو — ہم ضرور اسے اچھی زندگی دیں گے۔",
  "dailyScripture14Ref": "قرآن 16:97",
  "dailyScripture15Text": "یقیناً الله کسی قوم کی حالت تبدیل نہیں کرتا جب تک وہ اپنے آپ میں تبدیلی نہ کریں۔",
  "dailyScripture15Ref": "قرآن 13:11",
  "dailyScripture16Text": "تو کمزوری مت کرو اور غم مت کھاؤ، اور تاسو بہتر ہوں گے اگر تاسو سچے ایماندار ہو۔",
  "dailyScripture16Ref": "قرآن 3:139",
  "dailyScripture17Text": "اے میرے بندوں جنہوں نے اپنے آپ کے خلاف سے کیا، الله کی رحمت سے ہتاش مت ہو۔ یقیناً الله تمام گناہوں کو معاف کرتا ہے۔",
  "dailyScripture17Ref": "قرآن 39:53",
  "dailyScripture18Text": "اور جو کوئی الله سے ڈرتا ہے — وہ اس کے لیے راستہ بناتا ہے، اور اسے ایسی جگہ سے رزق دیتا ہے جہاں وہ توقع نہیں رکھتا۔",
  "dailyScripture18Ref": "قرآن 65:2-3",
  "dailyScripture19Text": "الله کی رحمت میں ہتاش مت ہو۔",
  "dailyScripture19Ref": "قرآن 12:87",
  "dailyScripture20Text": "اور ہم نے یقیناً قرآن کو یادگاری کے لیے آسان بنایا ہے۔ تو کیا کوئی ہے جو توجہ دے گا؟",
  "dailyScripture20Ref": "قرآن 54:17",
  "dailyScripture21Text": "اور وہ تاسو کو گمراہ پایا اور تاسو کو ہدایت دی۔",
  "dailyScripture21Ref": "قرآن 93:7",
  "dailyScripture22Text": "اور تاسو کے رب نے کہا: مجھ سے دعا کرو؛ میں تاسو کی جواب دوں گا۔",
  "dailyScripture22Ref": "قرآن 40:60",
  "dailyScripture23Text": "اور ہم نے یقیناً بنی آدم کو عزت دی ہے۔",
  "dailyScripture23Ref": "قرآن 17:70",
  "dailyScripture24Text": "اور صبر اور نماز کے ذریعے مدد مانگو۔",
  "dailyScripture24Ref": "قرآن 2:45",
  "dailyScripture25Text": "جو کوئی بھی ایک ذرہ کے برابر نیکی کرے وہ اسے دیکھے گا۔",
  "dailyScripture25Ref": "قرآن 99:7",
  "dailyScripture26Text": "بے شک الله کی مدد قریب ہے۔",
  "dailyScripture26Ref": "قرآن 2:214",
  "dailyScripture27Text": "اور جو کوئی شکر کرتا ہے — اس کا شکر صرف اپنے لیے ہے۔",
  "dailyScripture27Ref": "قرآن 31:12",

  "dailyReflection0": "جیسے یہ دن بند ہوتا ہے، ایک لحظہ پر غور کریں جہاں الله کی رحمت واضح تھی۔",
  "dailyReflection1": "الله تعالیٰ کے سامنے جو کچھ آج آپ کے دل پر تھا۔",
  "dailyReflection2": "اس دن سے ایک برکت کا نام بتائیں اور الله کا شکر ادا کریں۔",
  "dailyReflection3": "الله کی بے حد دیکھ بھال میں رہنے کے علم میں سکون تلاش کریں۔",
  "dailyReflection4": "اس پر تفکر کریں جہاں تاسو آج شفقت اور رحم دکھانے کے لیے بلایا گیا۔",
  "dailyReflection5": "جو تاسو کنٹرول نہیں کر سکتے اس کو جانے دیں اور الله تعالیٰ کی کامل منصوبے پر توکل کریں۔",
  "dailyReflection6": "جیسے دن بند ہوتا ہے، الله کی یادگاری میں سلام پائیں۔",
  "dailyReflection7": "اس پر غور کریں کہ تاسو نے آج نمازوں کی عزت کی، اور ہر ایک کے لیے الله کا شکر۔",
  "dailyReflection8": "ایسے لحظے پر غور کریں جہاں صبر (صبر) نے آج آپ کی رہنمائی کی۔",
  "dailyReflection9": "آج کی کسی بھی کمی کے لیے معافی مانگیں — الله کی رحمت بے حد ہے۔",
  "dailyReflection10": "ایک شخص کا نام بتائیں جس کو تاسو نے آج شفقت دکھائی اور اس کے لیے دعا کریں۔",
  "dailyReflection11": "شکر گزاری میں بیٹھیں: الله نے اس دن کیا دیا جو تاسو نے نہیں مانگا؟",
  "dailyReflection12": "قرآن کی ایک آیت پر غور کریں جو تاسو اب ہو رہے ہیں اس سے بات کرتی ہے۔",
  "dailyReflection13": "اس بات پر غور کریں کہ تاسو نے اپنا وقت آج کیسے استعمال کیا — اور کل کو الله کو پیش کریں۔",
  "dailyReflection14": "جانتے ہوئے آرام کریں کہ جو مشکل آج آئی، الله تاسو کے ساتھ تھا۔",
  "dailyReflection15": "اس بارے میں سوچیں کہ آج تاسو نے اپنے خاندار یا معاشرے کی کس طرح خدمت کی الله کے نام میں۔",
  "dailyReflection16": "جیسے رات ہوتی ہے، توبہ کریں — الله ان لوگوں کو پسند کرتا ہے جو اس کی طرف واپس آتے ہیں۔",
  "dailyReflection17": "الله نے اپنے دن میں خوبصورتی رکھی، چاہے کتنی بھی چھوٹی ہو، اس کی عکاسی کریں۔",
  "dailyReflection18": "اس بارے میں سوچیں کہ تاسو نے آج کیا سیکھا اور یہ تاسو کو الله کے قریب کیسے لاتا ہے۔",
  "dailyReflection19": "دن کی فکریں الله کے ساتھ چھوڑ دیں — وہ جو تاسو نہیں کر سکتے اسے سنبھالتا ہے۔",
  "dailyReflection20": "اس لحظے کے بارے میں سوچیں جہاں تاسو آج بہتر انتخاب کر سکتے تھے، اور نرمی سے سیکھیں۔",
  "dailyReflection21": "جو تکلیف میں ہیں ان کے لیے دعا کریں — آپ کی نماز انہیں ایک تحفہ ہے۔",
  "dailyReflection22": "ایک برکت کو یاد کریں جو تاسو اکثر نظر انداز کرتے ہیں اور الله کا شکر کے لیے ایک لمحہ دیں۔",
  "dailyReflection23": "اپنی نیتوں کے بارے میں غور کریں — کیا وہ الله کے لیے تھے؟ کل، دوبارہ شروع کریں۔",
  "dailyReflection24": "جیسے رات خاموشی میں رہتی ہے، خاموشی میں الله کی قربت سنیں۔",
  "dailyReflection25": "اس بارے میں سوچیں جہاں تاسو نے آج طاقت پائی — وہ طاقت الله سے ہے۔",
  "dailyReflection26": "ایک چیز کا نام بتائیں جو تاسو کل کریں گے، الله کے نام میں، جو تاسو آج نہیں کیا۔",
  "dailyReflection27": "جیسے تاسو آرام کے لیے تیاری کریں، اپنی روح کو الله کو سپرد کریں — وہ بہترین محافظ ہے۔",

