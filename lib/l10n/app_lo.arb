  "accountDeleteSuccessBody": "ບັນຊີ ແລະ ຂໍ້ມູນທີ່ກ່ຽວຂ້ອງໄດ້ຖືກລົບຖາວອນ.",
  "accountDeleteSuccessClose": "ປິດ",
  "accountDeleteErrorTitle": "ບໍ່ສາມາດລົບບັນຊີ",
  "accountDeleteErrorClose": "ຕົກລົງ",
  "accountDeleteReauthCancelled": "ການກວມກັບບັນຊີຖືກຍົກເລີກ. ກະລຸນາເຂົ້າສູ່ລະບົບຄືນໄປ ແລະ ລອງລົບຄືນໃໝ່.",
  "accountDeleteReauthRequired": "ການລົບບັນຊີຕ້ອງມີການເຂົ້າສູ່ລະບົບວ່າົນ. ກະລຸນາອອກຈາກລະບົບ, ເຂົ້າສູ່ລະບົບຄືນໄປ, ແລະ ລອງລົບຄືນໃໝ່.",
  "settingsDeletePermanentWarning": "ການກະທໍາມີຖາວອນ ແລະ ບໍ່ສາມາດຍົກເລີກໄດ້. ຂໍ້ມູນທັງໝົດທີ່ກ່ຽວຂ້ອງກັບບັນຊີຂອງທ່ານຈະຖືກລົບ.",

  "dailyGraceTitle": "ຄໍາແນະນໍາປະຈໍາວັນ",
  "dailyGraceScriptureLabel": "VERSE ຂອງມື້",
  "dailyGraceSaintLabel": "ຄົນສຶກສາຂອງອາທິດ",
  "dailyGraceReflectionLabel": "ການສະທ້ອນໃຈຕອນເຍັນ",
  "dailyGraceCopiedToast": "Verse ສຳເນົາໄປຫາຄຳທີ່ເກັບເກັບ",

  "dailyScripture0Text": "ແທ້ຈິງແລ້ວ, ຜູ້ທີ່ຍຸກธັນນະກໍາຈະຢູ່ໃນສວນ ແລະ ແມ່ນ້ໍາ, ໃນບ່ອນນັ່ງຂອງກຽດກວາຕໍ່ໜ້າກະສັດທີ່ຢຸງມີ.",
  "dailyScripture0Ref": "Quran 54:54-55",
  "dailyScripture1Text": "ແລະ ພວກເຮົາໄດ້ບໍ່ສົ່ງທ່ານ, [ໂອ Muhammad], ເວັ້ນແຕ່ວ່າເມດຕາກຣຸນາເພື່ອຜູ້ມະຫາວິທະຍາ.",
  "dailyScripture1Ref": "Quran 21:107",
  "dailyScripture2Text": "ບໍ່ Allah ພຽງພໍສໍາລັບບໍລິການຂອງວາລະ? ເຖິງວ່າພວກເຂົາໄດ້ວ່າທົ່ວໃຈທ່ານດ້ວຍອື່ນໆນອກຈາກວາລະ.",
  "dailyScripture2Ref": "Quran 39:36",
  "dailyScripture3Text": "ບາງທີທ່ານຢ້ານກົວບາງຢ່າງ ແລະ ມັນດີສໍາລັບທ່ານ; ແລະ ບາງທີທ່ານຮັກບາງຢ່າງ ແລະ ມັນບໍ່ດີສໍາລັບທ່ານ. ແລະ Allah ຮູ້, ຍ້ອນວ່າທ່ານບໍ່ຮູ້.",
  "dailyScripture3Ref": "Quran 2:216",
  "dailyScripture4Text": "ແທ້ຈິງແລ້ວ, Allah ແມ່ນກັບຜູ້ທີ່ອົດທົນ.",
  "dailyScripture4Ref": "Quran 2:153",
  "dailyScripture5Text": "ດັ່ງນັ້ນກະລຸນາຈື່ຂ້ອຍ; ຂ້ອຍຈະຈື່ທ່ານ. ແລະ ຂອບໃຈຂ້ອຍ ແລະ ບໍ່ປະຕິເສດຂ້ອຍ.",
  "dailyScripture5Ref": "Quran 2:152",
  "dailyScripture6Text": "ແທ້ຈິງແລ້ວ, ທີ່ສູງສຸດໃນສາຍຕາຂອງ Allah ແມ່ນທີ່ກົດຮັດທີ່ສຸດຂອງທ່ານ.",
  "dailyScripture6Ref": "Quran 49:13",
  "dailyScripture7Text": "ແລະ ພະຣະບົນຂອງທ່ານໄດ້ກໍາหນົດວ່າທ່ານກະຕັນຍູບໍ່ມີໃຄ່າຜະລິດ, ແລະ ວ່າທ່ານເພື່ອກຽດກວາພໍ່ແມ່ຂອງທ່ານ.",
  "dailyScripture7Ref": "Quran 17:23",
  "dailyScripture8Text": "ແທ້ຈິງແລ້ວ, ກັບຄວາມຍາກລໍາບາກມາກັບຄວາມສະສະ.",
  "dailyScripture8Ref": "Quran 94:6",
  "dailyScripture9Text": "ແລະ ວາລະກັບທ່ານບ່ອນໃດກໍ່ຕາມທີ່ທ່ານມີ. ແລະ Allah, ສິ່ງທີ່ທ່ານເຮັດ, ແມ່ນເບິ່ງເห็ນ.",
  "dailyScripture9Ref": "Quran 57:4",
  "dailyScripture10Text": "Allah ບໍ່ຮັກເຫມືອນວິນໍາທີ່ເກີນກວ່າສິ່ງທີ່ມັນສາມາດສົມທົບ.",
  "dailyScripture10Ref": "Quran 2:286",
  "dailyScripture11Text": "ແລະ ໃຜກໍ່ຕາມທີ່ອາໄສພຶ່ງອາດ Allah — ຫຼັງຈາກນັ້ນວາລະກໍ່ພຽງພໍສໍາລັບວາລະ.",
  "dailyScripture11Ref": "Quran 65:3",
  "dailyScripture12Text": "ເມດຕາກຣຸນາຂອງຂ້ອຍບົວທັງສິ່ງທີ່ມີ.",
  "dailyScripture12Ref": "Quran 7:156",
  "dailyScripture13Text": "ແລະ ເມື່ອບໍລິການຂອງຂ້ອຍຖາມທ່ານກ່ຽວກັບຂ້ອຍ — ແທ້ຈິງແລ້ວຂ້ອຍເກົ່າ. ຂ້ອຍກົງຕອບບໍລິການເມື່ອວາລະໂທສະຫຼັກກະຕໍ່ຂ້ອຍ.",
  "dailyScripture13Ref": "Quran 2:186",
  "dailyScripture14Text": "ໃຜກໍ່ຕາມທີ່ເຮັດຄວາມເມດຕາກຣຸນາ, ບໍ່ວ່າຊາຍ ຫຼື ຍິງ, ໃນຂະນະທີ່ເປັນຜູ້ສະໄດ້ — ພວກເຮົາຈະແນ່ນອນວ່າເຮັດໃຫ້ວາລະມີຊີວິດທີ່ດີ.",
  "dailyScripture14Ref": "Quran 16:97",
  "dailyScripture15Text": "ແທ້ຈິງແລ້ວ, Allah ຈະບໍ່ປ່ຽນເງື່ອນໄຂຂອງປະຊາຊົນຈົນກວ່າພວກເຂົາປ່ຽນສິ່ງທີ່ຢູ່ໃນຕົວເອງ.",
  "dailyScripture15Ref": "Quran 13:11",
  "dailyScripture16Text": "ດັ່ງນັ້ນບໍ່ລະ ແລະ ບໍ່ໂສກ, ແລະ ທ່ານຈະເຕີມກວ່າຖ້າທ່ານເປັນຜູ້ສະໄດ້ທີ່ແທ້ຈິງ.",
  "dailyScripture16Ref": "Quran 3:139",
  "dailyScripture17Text": "ໂອ ບໍລິການຂອງຂ້ອຍທີ່ໄດ້ລະເມີດກົນຕົວເອງ, ບໍ່ໝາຍຄວາມວ່າເມດຕາກຣຸນາຂອງ Allah. ແທ້ຈິງແລ້ວ, Allah ຮັກບາດກ້າວໃຫຍ່ທັງໝົດ.",
  "dailyScripture17Ref": "Quran 39:53",
  "dailyScripture18Text": "ແລະ ໃຜກໍ່ຕາມທີ່ຢ້ານກົວ Allah — ວາລະຈະເຮັດໃຫ້ວາລະເປັນວິທີອອກໄປ, ແລະ ຈະໃຫ້ວາລະຈາກບ່ອນທີ່ວາລະບໍ່ຄາດໝາຍ.",
  "dailyScripture18Ref": "Quran 65:2-3",
  "dailyScripture19Text": "ບໍ່ສູນເສຍຄວາມຫວັງໃນເມດຕາກຣຸນາຂອງ Allah.",
  "dailyScripture19Ref": "Quran 12:87",
  "dailyScripture20Text": "ແລະ ພວກເຮົາໄດ້ທົ່ວທຽວ Quran ງ່າຍກວ່າເພື່ອທົ່ວທຽວ. ດັ່ງນັ້ນມີບໍາຄົນໃດທີ່ມີຄວາມກະອື່ວ?",
  "dailyScripture20Ref": "Quran 54:17",
  "dailyScripture21Text": "ແລະ ວາລະພົບທ່ານສູນເສຍ ແລະ ນໍາທາງທ່ານ.",
  "dailyScripture21Ref": "Quran 93:7",
  "dailyScripture22Text": "ແລະ ພະຣະບົນຂອງທ່ານກ່າວວ່າ: ໄປຫາຂ້ອຍ; ຂ້ອຍຈະກົງຕອບທ່ານ.",
  "dailyScripture22Ref": "Quran 40:60",
  "dailyScripture23Text": "ແລະ ພວກເຮົາໄດ້ເດັກລັກສະນະລູກຂອງ Adam.",
  "dailyScripture23Ref": "Quran 17:70",
  "dailyScripture24Text": "ແລະ ຊອກຫາຄວາມຊ່ວຍເຫຼືອຜ່ານຄວາມອົດທົນ ແລະ ຄໍາອະທິຖານ.",
  "dailyScripture24Ref": "Quran 2:45",
  "dailyScripture25Text": "ໃຜກໍ່ຕາມທີ່ເຮັດບາ້ອະອາກາດຊະໜາດສາມາດເຫັນມັນ.",
  "dailyScripture25Ref": "Quran 99:7",
  "dailyScripture26Text": "ໂດຍບໍ່ມີສົງໂສ, ຄວາມຊ່ວຍເຫຼືອຂອງ Allah ແມ່ນໃກ້.",
  "dailyScripture26Ref": "Quran 2:214",
  "dailyScripture27Text": "ແລະ ໃຜກໍ່ຕາມທີ່ຂອບໃຈ — ກະຕັນຍູຂອງວາລະແມ່ນສໍາລັບຜົນປະໂຫຍດຂອງຕົວເອງ.",
  "dailyScripture27Ref": "Quran 31:12",

  "dailyReflection0": "ໃນຂະນະທີ່ມື້ປິດ, ພິจາລະນາຊ່ວງໜຶ່ງທີ່ເມດຕາກຣຸນາຂອງ Allah ແມ່ນຊັດເຈນ.",
  "dailyReflection1": "ປະເມີນຕໍ່ Allah ສິ່ງທີ່ໃຈຫາກຈາກທ່ານໃນມື້ຕົ້ນ.",
  "dailyReflection2": "ຕັ້ງຊື່ສະພາບໂຊກຊະໜາໜຶ່ງຈາກມື້ນີ້ ແລະ ສະດວກກະຕັນຍູຕໍ່ Allah.",
  "dailyReflection3": "ພັກຜ່ອນໃນຄວາມເຂົ້າໃຈວ່າທ່ານຖືກຖືກຜົນໃນຄວາມຂົນໃຈບໍ່ສຸດສອງຂອງ Allah.",
  "dailyReflection4": "ສະທ້ອນໃຈເກົ່ຽວກັບບ່ອນທີ່ທ່ານຮູ້ສຶກເຊື້ອເຊີນເພື່ອສະສະກະຕັນຍູ ແລະ ເມດຕາກຣຸນາໃນມື້.",
  "dailyReflection5": "ປ່ອຍໃຫ້ສາຍຂອງສິ່ງທີ່ທ່ານບໍ່ສາມາດຄວບຄຸມ ແລະ ເຊື່ອ Trust ໃນແຜນການທີ່ສົມບູນຂອງ Allah.",
  "dailyReflection6": "ໃນຂະນະທີ່ຕາເວັນອາ係, ຮັບກົວ່າສັນຕິພາບໃນຄໍາຈໍາໂລມຂອງ Allah.",
  "dailyReflection7": "ພິຈາລະນາວິທີທີ່ທ່ານມີກຽດກວາການອະທິຖານຂອງທ່ານໃນມື້ ແລະ ຂອບໃຈ Allah ສໍາລັບແຕ່ລະ.",
  "dailyReflection8": "ສະທ້ອນໃຈກ່ຽວກັບທີ່ມໍາວັນທີ່ຄວາມອົດທົນ (Sabr) ຊີວິດຂອງທ່ານໃນມື້.",
  "dailyReflection9": "ຂໍອະໄພສໍາລັບບໍ່ມົ້ຂອງມື້ — ເມດຕາກຣຸນາຂອງ Allah ແມ່ນບໍ່ສຸດ.",
  "dailyReflection10": "ຕັ້ງຊື່ຄົນໜຶ່ງທີ່ທ່ານສະສະກະຕັນຍູກະທຳໃນມື້ ແລະ ເຮັດ dua ສໍາລັບ.",
  "dailyReflection11": "ນັ່ງກັບຄວາມກະຕັນຍູ: ມື້ນີ້ Allah ສະໜອງວ່າທ່ານບໍ່ຂໍ?",
  "dailyReflection12": "ສະທ້ອນໃຈກ່ຽວກັບ verse ຈາກ Quran ທີ່ເວົ້າເຖິງບ່ອນທີ່ທ່ານຢູ່ຕອນນີ້.",
  "dailyReflection13": "ພິຈາລະນາວິທີທີ່ທ່ານໃຊ້ເວລາຂອງທ່ານໃນມື້ — ແລະ ສະໜອງພາຍຸກັບ Allah.",
  "dailyReflection14": "ພັກຜ່ອນໃນທີ່ວ່າຄວາມຍາກລໍາບາກໃດກໍ່ມາໃນມື້, Allah ແມ່ນກັບທ່ານໂດຍວິທີ.",
  "dailyReflection15": "ຄິດກ່ຽວກັບວ່າທ່ານປະຕິບັດຕໍ່ຄອບຄົວ ຫຼື ຊຸມຊົນຂອງທ່ານໃນມື້ສໍາລັບສາກຂອງ Allah.",
  "dailyReflection16": "ໃນຂະນະທີ່ຕາເວັນ, ເຮັດ Tawbah — Allah ຮັກຜູ້ທີ່ກັບໄປຫາວາລະ.",
  "dailyReflection17": "ສະທ້ອນໃຈກ່ຽວກັບຄວາມສວຍງາມ Allah ໃສ່ໃນມື້ຂອງທ່ານ, ສະໄດ້ຫນ້ອຍ.",
  "dailyReflection18": "ພິຈາລະນາສິ່ງທີ່ທ່ານຮຽນຮູ້ໃນມື້ ແລະ ວິທີທີ່ມັນດຶງທ່ານໃກ້ຊິດກັບ Allah.",
  "dailyReflection19": "ໂອ້ຄວາມວົນກະລັກຂອງມື້ພັກຜ່ອນກັບ Allah — ວາລະບາຸກສິ່ງທີ່ທ່ານບໍ່ສາມາດ.",
  "dailyReflection20": "ຄິດກ່ຽວກັບຊ່ວງທີ່ທ່ານຄວນໄດ້ເລືອກໃຫ້ດີກວ່າໃນມື້, ແລະ ຮຽນຮູ້ຈາກມັນອາໄຫວ້.",
  "dailyReflection21": "ເຮັດ dua ສໍາລັບຜູ້ທີ່ຕໍ່ສູ້ — ກະລຸນາຂອງທ່ານເປັນຂອງຂຶ້ນໃຫ້ກັບເຂົາ.",
  "dailyReflection22": "ຍົກຄືນສະພາບໂຊກຊະໜາທີ່ທ່ານມັກມື່ຍາກລໍາບາກ ແລະ ໃຊ້ເວລາທີ່ຈະ praise Allah ສໍາລັບ.",
  "dailyReflection23": "ສະທ້ອນໃຈກ່ຽວກັບຄວາມຕັ້ງໃຈຂອງທ່ານໃນມື້ — ມີ Allah ບໍ? ສະຕະຮູມວັນພາຍຸ.",
  "dailyReflection24": "ໃນຂະນະທີ່ຕາເວັນອາສ່างສົບ, ຟັງ Allah ເກົ່າໃກ້ສຸດໃນຄວາມງຽບສະຫຼາດ.",
  "dailyReflection25": "ກົ່າວ່າຊ່ວງໃນມື້ທີ່ທ່ານໄດ້ຕາເວັນກໍາລັງ — ກໍາລັງແມ່ນຈາກ Allah.",
  "dailyReflection26": "ຕັ້ງຊື່ສິ່ງໜຶ່ງທີ່ທ່ານຈະເຮັດໃນມື້ເດືອນ, ສໍາລັບ Allah ຂອງ, ທີ່ທ່ານບໍ່ໄດ້ເຮັດໃນມື້.",
  "dailyReflection27": "ໃນຂະນະທີ່ທ່ານກະກຽມຕົວເພື່ອພັກຜ່ອນ, ມອບຈິດໃຈຂອງທ່ານ Allah — ວາລະແມ່ນທີ່ດີທີ່ສຸດຂອງເຖົ້າ.",

