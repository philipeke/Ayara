  "promptDailyGuidance": "כתוב הנחיה יומית קצרה ומעשית המושרשת באמונה אסלאמית סונית, מבוססת על הקרآן, ההדיס ותורת הנביא מוחמד. בחר זווית טازה בכל פעם: סגולה מהאתיקה האסלאמית, אמת מהסונה, חכמה מהחברים של הנביא, או פרקטיקה שקטה מן המסורת האסלאמית. כלול פסוק אחד מהקרآן עם חלק ופסוק (סורה:אייה) והרהור של משפט או שניים להנצת לאורך היום. אופציונלי קשור זאת ללוח השנה האסלאמי או לתאריך חשוב אם רלוונטי.",

  "promptFaithTrust": "כתוב הרהור אסלאמי קצר על אימאן (אמונה) והשתמטות בתוכנית של אללה (תוקל). הנטע זאת בקרآן, בדוגמה של הנביא מוחמד ובאמונה של החברים. בחר זווית שונה בכל פעם: השתמטות בעת אי ודאות, הסתמכות על חוכמה אלוהית, סבלנות בניסיונות, או התעמדות שקטה בחיי היומיום. כלול פסוק קרآני אחד וצעד אחד כנה ליום שנמשך מחוכמה רוחנית אסלאמית.",

  "promptPrayerReflection": "כתוב הרהור תפילה אסלאמי קצר המושרש בסלאה, דועא או ד'יקר. בחר צורה שונה בכל פעם: זכר בוקר או ערב (אדכאר), הרהור על חמש התפילות היומיות, התבוננות בפסוק קרآני, או בקשה כנה. כלול פסוק קרآני אחד וציין בקצרה את צורת התפילה בה השתמשת.",

  "promptHopeDifficultTimes": "כתוב הרהור אסלאמי על סבלנות (סבר) וקווה בעת קשיים. הוצא מתורות קרآניות על ניסיונות, התעמדות הנביאים וחמלת אללה ברגעי קושי. בחר זווית שונה בכל פעם. כלול פסוק קרآני אחד ופרספקטיבה אחת מעודדת מן המסורת האסלאמית.",

  "promptForgiveness": "כתוב הרהור אסלאמי חכם על בקשת סליחה (תובה) וחמלת אללה. הוצא מתורות קרآניות על תשובה, החמלה של אללה ודוגמה הסולחת של הנביא מוחמד. בחר זווית שונה: חזרה לאללה, סליחה לאחרים, ריפוי קשרים, או אמונה בחמלת אללה אחרי טעויות. כלול פסוק קרآני אחד וצעד קונקרטי אחד.",

  "promptLoveCompassion": "כתוב הרהור אסלאמי קצר על חמלה (רחמה) וחמלה בחיי היומיום. הוצא מדוגמת הנביא מוחמד, תפיסת אחסאן (השלמות) ותורות אסלאמיות על אדיבות כלפי משפחה, שכנים וחלושים. כלול פסוק קרآני אחד ופעילות אחת של חמלה קטנה לתרגול היום.",

  "promptStrengthCourage": "כתוב הרהור אסלאמי על חוזק המבוסס על אמונה וגבורה. הוצא מדוגמות של הנביאים, הקהילה המוסלמית המוקדמת ומאמינים שנשארו חזקים בקשיים. בחר זווית שונה בכל פעם: גבורה דרך אמונה, חוזק בתפילה, השתמטות בעת פחד, או עמידות בקושי. כלול פסוק קרآני אחד וביקשה קצרה או ביטוי זכר.",

  "promptGratitude": "כתוב הרהור אסלאמי על הכרת תודה (שוקר) כלפי אללה. הנטע זאת בתורות קרآניות ומסורת נביאית. בחר זווית שונה: הכרת תודה בקושי, הערכת ברכות קטנות, התחלת היום בתהילה של אללה, או הכרה בהנחיית אללה בחיי היומיום. כלול פסוק קרآני אחד ופרקטיקה אחת של הכרת תודה.",

  "promptPurposeCalling": "כתוב הרהור אסלאמי על מטרת החיים בעבודת אללה וחיים צודקים. הוצא מתורות קרآניות על מטרה, שירות לאחרים והשימוש בכישרונות לטוב. בחר זווית שונה בכל פעם: שירות למשפחה וקהילה, חיפוש הנחיה דרך איסטיכאראה, חיים בכוונה, או מציאת משמעות בעבודה רגילה. כלול פסוק קרآני אחד ושתי שאלות הרהור.",

  "promptFamilyRelationships": "כתוב הנחיה אסלאמית חכמה על משפחה וקשרים המושרשים בתורות קרآניות ובדוגמת הנביא מוחמד. בחר זווית שונה בכל פעם: אדיבות בחיי משפחה, סבלנות בסכסוך, כיבוד הוריים, גדול ילדים באמונה, או חיזוק נישואין. כלול פסוק קרآני אחד ופרקטיקה יחסית אחת לנסיון.",

  "promptPeaceAnxietyRelief": "כתוב הרהור אסלאמי מרגיע על מציאת שלום פנימי דרך זכר אללה (ד'יקר) והשתמטות בתוכניתו. הוצא מתורות קרآניות על שלווה של הלב, תפילה והשמטה לרצון אללה. בחר גישה שונה בכל פעם וכלול פסוק קרآני אחד ופרקטיקה אחת פשוטה מן המסורת האסלאמית.",

  "promptWisdomOfJesus": "כתוב חלק קצר של חוכמה מהנביאים כפי שנלמד בד'אים. הוצא מהקרآן או הדיס והסבר בקצרה כיצד חכמים אסלאמיים הבינו את התורה. בחר נושא שונה בכל פעם: אופי, סבלנות, ענווה, אמונה, או התנהגות יומית. כלול ציטוט קרآני או הפניית דיס והחלה מעשית אחת.",

  "promptHumilityCharacter": "כתוב הרהור אסלאמי על ענווה (תואדעו) וביצוע טוב (אכלאק). הוצא מתורות קרآניות, מדוגמת הנביא מוחמד וממסורת פיתוח אופי אסלאמי. בחר זווית שונה: ענווה בהנהגה, הודאה בטעויות, התיחסות לאחרים בכבוד, או גדילה רוחנית דרך התבוננות עצמית. כלול פסוק קרآני אחד והרגל אחד לתרגול.",

  "promptOvercomingTemptation": "כתוב הרהור אסלאמי על התנגדות לפיתוי ושמירה על הדרך הישרה. הוצא מהנחיות קרآניות, זכר אללה (ד'יקר), תפילה (סלאה) ודוגמות של מאמינים שהתגברו על קשיים. בחר זווית שונה בכל פעם. כלול פסוק קרآני אחד ואסטרטגיה מעשית אחת ל24 השעות הבאות.",

  "promptEveningReflection": "כתוב הרהור ערב אסלאמי שלווה המושרש במסורת זכר ערב (אדכאר אל-מסאא). עודד הכרת תודה, התבוננות עצמית (מוחאסבה) והשתמטות בעת כניסה למנוחה. כלול 3–5 הנחיות הרהור קצרות על היום, בקשה קצרה וסיגום, ופסוק קרآני אחד.",

