  "tasbihatScreenDescription": "ದೈನಂದಿನ ನಮಾಝ್ ಸಮಯದಲ್ಲಿ ಮತ್ತು ಅದರ ನಂತರ ಪಠಿಸುವ ತಸ್ಬೀಹ್‌ಗಳ ಸಂಪೂರ್ಣ ಮಾರ್ಗದರ್ಶಿ — ಅಹ್ಲ್ ಅಲ್-ಬೈತ್ (a) ಪರಂಪರೆಯನ್ನು ಅನುಸರಿಸಿ.",
  "tasbihatArba3Title": "ತಸ್ಬೀಹಾತ್ ಅಲ್-ಅರ್ಬಅ",
  "tasbihatArba3Subtitle": "3ನೇ ಮತ್ತು 4ನೇ ರಕಅತ್‌ನಲ್ಲಿ ಪಠಿಸಲಾಗುತ್ತದೆ",
  "tasbihatArba3Info": "ಶಿಯಾ ಫಿಖ್‌ನಲ್ಲಿ, ತಸ್ಬೀಹಾತ್ ಅಲ್-ಅರ್ಬಅ ಜುಹರ್, ಅಸರ್, ಮಘ್ರಿಬ್ ಮತ್ತು ಇಶಾ ನಮಾಝ್‌ನ 3ನೇ ಮತ್ತು 4ನೇ ರಕಅತ್‌ನಲ್ಲಿ ಸೂರಾ ಅಲ್-ಫಾತಿಹಾ ಬದಲಿಗೆ ಪಠಿಸಲಾಗುತ್ತದೆ. ಅದನ್ನು ಒಮ್ಮೆ ಪಠಿಸುವುದು ವಾಜಿಬ್, ಮತ್ತು ಮೂರು ಬಾರಿ ಪಠಿಸುವುದು ಮುಸ್ತಹಬ್.",
  "tasbihatArba3Translation": "ಅಲ್ಲಾಹನಿಗೆ ಮಹಿಮೆ · ಎಲ್ಲಾ ಸ್ತುತಿಯೂ ಅಲ್ಲಾಹನಿಗೇ ಸೇರಿದೆ\nಅಲ್ಲಾಹ ಹೊರತು ಬೇರೆ ದೇವರಿಲ್ಲ · ಅಲ್ಲಾಹ ಅತ್ಯಂತ ಮಹಾನ್",
  "tasbihatArba3CompleteTitle": "ಪಠಣ ಪೂರ್ಣಗೊಂಡಿದೆ",
  "tasbihatArba3CompleteMessage": "ನಿಮ್ಮ ನಮಾಝ್ ಸ್ವೀಕರಿಸಲ್ಪಡಲಿ — ಆಮೀನ್",
  "tasbihatArba3TapHint": "ಪ್ರತಿ ಪಠಣದ ನಂತರ ತಟ್ಟಿರಿ",
  "tasbihatZahraSubtitle": "ಪ್ರತಿ ನಮಾಝ್ ನಂತರ · 100 ಮಣಿಗಳು",
  "tasbihatZahraOriginLabel": "ಮೂಲ",
  "tasbihatZahraHadith": "ಸಯ್ಯಿದಾ ಫಾತಿಮಾ ಅಲ್-ಜಹ್ರಾ (sa) ಪ್ರವಾದಿ ﷺ ಅವರಲ್ಲಿ ಒಬ್ಬ ಸೇವಕನನ್ನು ಕೇಳಿದರು. ಅವರು ಹೇಳಿದರು: \"ನಾನು ಅದಕ್ಕಿಂತ ಉತ್ತಮವಾದುದನ್ನು ತೋರಿಸಲೇಬೇಕೆ? ಪ್ರತಿ ನಮಾಝ್‌ನ ನಂತರ ಸುಭ್ಹಾನಲ್ಲಾಹ್ 33 ಬಾರಿ, ಅಲ್ಹಮ್ದುಲಿಲ್ಲಾಹ್ 33 ಬಾರಿ, ಮತ್ತು ಅಲ್ಲಾಹು ಅಕ್ಬರ್ 34 ಬಾರಿ ಹೇಳು. ಅದು ನಿನಗೆ ಸೇವಕನಿಗಿಂತ ಉತ್ತಮ.\"",
  "tasbihatZahraHadithSource": "— ಬಿಹಾರ್ ಅಲ್-ಅನ್ವಾರ್, ಸಂಪುಟ 85",
  "tasbihatZahraOpenCounter": "ತಸ್ಬೀಹ್ ಕೌಂಟರ್ ತೆರೆಯಿರಿ",
  "tasbihatDuasTitle": "ಶಿಫಾರಸು ಮಾಡಿದ ದುವಾಗಳು",
  "tasbihatDuasSubtitle": "ನಿಮ್ಮ ನಮಾಝ್ ಪೂರ್ಣವಾದ ನಂತರ",
  "tasbihatDuaAyatKursiTitle": "ಆಯತುಲ್ ಕುರ್ಸಿ",
  "tasbihatDuaAyatKursiWhen": "ಪ್ರತಿ ಫರ್ಡ್ ನಮಾಝ್ ನಂತರ",
  "tasbihatDuaAyatKursiSource": "ಸೂರಾ ಅಲ್-ಬಖರಾ 2:255",
  "tasbihatDuaAyatKursiNote": "ಪ್ರತಿ ಫರ್ಡ್ ನಮಾಝ್ ನಂತರ ಆಯತುಲ್ ಕುರ್ಸಿಯನ್ನು ಪಠಿಸುವವನ ಮತ್ತು ಸ್ವರ್ಗದ ನಡುವೆ ಮರಣ ಹೊರತು ಮತ್ತೇನೂ ಇರುವುದಿಲ್ಲ. ಇಮಾಮ್ ಅಲ್-ಬಾಕಿರ್ (a) ಅವರು ಅದು ಕುರ್‌ಆನ್‌ನ ಮಹಾನ್ ಆಯತ್‌ಗಳಲ್ಲಿ ಒಂದೆಂದು ಹೇಳಿದರು.",
  "tasbihatDuaSalawatTitle": "ಸಲವಾತ್",
  "tasbihatDuaSalawatWhen": "ಪ್ರತಿ ನಮಾಝ್ ನಂತರ · ಎಲ್ಲಾ ದುವಾಗಳನ್ನು ಪೂರ್ಣಗೊಳಿಸುತ್ತದೆ",
  "tasbihatDuaSalawatSource": "ಇಮಾಮ್ ಅಲ್-ಸಾದಿಕ್ (a) — ಅಲ್-ಕಾಫಿ",
  "tasbihatDuaSalawatNote": "ಪ್ರವಾದಿ ﷺ ಮತ್ತು ಅವರ ಪರಿಶುದ್ಧ ಕುಟುಂಬದ (ಆಲ್ ಮುಹಮ್ಮದ್) ಮೇಲೆ ಸಲವಾತ್ ಕಳುಹಿಸುವುದು ಪ್ರತಿ ದುವಾವನ್ನು ಪೂರ್ಣಗೊಳಿಸಲು ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ. ಇಮಾಮ್ ಅಲ್-ಸಾದಿಕ್ (a) ಹೇಳಿದರು: \"ನೀನು ಮುಹಮ್ಮದ್ ಮತ್ತು ಅವರ ಕುಟುಂಬದ ಮೇಲೆ ಸಲವಾತ್ ಕಳುಹಿಸುವವರೆಗೆ ಯಾವುದೇ ದುವಾ ಸ್ಥಗಿತವಾಗಿರುತ್ತದೆ.\"",
  "tasbihatDuaFarajTitle": "ದುಆ ಅಲ್-ಫರಜ್",
  "tasbihatDuaFarajWhen": "ಪ್ರತಿ ನಮಾಝ್ ನಂತರ · ನಮ್ಮ ಕಾಲದ ಇಮಾಮ್‌ಗಾಗಿ",
  "tasbihatDuaFarajSource": "ಇಮಾಮ್ ಅಲ್-ಹಸನ್ ಅಲ್-ಅಸ್ಕರಿ (a) ಕಲಿಸಿದ್ದಾರೆ",
  "tasbihatDuaFarajNote": "ಹನ್ನೆರಡನೇ ಇಮಾಮ್ ಇಮಾಮ್ ಅಲ್-ಮಹ್ದಿ (af) ಅವರ ಮರುಪ್ರತ್ಯಕ್ಷತೆಗಾಗಿ ಮಾಡುವ ದುವಾ, ಇದನ್ನು ಅವರ ತಂದೆ ಕಲಿಸಿದರು. ಜೀವಂತ ಇಮಾಮ್‌ನ ಭಕ್ತಿಯ ಕೃತ್ಯವಾಗಿ ಶಿಯಾ ಭಕ್ತರು ಪ್ರತಿದಿನ ಪ್ರತಿ ನಮಾಝ್ ನಂತರ ಇದನ್ನು ಪಠಿಸುತ್ತಾರೆ.",
  "tasbihatDuaTasbihFatimaTitle": "ಸಯ್ಯಿದಾ ಫಾತಿಮಾರ ತಸ್ಬೀಹ್",
  "tasbihatDuaTasbihFatimaWhen": "ಮಘ್ರಿಬ್ ಮತ್ತು ಇಶಾ ನಂತರ · ವಿಶೇಷವಾಗಿ ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ",
  "tasbihatDuaTasbihFatimaSource": "ಇಮಾಮ್ ಅಲ್-ಬಾಕಿರ್ (a) — ಬಿಹಾರ್ ಅಲ್-ಅನ್ವಾರ್",
  "tasbihatDuaTasbihFatimaNote": "ಇಮಾಮ್ ಅಲ್-ಬಾಕಿರ್ (a) ಅವರು, ಇಶಾ ನಂತರ ಮಲಗುವ ಮೊದಲು ತಸ್ಬೀಹ್ ಅಲ್-ಜಹ್ರಾ ಪಠಿಸುವುದು 1000 ರಕಅತ್ ನಫ್ಲ್ ನಮಾಝ್‌ಗಿಂತ ಉತ್ತಮ ಎಂದು ಹೇಳಿದರು. ಅದರ ಬೆಳಕು ಆಕಾಶಗಳಿಗೆ ಏರುತ್ತದೆ.",
