  "promptDailyGuidance": "ಸುನ್ನಿ ಇಸ್ಲಾಮಿಕ ಮಾನ್ಯತೆಗೆ ಆಧಾರಿತ ಸಂಕ್ಷಿಪ್ತ, ಪ್ರಾಯೋಗಿಕ ದೈನಂದಿನ ಮಾರ್ಗದರ್ಶನ ಬರೆಯಿರಿ — ಕುರಾನ್, ಹದೀಸ್ ಮತ್ತು ಪ್ರವಾದಿ ಮುಹಮ್ಮದ್ ಯ ಬೋಧನೆಗಳಿಂದ ನೆಲಸಮ ಬೆಳಿತ. ಪ್ರತಿ ಬಾರಿ ತಾಜಾ ದೃಷ್ಟಿಕೋನ ಆಯ್ಕೆ ಮಾಡಿ: ಇಸ್ಲಾಮಿಕ ನೈತಿಕತೆಯಿಂದ ಒಂದು ಗುಣ, ಸುನ್ನತ್ ದಿಂದ ಒಂದು ಸತ್ಯ, ಪ್ರವಾದಿಯ ಸಾಥಿಗಳಿಂದ ಜ್ಞಾನ ಅಥವಾ ಇಸ್ಲಾಮಿಕ ಪರಂಪರೆಯಿಂದ ಶಾಂತ ಅಭ್ಯಾಸ. ಒಂದು ಕುರಾನ್ ಆಯಾತ (ಸೂರಾ:ಆಯಾತ) ಮತ್ತು ದಿನದ ಮೂಲಕ ಒಯ್ಯುವುದಕ್ಕಾಗಿ ಒಂದು 1-2 ವಾಕ್ಯಗಳ ಪ್ರತಿಫಲನ ಸೇರಿಸಿ. ಅನಿವಾರ್ಯವಾಗಿ ಇದನ್ನು ಇಸ್ಲಾಮಿಕ ಕ್ಯಾಲೆಂಡರ್ ಅಥವಾ ಒಂದು ಮುಖ್ಯ ದಿನಾಂಕಕ್ಕೆ ಸಂಪರ್ಕಿಸಿ.",

  "promptFaithTrust": "ಈಮಾನ್ (ವಿಶ್ವಾಸ) ಮತ್ತು ಅಲ್ಲಾಹನ ಯೋಜನೆಗೆ ನಿಭಾಯಿಸುವಿಕೆ (ತವಕ್ಕಲ್) ಕುರಿತು ಸಂಕ್ಷಿಪ್ತ ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಇದನ್ನು ಕುರಾನ್, ಪ್ರವಾದಿ ಮುಹಮ್ಮದ್ ಯ ಉದಾಹರಣೆ ಮತ್ತು ಸಾಹಾಬಾ (ಪ್ರವಾದಿ ಸಾಥಿಗಳು) ರ ಈಮಾನ್‌ನಲ್ಲಿ ಆಧಾರಿತ ಮಾಡಿ. ಪ್ರತಿ ಬಾರಿ ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ಅನಿಶ್ಚಿತತೆಯ ಸಮಯದಲ್ಲಿ ಅಲ್ಲಾಹನಲ್ಲಿ ಸರಿದೋಸೆ ಇಡುವುದು, ದೈವಿಕ ಜ್ಞಾನದ ಮೇಲೆ ಅವಲಂಬನೆ, ಪರೀಕ್ಷೆಗಳಲ್ಲಿ ಅವುಡ್ಳೆ ಅಥವಾ ಪ್ರತಿದಿನದ ಜೀವನದಲ್ಲಿ ಧೈರ್ಯವಾದ ಧೈರ್ಯ. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಇಸ್ಲಾಮಿಕ ಆಧ್ಯಾತ್ಮಿಕ ಜ್ಞಾನದಿಂದ ಪಡೆದ ಇಂದಿನ ಒಂದು ಪ್ರಾಮಾಣಿಕ ಹೆಜ್ಜೆ ಸೇರಿಸಿ.",

  "promptPrayerReflection": "ನಮಾಜ, ದುಆ ಅಥವಾ ಧಿಕ್ರಲ್ಲಿ ಆಧಾರಿತ ಸಂಕ್ಷಿಪ್ತ ಇಸ್ಲಾಮಿಕ ನಮಾಜ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಪ್ರತಿ ಬಾರಿ ಫಾರ್ಮ್‌ಟ್‌ಅನ್ನು ಬದಲಾಯಿಸಿ: ಬೆಳಿಗ್ಗೆ ಅಥವಾ ಸಂಜೆಯ ಜ್ಞಾಪನೆ (ಅದ್ಖಾರ), ಐದು ದೈನಂದಿನ ನಮಾಜಗಳ ಮೇಲೆ ಪ್ರತಿಫಲನ, ಒಂದು ಕುರಾನ್ ವಾಕ್ಯದ ಧ್ಯಾನ ಅಥವಾ ಪ್ರಾಮಾಣಿಕ ವಿನಂತಿ. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಬಳಸಿದ ನಮಾಜ ಫಾರ್ಮ್‌ಟ್‌ಅನ್ನು ಸಂಕ್ಷಿಪ್ತವಾಗಿ ಹೆಸರಿಸಿ.",

  "promptHopeDifficultTimes": "ಕಷ್ಟದ ಸಮಯಗಳಲ್ಲಿ ಅವುಡ್ಳೆ (ಧೈರ್ಯ) ಮತ್ತು ಭರವಸೆ ಕುರಿತು ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಪರೀಕ್ಷೆಗಳ ಕುರಾನ್ ಬೋಧನೆಗಳು, ಪ್ರವಾದಿಗಳ ಅವುಡ್ಳೆ ಮತ್ತು ಕಷ್ಟದ ಕ್ಷಣಗಳಲ್ಲಿ ಅಲ್ಲಾಹನ ದಯೆಯಿಂದ ತೆಗೆದುಕೊಂಡಿ. ಪ್ರತಿ ಬಾರಿ ದೃಷ್ಟಿಕೋನ ಬದಲಾಯಿಸಿ. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಇಸ್ಲಾಮಿಕ ಪರಂಪರೆಯಿಂದ ಒಂದು ಆತ್ಮೀಯ ದೃಷ್ಟಿಕೋನ ಸೇರಿಸಿ.",

  "promptForgiveness": "ಕ್ಷಮಾಪನೆ (ತೌಬಾ) ಅನ್ವೇಷಣ ಮತ್ತು ಅಲ್ಲಾಹನ ದಯೆ ಕುರಿತು ವಿವೇಚನೆಶೀಲ ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ತೌಬಾ ಸಂಬಂಧೀಯ ಕುರಾನ್ ಬೋಧನೆಗಳು, ಅಲ್ಲಾಹನ ಕರುಣೆ ಮತ್ತು ಪ್ರವಾದಿ ಮುಹಮ್ಮದ್ ಯ ಕ್ಷಮಾಶೀಲ ಉದಾಹರಣೆ ಇಂದಿಂದ ತೆಗೆದುಕೊಂಡಿ. ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ಅಲ್ಲಾಹನ ಕಡೆಗೆ ಫಿರಿ ಸೋಲು, ಇತರರನ್ನು ಕ್ಷಮಿಸುವುದು, ಸಂಬಂಧ ಸೋಲು ಅಥವಾ ತಪ್ಪುಗಳ ನಂತರ ಅಲ್ಲಾಹನ ದಯೆಗೆ ನಂಬುವುದು. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಒಂದು ವಾಸ್ತವಿಕ ಹೆಜ್ಜೆ ಸೇರಿಸಿ.",

  "promptLoveCompassion": "ದೈನಂದಿನ ಜೀವನದಲ್ಲಿ ದಯೆ (ರಹ್ಮಾ) ಮತ್ತು ಸಹಾನುಭೂತಿ ಕುರಿತು ಸಂಕ್ಷಿಪ್ತ ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಪ್ರವಾದಿ ಮುಹಮ್ಮದ್ ಯ ಉದಾಹರಣೆ, ಅಹ್ಸಾನ್ ಪರಿಕಲ್ಪನೆ (ಶ್ರೇಷ್ಠತ್ವ) ಮತ್ತು ಕುಟುಂಬ, ನೆರೆಹೋರು ಮತ್ತು ದುರ್ಬಲರ ಪ್ರತಿ ದಯೆಯ ಇಸ್ಲಾಮಿಕ ಬೋಧನೆಗಳಿಂದ ತೆಗೆದುಕೊಂಡಿ. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಇಂದು ಅಭ್ಯಾಸ ಮಾಡಲು ಸಹಾನುಭೂತಿಯ ಒಂದು ಸಣ್ಣ ಕಾರ್ಯ ಸೇರಿಸಿ.",

  "promptStrengthCourage": "ವಿಶ್ವಾಸ-ಆಧಾರಿತ ಶಕ್ತಿ ಮತ್ತು ಧೈರ್ಯ ಕುರಿತು ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಪ್ರವಾದಿಗಳ ಉದಾಹರಣೆಗಳು, ಆರಂಭಿಕ ಮುಸ್ಲಿಮ ಸಮುದಾಯ ಮತ್ತು ಕಷ್ಟದಲ್ಲಿ ಸ್ಥಿರ ನಂಬಿದವರಿಂದ ತೆಗೆದುಕೊಂಡಿ. ಪ್ರತಿ ಬಾರಿ ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ವಿಶ್ವಾಸದ ಮೂಲಕ ಧೈರ್ಯ, ನಮಾಜದ ಮೂಲಕ ಶಕ್ತಿ, ಭಯದ ಸಮಯದಲ್ಲಿ ಅಲ್ಲಾಹನಲ್ಲಿ ವಿಶ್ವಾಸ ಅಥವಾ ಕಷ್ಟದಲ್ಲಿ ಧೈರ್ಯ. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಒಂದು ಸಂಕ್ಷಿಪ್ತ ವಿನಂತಿ ಅಥವಾ ಜ್ಞಾಪನೀಯ ವಾಕ್ಯ ಸೇರಿಸಿ.",

  "promptGratitude": "ಅಲ್ಲಾಹನ ಕೃತಜ್ಞತೆ (ಶುಕ್ರ) ಕುರಿತು ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಇದನ್ನು ಕುರಾನ್ ಬೋಧನೆ ಮತ್ತು ನಾಬಿ ಪರಂಪರೆಯಿಂದ ಆಧಾರ ಮಾಡಿ. ದೃಷ್ಟಿಕೋನ ಬದಲಾಯಿಸಿ: ಕಷ್ಟದಲ್ಲಿ ಕೃತಜ್ಞತೆ, ಸಣ್ಣ ಆಶೀರ್ವಾದಗಳನ್ನು ಪ್ರಶಂಸಿಸುವುದು, ದಿನವನ್ನು ಅಲ್ಲಾಹನ ಪ್ರಶಂಸೆಯೊಂದಿಗೆ ಪ್ರಾರಂಭಿಸುವುದು ಅಥವಾ ದೈನಂದಿನ ಜೀವನದಲ್ಲಿ ಅಲ್ಲಾಹನ ಮಾರ್ಗದರ್ಶನವನ್ನು ಸ್ವೀಕರಿಸುವುದು. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಒಂದು ಕೃತಜ್ಞತೆ ಅಭ್ಯಾಸ ಸೇರಿಸಿ.",

  "promptPurposeCalling": "ಅಲ್ಲಾಹನ ಅನುಮೋದನೆ ಮತ್ತು ನೈತಿಕತೆಯಿಂದ ಬಾಳುವುದರ ಮುಖ್ಯಾರ್ಥ ಕುರಿತು ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಉದ್ದೇಶ, ಇತರರನ್ನು ಸೇವೆ ಮಾಡುವುದು ಮತ್ತು ತನ್ನ ನಿಯೋಗಗಳನ್ನು ಒಳ್ಳೆಯ ಕೆಲಸಕ್ಕೆ ಬಳಸುವುದರ ಕುರಾನ್ ಬೋಧನೆಗಳಿಂದ ತೆಗೆದುಕೊಂಡಿ. ಪ್ರತಿ ಬಾರಿ ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ಕುಟುಂಬ ಮತ್ತು ಸಮುದಾಯಕ್ಕೆ ಸೇವೆ, ಇಸ್ತಿಖಾರಾ ಮೂಲಕ ಮಾರ್ಗದರ್ಶನ ಖೋಜುವುದು, ಉದ್ದೇಶದೊಂದಿಗೆ ಬಾಳುವುದು ಅಥವಾ ಸಾಮಾನ್ಯ ಕೆಲಸದಲ್ಲಿ ಅರ್ಥವನ್ನು ಕಂಡುಹಿಡಿಯುವುದು. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಎರಡು ಚಿಂತನೀಯ ಪ್ರಶ್ನೆಗಳು ಸೇರಿಸಿ.",

  "promptFamilyRelationships": "ಕುರಾನ್ ಬೋಧನೆ ಮತ್ತು ಪ್ರವಾದಿ ಮುಹಮ್ಮದ್ ಯ ಉದಾಹರಣೆಯಲ್ಲಿ ಆಧಾರಿತ ಕುಟುಂಬ ಮತ್ತು ಸಂಬಂಧಗಳ ಬುದ್ಧಿವಂತ ಇಸ್ಲಾಮಿಕ ಮಾರ್ಗದರ್ಶನ ಬರೆಯಿರಿ. ಪ್ರತಿ ಬಾರಿ ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ಕುಟುಂಬ ಜೀವನದಲ್ಲಿ ದಯೆ, ಸಂಘರ್ಷದಲ್ಲಿ ಸಹನೆ, ಪೋಷಕರನ್ನು ಘನ್ಯ ಮಾಡುವುದು, ಈಮಾನ್‌ನಲ್ಲಿ ಮಕ್ಕಳನ್ನು ಕಾಲುಬೆಳೆಯುವುದು ಅಥವಾ ವಿವಾಹವನ್ನು ಶಕ್ತಿಶಾಲಿ ಮಾಡುವುದು. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಒಂದು ಸಂಬಂಧಿತ ಅಭ್ಯಾಸ ಪ್ರಯತ್ನ ಸೇರಿಸಿ.",

  "promptPeaceAnxietyRelief": "ಅಲ್ಲಾಹನ ಜ್ಞಾಪನೆ (ಧಿಕ್ರ) ಮತ್ತು ಅವನ ಯೋಜನೆಗೆ ನಿಭಾಯಿಸುವಿಕೆಯ ಮೂಲಕ ಆಂತರಿಕ ಶಾಂತಿ ಕಂಡುಹಿಡಿಯುವುದರ ಕುರಿತು ಜಗತ್ತಿನ ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಹೃದಯದ ಶಾಂತಿ, ನಮಾಜ ಮತ್ತು ಅಲ್ಲಾಹನ ಇಚ್ಛೆಗೆ ಸರಿದೋಸೆ ಇಡುವುದರ ಕುರಾನ್ ಬೋಧನೆಗಳಿಂದ ತೆಗೆದುಕೊಂಡಿ. ಪ್ರತಿ ಬಾರಿ ವಿಧಾನವನ್ನು ಬದಲಾಯಿಸಿ ಮತ್ತು ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಇಸ್ಲಾಮಿಕ ಪರಂಪರೆಯಿಂದ ಒಂದು ಸರಳ ಆಧಾರ ಅಭ್ಯಾಸ ಸೇರಿಸಿ.",

  "promptWisdomOfJesus": "ಇಸ್ಲಾಮಲ್ಲಿ ಕಲಿಸಿದಂತೆ ಪ್ರವಾದಿಗಳಿಂದ ಜ್ಞಾನದ ಒಂದು ಸಣ್ಣ ತುಂಡು ಬರೆಯಿರಿ. ಕುರಾನ್ ಅಥವಾ ಹದೀಸ್ ಇಂದಿಂದ ತೆಗೆದುಕೊಂಡಿ ಮತ್ತು ಇಸ್ಲಾಮಿಕ ವಿದ್ವಾಂಸರು ಬೋಧನೆಯನ್ನು ಹೇಗೆ ಮೂಲ್ಯಮಾಪನ ಮಾಡಿದ್ದಾರೆ ಎಂಬುದು ಸಂಕ್ಷಿಪ್ತವಾಗಿ ವಿವರಿಸಿ. ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ಚರಿತ್ರೆ, ಧೈರ್ಯ, ನಮ್ರತೆ, ಈಮಾನ್ ಅಥವಾ ದೈನಂದಿನ ನಡತೆ. ಕುರಾನ್ ವಾಕ್ಯ ಅಥವಾ ಹದೀಸ್ ಉಲ್ಲೇಖ ಮತ್ತು ಒಂದು ಪ್ರಾಯೋಗಿಕ ಅನುಪ್ರಯೋಗ ಸೇರಿಸಿ.",

  "promptHumilityCharacter": "ನಮ್ರತೆ (ತವಾಧು) ಮತ್ತು ಉತ್ತಮ ಚರಿತ್ರೆ (ಅಖ್ಲಾಕ) ಕುರಿತು ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಕುರಾನ್ ಬೋಧನೆಗಳು, ಪ್ರವಾದಿ ಮುಹಮ್ಮದ್ ಯ ಉದಾಹರಣೆ ಮತ್ತು ಇಸ್ಲಾಮಿಕ ಚರಿತ್ರೆ ಅಭಿವೃದ್ಧಿ ಪರಂಪರೆಯಿಂದ ತೆಗೆದುಕೊಂಡಿ. ವಿಷಯವನ್ನು ಬದಲಾಯಿಸಿ: ನೇತೃತ್ವದಲ್ಲಿ ನಮ್ರತೆ, ತಪ್ಪುಗಳನ್ನು ಒಪ್ಪಿಕೊಳ್ಳುವುದು, ಇತರರನ್ನು ಆದರಿನೊಂದಿಗೆ ಪರಿಚಿತರಾಗಿ ಕೈ ಹಿಡಿಯುವುದು ಅಥವಾ ಆತ್ಮ ಚಿಂತನೆಯ ಮೂಲಕ ಆಧ್ಯಾತ್ಮಿಕವಾಗಿ ಬೆಳೆಯುವುದು. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಅಭ್ಯಾಸ ಮಾಡಲು ಒಂದು ಅಭ್ಯಾಸ ಸೇರಿಸಿ.",

  "promptOvercomingTemptation": "ಪ್ರಲೋಭನಾ ನಿರೋಧ ಮತ್ತು ನೇರ ಮಾರ್ಗದ ಮೇಲೆ ಇಂತಿಹಾಮ ರಕ್ಷಾ ಕುರಿತು ಇಸ್ಲಾಮಿಕ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಕುರಾನ್ ಮಾರ್ಗದರ್ಶನ, ಅಲ್ಲಾಹನ ಜ್ಞಾಪನೆ (ಧಿಕ್ರ), ನಮಾಜ (ನಮಾಜ) ಮತ್ತು ಸಂಘರ್ಷಗಳನ್ನು ಜಯಿಸಿದ ನಂಬಿದವರ ಉದಾಹರಣೆಗಳಿಂದ ತೆಗೆದುಕೊಂಡಿ. ಪ್ರತಿ ಬಾರಿ ದೃಷ್ಟಿಕೋನ ಬದಲಾಯಿಸಿ. ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಮತ್ತು ಮುಂದಿನ 24 ಗಂಟೆಗಳಿಗೆ ಒಂದು ವಾಸ್ತವಿಕ ಕೌಶಲ್ಯ ಸೇರಿಸಿ.",

  "promptEveningReflection": "ಸಂಜೆಯ ಜ್ಞಾಪನೆ (ಅದ್ಖಾರ ಅಲ್-ಮಸಾ) ರ ಪರಂಪರೆಯಲ್ಲಿ ಆಧಾರಿತ ಶಾಂತ ಇಸ್ಲಾಮಿಕ ಸಂಜೆಯ ಪ್ರತಿಫಲನ ಬರೆಯಿರಿ. ಕೃತಜ್ಞತೆ, ಆತ್ಮ ಚಿಂತನೆ (ಮುಹಾಸಬಾ) ಮತ್ತು ವಿಶ್ರಾಮದ ಮುಂಚೆ ಅಲ್ಲಾಹನಲ್ಲಿ ನಿಭಾಯಿಸುವಿಕೆ ಪ್ರೋತ್ಸಾಹಿಸಿ. 3-5 ಸಣ್ಣ ಪ್ರತಿಫಲನ ವಿನ್ಯಾಸಗಳು, ಒಂದು ಸಂಕ್ಷಿಪ್ತ ಮುಕ್ತಾಯ ವಿನಂತಿ ಮತ್ತು ಒಂದು ಕುರಾನ್ ವಾಕ್ಯ ಸೇರಿಸಿ.",

