  "dailyGraceReflectionLabel": "ಸಂಜೆಯ ಪ್ರತಿಫಲನ",
  "dailyGraceCopiedToast": "ವಾಕ್ಯ ಕ್ಲಿಪ್‌ಬೋರ್ಡ್‌ಗೆ ನಕಲಿಸಲಾಗಿದೆ",

  "dailyScripture0Text": "ವಾಸ್ತವವಾಗಿ, ಧರ್ಮಿಗಳು ಬಾಗುಹೊಳೆ ಮತ್ತು ನದಿಗಳಲ್ಲಿ ಇರುತ್ತಾರೆ, ಪರಾಕ್ರಮಿ ರಾಜನ ಪಾಸದಲ್ಲಿ ಗೌರವದೊ ಸ್ಥಾನದಲ್ಲಿ.",
  "dailyScripture0Ref": "ಕುರಾನ್ 54:54-55",
  "dailyScripture1Text": "ಮತ್ತು ನಾವು ನಿಮ್ಮನ್ನು (ಮುಹಮ್ಮದ್) ಲೋಕಗಳಿಗೆ ದಯೆ ಅನ್ನೋ ಕಾರಣ ಅಲ್ಲದೆ ಪಾಠವಾಗಿ ಕಳೆಯಿಲ್ಲ.",
  "dailyScripture1Ref": "ಕುರಾನ್ 21:107",
  "dailyScripture2Text": "ಅಲ್ಲಾಹ ತನ್ನ ಸೇವಕನ ಸಾಕಾಗುತ್ತದೆ ಅಲ್ಲವೆ? ಮತ್ತು ಅವರು ನಿಮ್ಮನ್ನು ಇತರರನ್ನ ಆತ್ಮನೀಯವಾಗಿ ಭಿತ್ತಿಗೊಳಿಸುತ್ತಾರೆ.",
  "dailyScripture2Ref": "ಕುರಾನ್ 39:36",
  "dailyScripture3Text": "ಬಹುಶಃ ನೀವು ನೆನೆಸುವುದು ಚೆನ್ನಾಗಿರುವುದು ಮತ್ತು ನೀವು ಪ್ರೆಮಿಸುವುದು ನೀಚಾಗಿರುವುದು. ಮತ್ತು ಅಲ್ಲಾಹ ನಿಜವಾಗಿ ತಿಳಿದಿದ್ದಾರೆ ಮತ್ತು ನೀವು ತಿಳಿದಿಲ್ಲ.",
  "dailyScripture3Ref": "ಕುರಾನ್ 2:216",
  "dailyScripture4Text": "ವಾಸ್ತವವಾಗಿ ಅಲ್ಲಾಹ ಅವುಡ್ಳೆ ಉಪಹಾರ ಆತ್ಮ ತೊ.",
  "dailyScripture4Ref": "ಕುರಾನ್ 2:153",
  "dailyScripture5Text": "ಆದ್ದರಿಂದ ನನ್ನನ್ನು ಮನೆಯಿಂದೂ; ನಾನು ನಿಮ್ಮನ್ನು ಜಿನೋಸೆಗಲು. ಮತ್ತು ನನ್ನಿಂದ ಧನ್ಯವಾದ ಬನ್ನಿ ಮತ್ತು ನನ್ನನ್ನು ನಿರಾಕರಿಸಬೇಡ.",
  "dailyScripture5Ref": "ಕುರಾನ್ 2:152",
  "dailyScripture6Text": "ವಾಸ್ತವವಾಗಿ, ನಿಮ್ಮಲ್ಲಿ ಅಲ್ಲಾಹನ ನೋಸಕೆ ಅತ್ಯಂತ ಸಮ್ಮಾನಿತ ಅದು ತುಮ್ಮಲ್ಲಿ ಅತ್ಯಂತ ಶುದ್ಧ ಎಂಬುದು.",
  "dailyScripture6Ref": "ಕುರಾನ್ 49:13",
  "dailyScripture7Text": "ಮತ್ತು ನಿಮ್ಮ ರಬ್ಬು ಆದೇಶ ನೀಡಿದೆ ಆದ್ದರಿಂದ ನೀವು ಆಯತ್ತ ಇದ್ದರೆ ಅಲ್ಲಾಹವನ್ನ ಪೂಜಿಸಬೇಕು ಮತ್ತು ಪೋಷಕರಿಗೆ ವರದಿ ನೀಡಬೇಕು.",
  "dailyScripture7Ref": "ಕುರಾನ್ 17:23",
  "dailyScripture8Text": "ವಿಷಾದವನ್ನ ಸಹಿಷ್ಣುತೆ ಕೊಂಡು ಬರುತ್ತದೆ.",
  "dailyScripture8Ref": "ಕುರಾನ್ 94:6",
  "dailyScripture9Text": "ಮತ್ತು ಅವನು ನಿಮ್ಮ ತೊ ಇರುತ್ತಾರೆ ಎಲ್ಲಿ ನೀವು ಇದ್ದೀರಿ. ಮತ್ತು ಅಲ್ಲಾಹ ನಿಮ್ಮ ಕಾಯ್ಕೆ ನೋಡುತ್ತಿದ್ದಾರೆ.",
  "dailyScripture9Ref": "ಕುರಾನ್ 57:4",
  "dailyScripture10Text": "ಅಲ್ಲಾಹ ಯಾವುದೋ ಆತ್ಮನ ಆಕಾರ ತರುತಿರುವುದಿಲ್ಲ ಆದರೆ ಯಾವುದು ಅದು ಪುಲಿ ಸಾಧ್ಯಾಗುವುದಿಲ್ಲ.",
  "dailyScripture10Ref": "ಕುರಾನ್ 2:286",
  "dailyScripture11Text": "ಮತ್ತು ಯಾವುದೋ ಅಲ್ಲಾಹಿಗೆ ಭರವಸೆ ಇಡಿ ನಂತರ ಅವನು ಸಾಕಾಗುತ್ತದೆ.",
  "dailyScripture11Ref": "ಕುರಾನ್ 65:3",
  "dailyScripture12Text": "ನನ್ನ ದಯೆ ಎಲ್ಲವನ್ನ ಸುತ್ತುವಳಿಯುತ್ತದೆ.",
  "dailyScripture12Ref": "ಕುರಾನ್ 7:156",
  "dailyScripture13Text": "ಮತ್ತು ನನ್ನ ಸೇವಕರು ನನ್ನೆ ಕುರಿತು ನಿಮ್ಮನ್ನ ಕೇಳಿದಾಗ — ವಾಸ್ತವವಾಗಿ ನಾನು ಪರ. ನಾನು ವಿನಂತಿ ನೋಡಿ ಹಾಕುತ್ತೇನೆ ನಿಮ್ಮೆ ಅವರು ನನ್ನನ್ನ ಪರಿಶೀಲಿ ಮಾಡುವ ನೋಂದಣೆ.",
  "dailyScripture13Ref": "ಕುರಾನ್ 2:186",
  "dailyScripture14Text": "ಯಾವುದೋ ಧರ್ಮ ಹೆಕೊಂಡು ಅವಪು ಪುರುಷ ಅಥವಾ ಪುರುಷ, ನಿಜವಾಗಿ ನಾವು ಅವರನ್ನ ಚೆನ್ನಾದ ಜೀವನ ತೊಳೆಯುಚೆನ್ಕೆ ಪುನಸ್ಥಾಪಿತ ಮಾಡುತ್ತೇನೆ.",
  "dailyScripture14Ref": "ಕುರಾನ್ 16:97",
  "dailyScripture15Text": "ವಾಸ್ತವವಾಗಿ, ಅಲ್ಲಾಹ ನಿರ್ಕಟ ಬದಲಾಯುವುದೆಲ್ಲಅವರು ಯಾವುದೋ ರೂಡೂ ಬದಲಾಯುವವರೆ.",
  "dailyScripture15Ref": "ಕುರಾನ್ 13:11",
  "dailyScripture16Text": "ತಕಲೆ ಅನೆ ಮತ್ತು ಮೂಸುಸಸರಕೋ, ಮತ್ತು ನೀವು ಒಫ್ಸು ಜನ ಸದ್ಧ ನಂಬುವೆವೆ ಆನ ಒಪ್ಪು ಹೆದಾಗ.",
  "dailyScripture16Ref": "ಕುರಾನ್ 3:139",
  "dailyScripture17Text": "ಓ ನನ್ನ ಸೇವಕರ ಯಾವುದೋ ಮನಸ್ಸನ ವಿರುದ್ಧ ತಪ್ಪುಬೆಡೆ, ಅಲ್ಲಾಹನ ದಯೆಯ ನಿರಾಶಾ ಪರೋ ಅಣೆ. ವಾಸ್ತವವಾಗಿ, ಅಲ್ಲಾಹ ಎಲ್ಲಾ ಪಾಪಗಳನ್ನ ಕ್ಷಮಾಪನೆ ಮಾಡಿದ್ದಾರೆ.",
  "dailyScripture17Ref": "ಕುರಾನ್ 39:53",
  "dailyScripture18Text": "ಮತ್ತು ಯಾವುದೋ ಅಲ್ಲಾಹಿಂದ ಭಯಪಡುತ್ತಿದ್ದೆ ತನಗೆ ರಸ್ತೆ ಮಾಡುತ್ತಿದ್ದಾರೆ, ಮತ್ತು ಅವರ ಅನ್ನಾಗಮಿಸುತ್ತಿದ್ದಾರೆ ಎಲ್ಲಿ ಅವರು ಈತರ ಆರಿಷೆ.",
  "dailyScripture18Ref": "ಕುರಾನ್ 65:2-3",
  "dailyScripture19Text": "ಅಲ್ಲಾಹನ ದಯೆಯಲ್ಲಿ ನಿರಾಶೆ ಆಗಬೆಡ.",
  "dailyScripture19Ref": "ಕುರಾನ್ 12:87",
  "dailyScripture20Text": "ಮತ್ತು ನಾವು ನಿಜವಾಗಿ ಕುರಾನ್ ನೆನೆಯುವುದು ಸುಲಭ ಮಾಡಿದ್ದೇವೆ. ತಾವತ್ತೆ ಕೆಲಾವೊ ಅವುಲು ಓಪಲೋ ಮತ್ತೆ ಸೆನೆತೋ?",
  "dailyScripture20Ref": "ಕುರಾನ್ 54:17",
  "dailyScripture21Text": "ಮತ್ತು ಅವನು ನಿಮ್ಮನ್ನ ಕಲ್ಪನೆಯಾಗಿ ಕೂಟೆ ಮತ್ತು ನಿಮ್ಮನ್ನ ಮಾರ್ಗದರ್ಶನ ಮಾಡಿದ್ದಾರೆ.",
  "dailyScripture21Ref": "ಕುರಾನ್ 93:7",
  "dailyScripture22Text": "ಮತ್ತು ನಿಮ್ಮ ರಬ್ಬು ಹೆಣೆ ನನ್ನೆ ಕರೆ; ನಾನು ನೀಮಾರ ನೋಡಿ ಹಾಕುತ್ತೇನೆ.",
  "dailyScripture22Ref": "ಕುರಾನ್ 40:60",
  "dailyScripture23Text": "ಮತ್ತು ನಾವು ನಿಜವಾಗಿ ಆದಮ್ ಸಂತಾನ ಪ್ರಭುತ್ವ ಮಾಡಿದ್ದೇವೆ.",
  "dailyScripture23Ref": "ಕುರಾನ್ 17:70",
  "dailyScripture24Text": "ಮತ್ತು ಅವುಡ್ಳೆ ಮತ್ತು ನಮಾಜ ಮೂಲಕ ಸಾಹಾಯ್ಯ ಕೋರಿ.",
  "dailyScripture24Ref": "ಕುರಾನ್ 2:45",
  "dailyScripture25Text": "ಯಾವುದೋ ಪರಮಾಣುವಿನ ತೋಟೆ ಒಳ್ಳೆಯ ಕೆಲಸ ಮಾಡುವೆವೆ ಅವನು ಕಾಣುವೆನೆ.",
  "dailyScripture25Ref": "ಕುರಾನ್ 99:7",
  "dailyScripture26Text": "ನಿಸ್ಸಂದೆಹೆ, ಅಲ್ಲಾಹನ ಸಾಹಾಯ್ಯ ನೋರೆ.",
  "dailyScripture26Ref": "ಕುರಾನ್ 2:214",
  "dailyScripture27Text": "ಮತ್ತು ಯಾವುದೋ ಕೃತಜ್ಞತೆ ಬಿದ್ದೆ - ತನ್ನ ಕೃತಜ್ಞತೆ ತನ್ನ ಲಾಭಾರ್ಥವು.",
  "dailyScripture27Ref": "ಕುರಾನ್ 31:12",

  "dailyReflection0": "ಈ ದಿನ ಮುಚ್ಚುವಾಗ, ಅಲ್ಲಾಹನ ದಯೆ ಬಹಿರ್ಗತ ಒಂದು ಕ್ಷಣ ಚಿಂತಿಸಿ.",
  "dailyReflection1": "ಅಲ್ಲಾಹನ ಮುಂದೆ ಆಜನ್ಮ ತೂಕದಾಗಿ ಯಾವುದೋ ಬನ್ನಿ.",
  "dailyReflection2": "ಈ ದಿನದಿಂದ ಒಂದು ಆಶೀರ್ವಾದ ಹೆಸರು ಮತ್ತು ಅಲ್ಲಾಹಿಗೆ ಕೃತಜ್ಞತೆ ಪ್ರಕಟ ಮಾಡಿ.",
  "dailyReflection3": "ಅಲ್ಲಾಹನ ಅಸೀಮ ಜತ್ನದಲ್ಲಿ ಅಪಹರಿತ ಬೆಳೆ ಶಾಂತಿ ಪಡೆ.",
  "dailyReflection4": "ಆಜ ದೈನಂದಿನ ದಯೆ ಮತ್ತು ಕರುಣೆ ತೋರಿಸುವಂದಿಗೆ ಕರೆ ಅಲ್ಲಿಗೆ ಚಿಂತಿಸಿ.",
  "dailyReflection5": "ನೀವು ನಿಯಂತ್ರಿಸುವುದು ಖಾಲಿ ಕಠಿನ ಹಾಕಲಿ ಮತ್ತು ಅಲ್ಲಾಹನ ಪರಿಪೂರ್ಣ ಯೋಜನೆಗೆ ವಿಶ್ವಾಸ ಕೊರೋ.",
  "dailyReflection6": "ದಿನ ಮುಚ್ಚುವಾಗ, ಅಲ್ಲಾಹನ ಜ್ಞಾಪನೆಯಲ್ಲಿ ಶಾಂತಿ ಪ್ರಾಪ್ತ ಮಾಡಿ.",
  "dailyReflection7": "ಪ್ರತಿ ನಮಾಜಕೆ ಅಲ್ಲಾಹಿಗೆ ಧನ್ಯವಾದ ಮತ್ತು ಈ ದಿನದಲ್ಲಿ ನಿಮ್ಮ ನಮಾಜಗಳನ್ನ ಎಣಿಸಿ ಪ್ರತಿಫಲನ ಮಾಡಿ.",
  "dailyReflection8": "ಈ ದಿನದಲ್ಲಿ ಸಬ್ರ (ಧೈರ್ಯ) ನಿಮ್ಮ ಕ್ರಿಯೆಗಳನ್ನ ಮಾರ್ಗದರ್ಶನ ಒಂದು ಕ್ಷಣ ಪ್ರತಿಫಲನ ಮಾಡಿ.",
  "dailyReflection9": "ಈ ದಿನದ ಕೋಟಿಮೆಯನ್ನ ಕ್ಷಮಾಪನೆ ಮಾಗಿ — ಅಲ್ಲಾಹನ ದಯೆ ಮಿತಿ.",
  "dailyReflection10": "ನೀವು ಪ್ರತ್ಯಾಚಿ ದಯೆ ತೋರಿಕೊಂಡ ಒಂದು ವ್ಯಕ್ತಿ ಹೆಸರು ಮತ್ತು ಅವರ ಕೋಠೆ ದುಆ ಮಾಡಿ.",
  "dailyReflection11": "ಕೃತಜ್ಞತೆಯಲ್ಲಿ ಮಸತಿ: ನೀವು ಕೇಳಿ ಕೊಟ್ಟಿಲ್ಲ ಎಡೋ ಅಲ್ಲಾಹ ಕಲ್ಪನೆ ಮಾಡಿದ್ದಾರೆ?",
  "dailyReflection12": "ಕುರಾನ್ ಒಂದು ವೃತ್ತಿ ನಿಮ್ಮ ಸ್ಥಾನಕ ಮೇಲೆ ಮಾತನಾಡುವುದು ಚಿಂತಿಸಿ ಪ್ರತಿಫಲನ ಮಾಡಿ.",
  "dailyReflection13": "ನೀವು ನಿನ್ನ ಸಮೀಕರಣ ಹೇಗೆ ಬಳಸಿದ್ದೀರಿ ಚಿಂತಿಸಿ — ಅಲ್ಲಾಹನ ಕೋಠೆ ಆಜೂ ಮಾಡುತ್ತೀರಿ, ನಾಳೆ ಪುನರಾರಂಭ ಪಾರುವರಹ.",
  "dailyReflection14": "ಈ ದಿನವೀ ಕೆಲವು ಕಷ್ಟ ಬಂದಿದ್ದು ವಿಶ್ರಾಮೋ ಅಲ್ಲಾಹ ನಿಮ್ಮ ತೊ ಇದ್ದಾರೆ.",
  "dailyReflection15": "ಈ ದಿನದಲ್ಲಿ ನೀವು ಕುಟುಂಬ ಅಥವಾ ಸಮುದಾಯಕೆ ಸೇವೆ ಮಾಡಿದ ಒಂದು ವೈಯುದ್ಧೈಕತೆ ಬೋಧನೆ ಮಾಡಿ.",
  "dailyReflection16": "ರಾತ್ರಿ ಅಜೆದಾಗ, ತೌಬಾ (ಫಿರಿಕೆ) ಮಾಡಿ — ಅಲ್ಲಾಹ ತನಿಕೆ ಫಿರಿ ಬರುವಂಗಿ ಪ್ರೋತ್ಸಾಹಿತ ಮಾಡೆನೆ.",
  "dailyReflection17": "ಅಲ್ಲಾಹ ಸೃಷ್ಟಿ ನಿಮ್ಮ ದಿನಕೆ ಸೌಂದರ್ಯ ಕೊಂಡು ಹೋಗಿದೆ ಅದು ಚಿಂತಿಸಿ ಪ್ರತಿಫಲನ ಮಾಡಿ.",
  "dailyReflection18": "ನೀವು ಈ ದಿನ ಎಂದು ಕೆತೆ ಅದು ಎಲ್ಲಿ ನಾಲಿಕೇ ಅಲ್ಲಾಹಿಗೆ ಹತ್ತಾಕೆ ತಾರುವುದನ್ನ ಚಿಂತಿಸಿ ಪ್ರತಿಫಲನ ಮಾಡಿ.",
  "dailyReflection19": "ದಿನದ ಚಿಂತೆಯನ್ನ ಅಲ್ಲಾಹಿಗೆ ಛೋಡಿ ಪಾರುವರಹ — ಅವನು ನೀವು ಭುಕ್ತಿಸುವುದು ಹೊಗೆ ಮಾಧ್ವೆ ಚಲು ಪಾರುವರಹ.",
  "dailyReflection20": "ನೀವು ಉತ್ತಮ ಆಯ್ಕೆ ಮಾಡುವುದು ಒಂದು ಪದೋ ಚಿಂತಿಸಿ ಮತ್ತು ಕೋಮಲವಾಗಿ ಅದನ್ನ ಪಾಠವಾ ಕೊಳಯೂ.",
  "dailyReflection21": "ಸುತುಸುತೋ ಹೆಚ್ಚಾದರೆ ಅವುನು ದುಆ ಮಾಡಿ — ನಿಮ್ಮ ನಮಾಜ ಅವುನು ಒಂದು ಬಳುವುದಾಗಿದೆ.",
  "dailyReflection22": "ನೀವು ವಾಮೆ ಧನ್ಯವಾದ ಮಾಡುವುದು ಒಂದು ಆಶೀರ್ವಾದ ಮನುಪ ಮಾಡಿ ಮತ್ತು ಅಲ್ಲಾಹಿಗೆ ಧನ್ಯವಾದ ಮಾಡಿ.",
  "dailyReflection23": "ಈ ದಿನದ ನಿಮ್ಮ ಉದ್ದೇಶ ಪ್ರತಿಫಲನ ಮಾಡಿ — ಅವು ಅಲ್ಲಾಹಿಗೇ ಇತ್ತೇ? ನಾಳೆ, ಪುನಃ ಆರಂಭ ಪಾರುವರಹ.",
  "dailyReflection24": "ರಾತ್ರಿ ಶಾಂತಿ ಕಂಡಿದಾಗ, ಗಮನಿಸಿ ಅಲ್ಲಾಹನ ಸಮೀಪತೆ ಮಿಷ್ಟೆಯಲ್ಲಿ.",
  "dailyReflection25": "ಈ ದಿನದಲ್ಲಿ ಶಕ್ತಿ ನೀವು ಕಂಡೇ — ಆ ಶಕ್ತಿ ಅಲ್ಲಾಹ ಕಿಂದ.",
  "dailyReflection26": "ನೆ ಹೆಸರು ಒಂದು ವಿಷಯ ನೀವು ನಾಳೆ ಮಾಡುತ್ತೀರಿ, ಅಲ್ಲಾಹನ ಕೋಠೆ, ಪರಿವೃತ್ತನ ತರ ಚಟಿ ಮಾಡಿಲ್ಲ.",
  "dailyReflection27": "ನೀವು ವಿಶ್ರಾಮ ಪ್ರಸ್ತುತ ಪುನಹೋ, ನಿಮ್ಮ ಆತ್ಮನ ಅಲ್ಲಾಹಿಗೆ ಆರಿಯಿರಿ — ಅವನು ರಕ್ಷಕಾವಿ.",

