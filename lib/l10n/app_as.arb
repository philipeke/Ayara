  "promptDailyGuidance": "সুন্নী ইছলামী বিশ্বাসত প্রোথিত এটা চুটি, ব্যৱহাৰিক দৈনন্দিন নিৰ্দেশনা লিখক — কোৰআন, হাদীছ আৰু নবী মুহাম্মদৰ শিক্ষাত ভিত্তি কৰি। প্রতিবাৰ এটা নতুন দৃষ্টিভঙ্গি বাছনি কৰক: ইছলামী নৈতিকতাৰ এটা গুণ, সুন্নাহৰ এটা সত্য, নবীৰ সাহাবীসকলৰ জ্ঞান, বা ইছলামী ঐতিহ্যৰ পৰা এটা নীৰৱ অনুশীলন। এক কোৰআনৰ শ্লোক (সুৰা:আয়াহ) আৰু দিনটো ৰাখিবলৈ এটা ১–२ শব্দৰ চিন্তা অন্তৰ্ভুক্ত কৰক। ইছলামী ক্যালেণ্ডাৰ বা প্রাসঙ্গিক গুৰুত্বপূৰ্ণ তাৰিখৰ সৈতে ঐচ্ছিকভাবে সংযুক্ত কৰক।",

  "promptFaithTrust": "ঈমান (বিশ্বাস) আৰু আল্লাহৰ পৰিকল্পনাত বিশ্বাসৰ (তাওয়াক্কুল) ওপৰ এটা চুটি ইছলামী চিন্তা লিখক। কোৰআন, নবী মুহাম্মদৰ উদাহৰণ আৰু সাহাবাসকলৰ ঈমানত ইহা প্রোথিত কৰক। প্রতিবাৰ থিম পৰিৱৰ্তন কৰক: অনিশ্চয়তাৰ সময়ত আল্লাহত বিশ্বাস, ঐশ্বিক জ্ঞানত নিৰ্ভৰতা, পৰীক্ষাত ধৈর্য, বা দৈনন্দিন জীৱনত নীৰৱ দৃঢ়তা। এক কোৰআনৰ শ্লোক আৰু ইছলামী আধ্যাত্মিক জ্ঞান পৰা আজৰ বাবে এটা সৎ পদক্ষেপ অন্তৰ্ভুক্ত কৰক।",

  "promptPrayerReflection": "সালাহ, দোয়া, বা জিকিৰত প্রোথিত এটা চুটি ইছলামী নামাজৰ চিন্তা লিখক। প্রতিবাৰ ফৰ্ম পৰিৱৰ্তন কৰক: এটা সকালৰ বা সন্ধ্যাৰ স্মৃতিচিহ্ন (আধকাৰ), পাঁচটা দৈনিক নামাজৰ ওপৰ চিন্তা, এটা কোৰানিক শ্লোকৰ ধ্যান, বা এটা হৃদয়গ্রাহী দোয়া। এক কোৰআনৰ শ্লোক আৰু ব্যৱহৃত নামাজৰ ফৰ্মটি সংক্ষিপ্তভাবে নাম দিন।",

  "promptHopeDifficultTimes": "কঠিন সময়ত ধৈর্য (ছাব্র) আৰু আশাৰ ওপৰ এটা ইছলামী চিন্তা লিখক। পৰীক্ষাৰ বিষয়ত কোৰানিক শিক্ষা, নবীসকলৰ দৃঢ়তা আৰু কঠিন মুহূর্তত আল্লাহৰ দয়াত আঁকক। প্রতিবাৰ কোণ পৰিৱৰ্তন কৰক। এক কোৰআনৰ শ্লোক আৰু ইছলামী ঐতিহ্য পৰা এটা উৎসাহব্যঞ্জক দৃষ্টিভঙ্গি অন্তৰ্ভুক্ত কৰক।",

  "promptForgiveness": "ক্ষমা প্রার্থনা (তাওবাহ) আৰু আল্লাহৰ দয়াৰ ওপৰ এটা জ্ঞানী ইছলামী চিন্তা লিখক। তাওবাৰ ওপৰ কোৰানিক শিক্ষা, আল্লাহৰ সহানুভূতি আৰু নবী মুহাম্মদৰ ক্ষমাকাৰী উদাহৰণত আঁকক। থিম পৰিৱৰ্তন কৰক: আল্লাহৰ ফিৰি আসা, আনক ক্ষমা কৰা, সম্পর্ক নিৰাময়, বা ভুলৰ পিছত আল্লাহৰ দয়াত বিশ্বাস। এক কোৰআনৰ শ্লোক আৰু এটা নিৰ্দিষ্ট পদক্ষেপ অন্তৰ্ভুক্ত কৰক।",

  "promptLoveCompassion": "দৈনন্দিন জীৱনত দয়া (রাহমাহ) আৰু সহানুভূতিৰ ওপৰ এটা চুটি ইছলামী চিন্তা লিখক। নবী মুহাম্মদৰ উদাহৰণ, ইহছান (উৎকৰ্ষতা) ধারণা আৰু পৰিয়াল, প্রতিবেশী আৰু দুর্বলদের প্রতি দয়াৰ ইছলামী শিক্ষাত আঁকক। এক কোৰআনৰ শ্লোক আৰু আজ অনুশীলন কৰিবলৈ সহানুভূতিৰ এটা নেহেৰুৱা কাজ অন্তৰ্ভুক্ত কৰক।",

  "promptStrengthCourage": "ঈমানত ভিত্তি কৰি শক্তি আৰু সাহসৰ ওপৰ এটা ইছলামী চিন্তা লিখক। নবীসকলৰ উদাহৰণ, প্রাথমিক মুছলিম সম্প্রদায় আৰু কঠোৰতাত দৃঢ় অবস্থানকাৰী বিশ্বাসীদের পৰা আঁকক। প্রতিবাৰ থিম পৰিৱৰ্তন কৰক: ঈমানৰ মাধ্যমে সাহস, নামাজত শক্তি, ভয়ৰ সময়ত আল্লাহত বিশ্বাস, বা কঠিনতাত সংগ্রহণীয়তা। এক কোৰআনৰ শ্লোক আৰু স্মৃতিৰ এটা চুটি দোয়া বা বাক্য অন্তৰ্ভুক্ত কৰক।",

  "promptGratitude": "আল্লাহৰ প্রতি কৃতজ্ঞতা (শুকর) ৰ ওপৰ এটা ইছলামী চিন্তা লিখক। এইটি কোৰানিক শিক্ষা আৰু নবীৰ ঐতিহ্যত প্রোথিত কৰক। কোণ পৰিৱৰ্তন কৰক: কঠোৰতাত কৃতজ্ঞতা, ছোট আশিৰ্বাদক মূল্য দেওয়া, আল্লাহৰ প্রশংসাৰ সৈতে দিন শুৰু কৰা, বা দৈনন্দিন জীৱনত আল্লাহৰ নিৰ্দেশনা স্বীকৃতি দেওয়া। এক কোৰআনৰ শ্লোক আৰু এটা কৃতজ্ঞতা অনুশীলন অন্তৰ্ভুক্ত কৰক।",

  "promptPurposeCalling": "আল্লাহক উপাসনা আৰু ধার্মিকভাৱে জীৱনযাপনত জীৱনৰ উদ্দেশ্যৰ ওপৰ এটা ইছলামী চিন্তা লিখক। উদ্দেশ্য, আনক সেৱা কৰা আৰু ভালৰ বাবে কোনৰ উপহার ব্যৱহাৰ সম্পর্কে কোৰানিক শিক্ষা পৰা আঁকক। প্রতিবাৰ থিম পৰিৱৰ্তন কৰক: পৰিয়াল আৰু সম্প্রদায়ক সেৱা, ইসতিখারাৰ মাধ্যমে নিৰ্দেশনা সন্ধান, উদ্দেশ্য নিয়ে জীৱনযাপন, বা সাধাৰণ কাজত অৰ্থ খুঁজি পোৱা। এক কোৰআনৰ শ্লোক আৰু দুটি প্রতিফলনমূলক প্রশ্ন অন্তৰ্ভুক্ত কৰক।",

  "promptFamilyRelationships": "কোৰানিক শিক্ষা আৰু নবী মুহাম্মদৰ উদাহৰণত প্রোথিত পৰিয়াল আৰু সম্পর্কৰ ওপৰ জ্ঞানী ইছলামী পথপ্রদৰ্শন লিখক। প্রতিবাৰ থিম পৰিৱৰ্তন কৰক: পৰিয়ালত দয়া, সংঘর্ষত ধৈর্য, পিতামাতাৰ সম্মান, ঈমানে সন্তান উঠ্পন্ন, বা বিবাহ শক্তিশালী কৰা। এক কোৰআনৰ শ্লোক আৰু চেষ্টা কৰিবলৈ এটা সম্পর্কীয় অনুশীলন অন্তৰ্ভুক্ত কৰক।",

  "promptPeaceAnxietyRelief": "আল্লাহৰ স্মৃতিৰ (জিকিৰ) মাধ্যমে আভ্যন্তৰীণ শান্তি আৰু তার পরিকল্পনাত বিশ্বাস খোঁজাৰ ওপৰ এটা প্রশান্তিদায়ক ইছলামী চিন্তা লিখক। হৃদয়ৰ শান্তি, নামাজ আৰু আল্লাহৰ ইচ্ছাত সমর্পণৰ বিষয়ত কোৰানিক শিক্ষা পৰা আঁকক। প্রতিবাৰ পদ্ধতি পৰিৱৰ্তন কৰক আৰু এক কোৰআনৰ শ্লোক আৰু ইছলামী ঐতিহ্য পৰা এটা সহজ ভিত্তি অনুশীলন অন্তৰ্ভুক্ত কৰক।",

  "promptWisdomOfJesus": "ইছলামত শিক্ষিত নবীদের পৰা জ্ঞানৰ এটা চুটি টুকৰো লিখক। কোৰআন বা হাদীছ পৰা আঁকক আৰু ইছলামী বিদ্বানরা শিক্ষাটি কীভাবে বোঝেন তা সংক্ষিপ্তভাবে ব্যাখ্যা কৰক। থিম পৰিৱৰ্তন কৰক: চৰিত্র, ধৈর্য, বিনয়, ঈমান, বা দৈনন্দিন আচরণ। এক কোৰানিক শ্লোক বা হাদীছ রেফারেন্স আৰু এটা ব্যৱহাৰিক প্রয়োগ অন্তৰ্ভুক্ত কৰক।",

  "promptHumilityCharacter": "বিনয় (তাওয়াধু) আৰু সৎ চৰিত্রৰ (আখলাক) ওপৰ এটা ইছলামী চিন্তা লিখক। কোৰানিক শিক্ষা, নবী মুহাম্মদৰ উদাহৰণ আৰু ইছলামী চৰিত্র উন্নয়নৰ ঐতিহ্যত আঁকক। থিম পৰিৱৰ্তন কৰক: নেতৃত্বত বিনয়, ভুল স্বীকাৰ, আনক সম্মান সহকাৰে আচরণ, বা আত্মপ্রতিফলনৰ মাধ্যমে আধ্যাত্মিকভাৱে বৃদ্ধি। এক কোৰআনৰ শ্লোক আৰু অনুশীলন কৰিবলৈ এটা অভ্যাস অন্তৰ্ভুক্ত কৰক।",

  "promptOvercomingTemptation": "প্রতিকূলতা প্রতিৰোধ আৰু সঠিক পথত থাকাৰ ওপৰ এটা ইছলামী চিন্তা লিখক। কোৰানিক নিৰ্দেশনা, আল্লাহৰ স্মৃতি (জিকিৰ), নামাজ (সালাহ) আৰু সংগ্রাম অতিক্রম কৰা বিশ্বাসীদের উদাহৰণ পৰা আঁকক। প্রতিবাৰ কোণ পৰিৱৰ্তন কৰক। এক কোৰআনৰ শ্লোক আৰু পরবর্তী २४ ঘণ্টার জন্য এটা ব্যৱহাৰিক কৌশল অন্তৰ্ভুক্ত কৰক।",

  "promptEveningReflection": "সন্ধ্যাৰ স্মৃতিচিহ্ন (আধকাৰ আল-মাসা') ঐতিহ্যত প্রোথিত একটি শান্ত ইছলামী সন্ধ্যা প্রতিফলন লিখক। কৃতজ্ঞতা, আত্মপরীক্ষা (মুহাছাবাহ) আৰু বিশ্রামৰ আগে আল্লাহত বিশ্বাসকে উৎসাহিত কৰক। ३–५টা চুটি প্রতিফলন অনুরোধ দিনৰ বিষয়ে, একটি সংক্ষিপ্ত সমাপনী দোয়া আৰু একটি কোৰান শ্লোক অন্তৰ্ভুক্ত কৰক।",

