  "continueCta": "Gaa n'ihu",

  "promptDailyGuidance": "Dee mkpamkpa isiokwu kwa araw na-aghota na Sunni Islamiikdụ - n'ihi okwu Quraan, Hadith, na ọmụmụ Nabi Muhammad. Họrọ mma ọhụrụ kwa oge: Amamihe si na Islamiikdụ, Eziokwu si n'Ọrụ Ụfọdụ, amamihe si n'aka ndị Nabi, ma ọ bụ ihe nkịtị ọfụọ si na ọdịnala Islamiikdụ. Tinyenụ otu ayaya Quraan (Surah:Ayah) na mma-echiche 1–2 ya na-atụnyere ụbọchị. Ma ọ dịkwa mma, jikọ ya na ọnwa Islamiikdụ ma ọ bụ ụbọchị dị mkpa ma ọ́bụrụ na o kwesịrị.",

  "promptFaithTrust": "Dee mma-echiche Islamiikdụ maka Iman (ịtụkwasị) na tụkwasị n'anya Allaah (Tawakkul). Tinyenụ ya n'Ayaya Quraan, ọmụmụ Nabi Muhammad, na ịtụkwasị nke ndị Sahaba. Megharia ihe ịrụpụta kwa oge: ịtụkwasị Allaah ma ọ dị mkpasị, ịdabere n'amamihe Allaah, ndịka n'ọnọdụ, ma ọ bụ ndụ nta na ndụ kwa araw. Tinyenụ otu ayaya Quraan na otu nkwụkwọ n'ụlọ mma n'ihe ọmụmụ Islamiikdụ.",

  "promptPrayerReflection": "Dee mma-echiche Islamiikdụ maka mpempe (Salah, Dua, ma ọ bụ Dhikr). Gharia ụdị kwa oge: ịjụrụ ụtụtụ ma ọ bụ mgbede (Adhkar), mma-echiche maka mpempe ise, mma-echiche maka ayaya Quraan, ma ọ bụ mkpemkpe obi. Tinyenụ otu ayaya Quraan na aha nkịtị mpempe a jiri.",

  "promptHopeDifficultTimes": "Dee mma-echiche Islamiikdụ maka ndịka (Sabr) na ọnwụ n'oge ọnọdụ. Zaa n'isiokwu Quraan maka nnwụchịnye, ndịka nke ndị Nabi, na ihuhu Allaah n'oge ọnọdụ. Gharia ụdị kwa oge. Tinyenụ otu ayaya Quraan na otu isiokwu na-akpalị obi si na ọdịnala Islamiikdụ.",

  "promptForgiveness": "Dee amamihe Islamiikdụ maka ichọpụta mma (Tawbah) na ihuhu Allaah. Zaa n'isiokwu Quraan maka ịgbanweghachi, ihuhu Allaah, na ọmụmụ Nabi Muhammad maka ịgbagha. Gharia ihe ịrụpụta: ịgbanweghachi n'Allaah, ịgbagha ndị ọzọ, ị rụo mma ezinụlọ, ma ọ bụ ịgbụgba na ihuhu Allaah mgbe ọnwụ. Tinyenụ otu ayaya Quraan na otu nkwụkwọ n'ụlọ mma.",

  "promptLoveCompassion": "Dee mma-echiche Islamiikdụ maka ihuhu (Rahmah) na ihuhu n'ihe kwa araw. Zaa n'ọmụmụ Nabi Muhammad, idu amamihe (Ihsan), na isiokwu Islamiikdụ maka ihuhu n'ezinụlọ, ndị agbata obi, na ndị umeala. Tinyenụ otu ayaya Quraan na otu ọrụ ihuhu na-eme taa.",

  "promptStrengthCourage": "Dee mma-echiche Islamiikdụ maka ike na obi ike n'Iman. Zaa n'ọmụmụ ndị Nabi, ndị Isla na mbụ, na ndị Isla na-ọ na-ọsọ ma ọ dị ike. Gharia ihe ịrụpụta kwa oge: obi ike n'Iman, ike na mpempe, tụkwasị Allaah n'oge ụjọ, ma ọ bụ ndịka n'ọnọdụ. Tinyenụ otu ayaya Quraan na mkpemkpe ma ọ bụ okwu ọjụjụ nkwa.",

  "promptGratitude": "Dee mma-echiche Islamiikdụ maka ịgụ Allaah (Shukr). Tinyenụ ya n'isiokwu Quraan na ọdịnala. Gharia ụdị: ịgụ Allaah n'oge ọnọdụ, ịchọkwa ihe nta, ịmalite ụtụtụ n'obi ụtụtụ Allaah, ma ọ bụ ịchọ ede Allaah n'ihe kwa araw. Tinyenụ otu ayaya Quraan na otu ihe ịgụ na-eme.",

  "promptPurposeCalling": "Dee mma-echiche Islamiikdụ maka ihe ndụ n'ịlụ Allaah ma ọ bụ mma. Zaa n'isiokwu Quraan maka ihe ndụ, ịlụ ndị ọzọ, na iji ihe aha na mma. Gharia ihe ịrụpụta kwa oge: ịlụ ezinụlọ na mma, ichọ edee n'ihe dị mma (Istikhara), ibi n'okwu, ma ọ bụ ichọ ihe ndụ n'ọrụ izugbe. Tinyenụ otu ayaya Quraan na ihe abụọ mma-echiche.",

  "promptFamilyRelationships": "Dee isiokwu Islamiikdụ maka ezinụlọ na mma n'ihe tinyenụ n'Quraan na ọmụmụ Nabi Muhammad. Gharia ihe ịrụpụta kwa oge: ihuhu n'ezinụlọ, ndịka n'ọnọdụ, igido ụmụ, inye ụmụ ịmụ Iman, ma ọ bụ ịdị mma na nwanyị. Tinyenụ otu ayaya Quraan na otu ihe mma n'ike gbanwee.",

  "promptPeaceAnxietyRelief": "Dee mma-echiche Islamiikdụ na-eme ka obi ọ bụ ndo site n'ajụjụ Allaah (Dhikr) na tụkwasị n'azụ Allaah. Zaa n'isiokwu Quraan maka udo obi, mpempe, na ịkwesịkwesi azụ Allaah. Gharia ụdị kwa oge, tinyenụ otu ayaya Quraan na otu ihe nkịtị mma si na ọdịnala Islamiikdụ.",

  "promptWisdomOfJesus": "Dee mkpamkpa amamihe si n'aka ndị Nabi dị ka a kụziri n'Isla. Zaa n'Quraan ma ọ bụ Hadith na kọwaa ka ndị ọkọ Quraan hụrụ ihe ọmụmụ. Gharia ihe ịrụpụta kwa oge: agwa, ndịka, iweta aka, ịtụkwasị, ma ọ bụ ndu kwa araw. Tinyenụ ayaya Quraan ma ọ bụ Hadith na otu ihe ọrụ.",

  "promptHumilityCharacter": "Dee mma-echiche Islamiikdụ maka ịjụ isi (Tawadhu) na ihe ụka agwa (Akhlaq). Zaa n'isiokwu Quraan, ọmụmụ Nabi Muhammad, na ọdịnala Islamiikdụ maka ihe agwa. Gharia ihe ịrụpụta: ịjụ isi n'ọrụ ndị ama, ịgba ọfụ mma, ịkụ ndị ọzọ n'ụkwụ, ma ọ bụ imesi dị ka mmadu site na mma-echiche. Tinyenụ otu ayaya Quraan na otu ihe ọ na-eme.",

  "promptOvercomingTemptation": "Dee mma-echiche Islamiikdụ maka igbochie ujụ na ịgara ụzọ ziri ezi. Zaa n'isiokwu Quraan, ajụjụ Allaah (Dhikr), mpempe (Salah), na ọmụmụ ndị Isla na mụtara ezi. Gharia ụdị kwa oge. Tinyenụ otu ayaya Quraan na otu ọrụ maka 24 awa na-adịbeghị.",

  "promptEveningReflection": "Dee mma-echiche Islamiikdụ maka mgbede tinyenụ n'ọdịnala ajụjụ mgbede (Adhkar al-Masaa'). Gbalị ịgụ Allaah, mma-echiche ihe onwe (Muhasabah), na tụkwasị n'Allaah tupu ụra. Tinyenụ ihe ịrụpụta 3–5 maka ụbọchị, mkpemkpe dị mkpirikpi, na otu ayaya Quraan.",

