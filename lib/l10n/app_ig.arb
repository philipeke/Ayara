  "dailyScripture0Text": "N'ezie, ndị ziri ezi ga-anọ n'ọmụmụ na mmiri, n'oche nke onye ama ike.",
  "dailyScripture0Ref": "Quraan 54:54-55",
  "dailyScripture1Text": "Na Anyị ezighị ziri gị, O Muhammad, karịa ihuhu na ụwa niile.",
  "dailyScripture1Ref": "Quraan 21:107",
  "dailyScripture2Text": "Ọ bụ na Allaah ọ ga-azu onye ohu ya? Maọ ha na-atụ gị site n'ihe ndị ọzọ.",
  "dailyScripture2Ref": "Quraan 39:36",
  "dailyScripture3Text": "Ma ọ bụ na ịchọ ihe nke karị, ma nke a dị mma nye gị; na ịchọkwa ihe ọzọ, ma nke a dị njọ. Allaah maara, mana ị maghị.",
  "dailyScripture3Ref": "Quraan 2:216",
  "dailyScripture4Text": "N'ezie, Allaah nọ na ndị na-adịka.",
  "dailyScripture4Ref": "Quraan 2:153",
  "dailyScripture5Text": "Jụrụ m; Aga m ajụ gị. Guwa m, ma ka agwụ m.",
  "dailyScripture5Ref": "Quraan 2:152",
  "dailyScripture6Text": "N'ezie, onye kacha ama n'anya nke Allaah bụ onye kacha ziri ezi.",
  "dailyScripture6Ref": "Quraan 49:13",
  "dailyScripture7Text": "Na Allaah m akwadoro na ị lụ Allaah naanị, na ị lụkwa ndị nne gị.",
  "dailyScripture7Ref": "Quraan 17:23",
  "dailyScripture8Text": "N'ezie, na ọnọdụ na-abụ ike.",
  "dailyScripture8Ref": "Quraan 94:6",
  "dailyScripture9Text": "Na ọ nọkwa na gị ebe ọ bụla. Na Allaah, nke ị na-eme, ọ na-ahụ.",
  "dailyScripture9Ref": "Quraan 57:4",
  "dailyScripture10Text": "Allaah ọ gaghị abuocha mmadụ karịa ike ya.",
  "dailyScripture10Ref": "Quraan 2:286",
  "dailyScripture11Text": "Na onye na-atụkwasị Allaah — Allaah ga-azu ya.",
  "dailyScripture11Ref": "Quraan 65:3",
  "dailyScripture12Text": "Ihuhu m na-eche ihe niile.",
  "dailyScripture12Ref": "Quraan 7:156",
  "dailyScripture13Text": "Na mgbe ndị ohu m jụrụ gị maka m — N'ezie, m nọ nso. M na-aza onye na-eti udi mgbe ọ kpọrụ m.",
  "dailyScripture13Ref": "Quraan 2:186",
  "dailyScripture14Text": "Onye ọ bụla na-eme ihe ziri ezi, ọ bụ nwanyị ma ọ bụ nwoke, mgbe ọ bụ onye kwere — Anyị ga-atụrụ ya a ga-elu dị mma.",
  "dailyScripture14Ref": "Quraan 16:97",
  "dailyScripture15Text": "N'ezie, Allaah ọ gaghị agbanwe mma nke ndị, ruo mgbe ha agbanwee ihe na ha.",
  "dailyScripture15Ref": "Quraan 13:11",
  "dailyScripture16Text": "Jụ mma, ka agwụ, na ị ga-ewu onwe gị ma ị bụ ndị kwere ziri.",
  "dailyScripture16Ref": "Quraan 3:139",
  "dailyScripture17Text": "O ndị ohu m na-emesala onwe, kagbuo na ihuhu nke Allaah. N'ezie, Allaah na-agbagha mmehie niile.",
  "dailyScripture17Ref": "Quraan 39:53",
  "dailyScripture18Text": "Na onye ọ bụla na-atụ Allaah — Allaah ga-eme ụzọ maka ya, na-akụ ya site n'ebe ọ atụghị.",
  "dailyScripture18Ref": "Quraan 65:2-3",
  "dailyScripture19Text": "Kagbuo na ihuhu nke Allaah.",
  "dailyScripture19Ref": "Quraan 12:87",
  "dailyScripture20Text": "Na Anyị n'ezie emeela Quraan dị mma iji cheta. Jụ onye ọ ga-echeta?",
  "dailyScripture20Ref": "Quraan 54:17",
  "dailyScripture21Text": "Na ọ chọtara gị nka na-ede gị.",
  "dailyScripture21Ref": "Quraan 93:7",
  "dailyScripture22Text": "Na Allaah m na-asị: Kpọrụ m; Aga m aza gị.",
  "dailyScripture22Ref": "Quraan 40:60",
  "dailyScripture23Text": "Na Anyị n'ezie onye ama ama ụmụ Adam.",
  "dailyScripture23Ref": "Quraan 17:70",
  "dailyScripture24Text": "Na chọọ ike site na ndịka na ompempe.",
  "dailyScripture24Ref": "Quraan 2:45",
  "dailyScripture25Text": "Onye ọ bụla na-eme ihe dị nta ịchọ — ọ ga-ahụ ya.",
  "dailyScripture25Ref": "Quraan 99:7",
  "dailyScripture26Text": "N'amaghị ike nke Allaah nọ nso.",
  "dailyScripture26Ref": "Quraan 2:214",
  "dailyScripture27Text": "Na onye ọ bụla na-agụ Allaah — ịgụ ya maka onwe ya.",
  "dailyScripture27Ref": "Quraan 31:12",

  "dailyReflection0": "Ka ụbọchị a na-agbara ụzọ, chere otu oge Allaah na-egosi ihuhu.",
  "dailyReflection1": "Butere Allaah ihe niile na-agụsi obi gị taa.",
  "dailyReflection2": "Kebe otu ngọzi site n'ụbọchị na gụọ Allaah.",
  "dailyReflection3": "Nọ n'udo na ịma na ị dịbeghị n'aka Allaah.",
  "dailyReflection4": "Chere ebe ị na-akpọ obi iji gosi ihuhu na amataghachi taa.",
  "dailyReflection5": "Hapụ ihe ị nweghị ike ịkwụ na tụkwasị Allaah.",
  "dailyReflection6": "Ka mgbede na-abata, terị mma n'ụrụ Allaah.",
  "dailyReflection7": "Chere ịma ede mpempe gị taa, na gụọ Allaah.",
  "dailyReflection8": "Chere ebe ndịka (Sabr) dugharị omume gị taa.",
  "dailyReflection9": "Gaghara Allaah maka ọ bụla wee mejọrọ taa — ihuhu Allaah adị oke.",
  "dailyReflection10": "Kebe otu mmadụ ị gboro mma taa na mekpe mma nye ha.",
  "dailyReflection11": "Nọ n'ọkụ: gịnị na Allaah nyere gị taa na ị achọghị?",
  "dailyReflection12": "Chere ayaya si n'Quraan bụ ebe ị nọ taa.",
  "dailyReflection13": "Chere ka ị eji oge taa — na nyere echi nye Allaah.",
  "dailyReflection14": "Nọ n'udo n'ịma na Allaah soro gị n'ọnọdụ ọ bụla taa.",
  "dailyReflection15": "Chere otu ụzọ ị lụrụ eziokwu na ezinụlọ ma ọ bụ mma taa.",
  "dailyReflection16": "Ka ụbọchị na-agbara ụzọ, megharia — Allaah hụrụ ndị na-agbanweghachi.",
  "dailyReflection17": "Chere ọmụmụ Allaah nyere ụbọchị gị, olee karị.",
  "dailyReflection18": "Chere ihe ị mụtara taa na ka ọ na-akpakwuru Allaah.",
  "dailyReflection19": "Hapụ nḿụ ụbọchị n'aka Allaah — ọ na-ebu ihe ị nweghị ike ịbu.",
  "dailyReflection20": "Chere oge ị nwere ike ịme mma n'ụbọchị, na mụta n'obi nwayọ.",
  "dailyReflection21": "Mekpe mma nye ndị na-agụ — mpempe gị bụ onyinye nye ha.",
  "dailyReflection22": "Cheta ngọzi ị na-agbanyụ agbanyụ na gụọ Allaah.",
  "dailyReflection23": "Chere omume gị taa — ha maka Allaah? Echi, malite ọzọ.",
  "dailyReflection24": "Ka abalị na-emakụ, gere Allaah n'ezumike.",
  "dailyReflection25": "Chere ebe ị chọtara ike taa — ihe a bụ si n'Allaah.",
  "dailyReflection26": "Kebe otu ihe ị ga-eme echi, maka Allaah, na ị emeghị taa.",
  "dailyReflection27": "Ka ị na-arụ onwe gị ịra ura, nyere mkpụrụobi gị nye Allaah — ọ bụ onye kacha mma ọ na-echebe.",

