  "promptDailyGuidance": "सुन्नी इस्लामिक विश्वास पर आधारित एक छोटी, व्यावहारिक दैनिक मार्गदर्शन लिखें — जो क़ुरान, हदीस और पैगंबर मुहम्मद की शिक्षाओं पर निहित हो। हर बार एक नया दृष्टिकोण चुनें: इस्लामिक नैतिकता से एक गुण, सुन्नत से एक सत्य, पैगंबर के साथियों से ज्ञान, या इस्लामिक परंपरा से एक शांत अभ्यास। एक क़ुरान आयत (सूरह:आयह) और दिन भर के लिए ले जाने के लिए 1-2 वाक्य का चिंतन शामिल करें। यदि प्रासंगिक हो तो इसे इस्लामिक कैलेंडर या किसी महत्वपूर्ण तारीख से जोड़ें।",

  "promptFaithTrust": "ईमान (ईमान) और अल्लाह की योजना (तवक्कुल) में विश्वास पर एक छोटी इस्लामिक प्रतिबिंबन लिखें। इसे क़ुरान, पैगंबर मुहम्मद के उदाहरण और साहबा की आस्था में निहित करें। हर बार विषय को बदलें: अनिश्चितता के दौरान अल्लाह पर विश्वास, दैवीय ज्ञान पर भरोसा, परीक्षाओं में धैर्य, या रोजमर्रा की जीवन में शांत दृढ़ता। एक क़ुरान आयत और इस्लामिक आध्यात्मिक ज्ञान से आज के लिए एक ईमानदार कदम शामिल करें।",

  "promptPrayerReflection": "नमाज़, दुआ या धिक्र में निहित एक छोटी इस्लामिक प्रार्थना प्रतिबिंबन लिखें। हर बार रूप को बदलें: सुबह या शाम की याद (अधकार), पाँच दैनिक नमाज़ों पर चिंतन, क़ुरान की आयत पर ध्यान, या एक दिल से दुआ। एक क़ुरान आयत शामिल करें और उपयोग किए गए प्रार्थना रूप का संक्षेप में नाम दें।",

  "promptHopeDifficultTimes": "कठिनाई के दौरान धैर्य (सब्र) और आशा पर एक इस्लामिक प्रतिबिंबन लिखें। परीक्षाओं के बारे में क़ुरानिक शिक्षाओं, पैगंबरों की दृढ़ता, और कठिन क्षणों में अल्लाह की दया से ड्रा करें। हर बार दृष्टिकोण बदलें। एक क़ुरान आयत और इस्लामिक परंपरा से एक प्रोत्साहक दृष्टिकोण शामिल करें।",

  "promptForgiveness": "क्षमा (तवबा) माँगने और अल्लाह की दया पर एक बुद्धिमान इस्लामिक प्रतिबिंबन लिखें। पश्चाताप पर क़ुरानिक शिक्षाओं, अल्लाह की करुणा, और पैगंबर मुहम्मद के क्षमा करने वाले उदाहरण से ड्रा करें। विषय को बदलें: अल्लाह की ओर वापस आना, दूसरों को माफ करना, संबंधों को ठीक करना, या गलतियों के बाद अल्लाह की दया में विश्वास करना। एक क़ुरान आयत और एक ठोस कदम शामिल करें।",

  "promptLoveCompassion": "रोजमर्रा की जीवन में दया (रहमा) और करुणा पर एक छोटी इस्लामिक प्रतिबिंबन लिखें। पैगंबर मुहम्मद के उदाहरण, इहसान (उत्कर्षता) की अवधारणा, और परिवार, पड़ोसियों और कमजोर लोगों के प्रति कृपा पर इस्लामिक शिक्षाओं से ड्रा करें। एक क़ुरान आयत और आज अभ्यास करने के लिए करुणा का एक छोटा कार्य शामिल करें।",

  "promptStrengthCourage": "आस्था पर आधारित शक्ति और साहस पर एक इस्लामिक प्रतिबिंबन लिखें। पैगंबरों के उदाहरणों, प्रारंभिक मुस्लिम समुदाय, और उन विश्वासियों से ड्रा करें जो कठिनाई में दृढ़ रहे। हर बार विषय बदलें: आस्था के माध्यम से साहस, प्रार्थना में शक्ति, भय के दौरान अल्लाह में विश्वास, या कठिनाई में लचीलापन। एक क़ुरान आयत और याद (धिक्र) की एक छोटी दुआ या वाक्यांश शामिल करें।",

  "promptGratitude": "अल्लाह के प्रति कृतज्ञता (शुक्र) पर एक इस्लामिक प्रतिबिंबन लिखें। इसे क़ुरानिक शिक्षा और भविष्यवाणी परंपरा में निहित करें। दृष्टिकोण बदलें: कठिनाई में कृतज्ञता, छोटे आशीर्वादों की सराहना, अल्लाह की प्रशंसा के साथ दिन शुरू करना, या रोजमर्रा की जीवन में अल्लाह के मार्गदर्शन को पहचानना। एक क़ुरान आयत और एक कृतज्ञता अभ्यास शामिल करें।",

  "promptPurposeCalling": "अल्लाह की पूजा और न्यायपूर्वक जीवन के जीवन के उद्देश्य पर एक इस्लामिक प्रतिबिंबन लिखें। उद्देश्य, दूसरों की सेवा, और अच्छे के लिए किसी के उपहारों का उपयोग करने पर क़ुरानिक शिक्षाओं से ड्रा करें। हर बार विषय बदलें: परिवार और समुदाय की सेवा, इस्तिखारा के माध्यम से मार्गदर्शन लेना, इरादे के साथ जीवन यापन करना, या साधारण काम में अर्थ खोजना। एक क़ुरान आयत और दो चिंतन प्रश्न शामिल करें।",

  "promptFamilyRelationships": "क़ुरानिक शिक्षा और पैगंबर मुहम्मद के उदाहरण पर आधारित परिवार और संबंधों पर बुद्धिमान इस्लामिक मार्गदर्शन लिखें। हर बार विषय बदलें: परिवार के जीवन में दया, संघर्ष में धैर्य, माता-पिता का सम्मान, आस्था में बच्चों का पालन-पोषण, या विवाह को मजबूत करना। एक क़ुरान आयत और आजमाने के लिए एक संबंधपरक अभ्यास शामिल करें।",

  "promptPeaceAnxietyRelief": "अल्लाह की याद (धिक्र) और उनकी योजना में विश्वास के माध्यम से आंतरिक शांति खोजने पर एक शांत इस्लामिक प्रतिबिंबन लिखें। दिल की शांति, प्रार्थना, और अल्लाह की इच्छा के प्रति समर्पण के बारे में क़ुरानिक शिक्षाओं से ड्रा करें। हर बार दृष्टिकोण बदलें और एक क़ुरान आयत और इस्लामिक परंपरा से एक सरल आधार अभ्यास शामिल करें।",

  "promptWisdomOfJesus": "इस्लाम में पैगंबरों से ज्ञान का एक छोटा टुकड़ा लिखें। क़ुरान या हदीस से ड्रा करें और संक्षेप में समझाएँ कि इस्लामिक विद्वानों ने शिक्षा को कैसे समझा है। विषय हर बार बदलें: चरित्र, धैर्य, विनम्रता, आस्था, या दैनिक आचरण। एक क़ुरान आयत या हदीस संदर्भ और एक व्यावहारिक आवेदन शामिल करें।",

  "promptHumilityCharacter": "विनम्रता (तवाधु) और अच्छे चरित्र (अखलाक़) पर एक इस्लामिक प्रतिबिंबन लिखें। क़ुरानिक शिक्षाओं, पैगंबर मुहम्मद के उदाहरण, और इस्लामिक चरित्र विकास की परंपरा से ड्रा करें। विषय बदलें: नेतृत्व में विनम्रता, गलतियों को स्वीकार करना, दूसरों का सम्मान करना, या आत्म-प्रतिबिंबन के माध्यम से आध्यात्मिक रूप से बढ़ना। एक क़ुरान आयत और अभ्यास करने के लिए एक आदत शामिल करें।",

  "promptOvercomingTemptation": "प्रलोभन का विरोध करने और सीधे रास्ते पर रहने पर एक इस्लामिक प्रतिबिंबन लिखें। क़ुरानिक मार्गदर्शन, अल्लाह की याद (धिक्र), प्रार्थना (नमाज़), और उन विश्वासियों के उदाहरण से ड्रा करें जिन्होंने संघर्ष पर काबू पाया। हर बार दृष्टिकोण बदलें। एक क़ुरान आयत और अगले 24 घंटों के लिए एक व्यावहारिक रणनीति शामिल करें।",

  "promptEveningReflection": "संध्या स्मरण (अधकार अल-मसा) की परंपरा में निहित एक शांत इस्लामिक संध्या प्रतिबिंबन लिखें। कृतज्ञता, आत्म-प्रतिबिंबन (मुहासबा), और विश्राम से पहले अल्लाह में विश्वास को प्रोत्साहित करें। 3-5 छोटे प्रतिबिंबन प्रश्न दिन के बारे में, एक संक्षिप्त समापन दुआ, और एक क़ुरान आयत शामिल करें।",

