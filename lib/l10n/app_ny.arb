  "continueCta": "Pitilize",

  "promptDailyGuidance": "Lembani ndondomeko yachangu komanso yomveka, yomwe ili mu chikhulupiriro cha Islamic cha Sunni — yoyambira mu Quran, Hadith, ndi maphunziro a Maporofeta Muhammad. Sankhani njira yatsopano gwiriti: mphamvu ya khalakha ya Islamic, chowona mu Sunnah, nzeru ya Ashabah a Maporofeta, kapena ntchito yabasi ya Islamic. Gwalitsani Ayi Limodzi a Quran (Surah:Ayah) ndi kulingalira kwa ma entence 1–2 komwe muntha kumva tsiku lonse. Mutha kugwiritsa ntchito calendar ya Islamic kapena nthawi yosiyana ngati iliyonse.",

  "promptFaithTrust": "Lembani kulingalira koona ka Islamic pa Iman (chikhulupiriro) ndi kutenga mtima kwa zoyenera za Allah (Tawakkul). Yambitsani mu Quran, chitsanzo cha Maporofeta Muhammad, ndi chikhulupiriro cha Sahaba. Sinthani mutu gwiriti: kutenga mtima kwa Allah mu thamangizo, kumyankhula kwa nzeru ya Mulungu, kumwa mtima mu miyoyoyo, kapena kumwa mtima nthawi zonse mu moyo wambaridi. Gwalitsani Ayi Limodzi a Quran ndi njira limodzi yomveka kwa tsiku lino yomwe ili mu nzeru ya Islamic.",

  "promptPrayerReflection": "Lembani kulingalira koona ka Islamic pa Salah, Dua, kapena Dhikr. Sinthani mawonekedwe gwiriti: kulingalirako kumakangana kapena kumakasinthu (Adhkar), kulingalira pa zipangizo zisanu za tsiku lonse, kulingalira kwa Ayi wa Quran, kapena kumepukila mtima kwa Allah. Gwalitsani Ayi Limodzi a Quran ndi dzina loseketsa la mawonekedwe amapipila omwe amagwiritsidwa.",

  "promptHopeDifficultTimes": "Lembani kulingalira koona ka Islamic pa kumwa mtima (Sabr) ndi chiyembekezo mu nthawi yovuta. Menjani maphunziro a Quran pa miyoyoyo, kumwa mtima kwa Maporofeta, ndi chisoni cha Allah mu nthawi yovuta. Sinthani mawonekedwe gwiriti. Gwalitsani Ayi Limodzi a Quran ndi mawonekedwe amakondweza omwe ali mu Islamic.",

  "promptForgiveness": "Lembani kulingalira koona komanso kodziwika pa kufuna mwankhoswe (Tawbah) ndi chisoni cha Allah. Menjani maphunziro a Quran pa tawbah, chisoni cha Allah, ndi chitsanzo cha Maporofeta Muhammad pa kukhululukira. Sinthani mutu gwiriti: kubwerera kwa Allah, kukhululukira anthu ena, kupalamwira maubale, kapena kumverekeza chisoni cha Allah pambuyo pa zolakwa. Gwalitsani Ayi Limodzi a Quran ndi njira imodzi ya pomwe.",

  "promptLoveCompassion": "Lembani kulingalira koona ka Islamic pa chisoni (Rahmah) ndi wotambirana mu moyo wambaridi. Menjani chitsanzo cha Maporofeta Muhammad, nchikhalidwe ya Ihsan (kulimba), ndi maphunziro a Islamic pa chitimbire pa banja, anzanu, ndi anthu akutali. Gwalitsani Ayi Limodzi a Quran ndi ntchito imodzi yachangu ya chisoni yomwe muntha kuchita tsiku lino.",

  "promptStrengthCourage": "Lembani kulingalira koona ka Islamic pa mphamvu ndi chisoni ya chikhulupiriro. Menjani zitsanzo za Maporofeta, anthu oyambira a Islamic, ndi anthu okhulupirira omwe adakhalira mokhonokho mu nthawi yovuta. Sinthani mutu gwiriti gwiriti: chisoni popela mu chikhulupiriro, mphamvu mu mapipila, kutenga mtima mu Allah mu nthawi ya mantha, kapena kumwa mtima mu misodzi. Gwalitsani Ayi Limodzi a Quran ndi pempho yachangu kapena mawu a Dhikr.",

  "promptGratitude": "Lembani kulingalira koona ka Islamic pa kusiyidwa (Shukr) kwa Allah. Yambitsani mu maphunziro a Quran ndi Islamic. Sinthani mawonekedwe gwiriti: kusiyidwa mu nthawi yovuta, kulingalira zabwino zachangu, kumayamba tsiku kwa chidale cha Allah, kapena kumverekeza kutembenuka kwa Allah mu moyo wambaridi. Gwalitsani Ayi Limodzi a Quran ndi ntchito ya kusiyidwa.",

  "promptPurposeCalling": "Lembani kulingalira koona ka Islamic pa cholinga cha moyo mu kulumikira Allah ndi kukhala mokhonokho. Menjani maphunziro a Quran pa cholinga, kuthamangira anthu ena, ndi kugwiritsa ntchito za Allah kwa zabwino. Sinthani mutu gwiriti: kuthamangira banja ndi chilamulo, kufufuza ndondomeko mwa Istikhara, kukhala ndi cholinga, kapena kupeza tanthauzo mu ntchito wamba. Gwalitsani Ayi Limodzi a Quran ndi mafunso awiri olingalirika.",

  "promptFamilyRelationships": "Lembani ndondomeko ya Islamic yodziwika pa banja ndi maubale omwe ali mu maphunziro a Quran ndi chitsanzo cha Maporofeta Muhammad. Sinthani mutu gwiriti: chitimbire mu banja, kumwa mtima mu nkhondo, kunyanyetsa abambo ananu, kuimera ana mu chikhulupiriro, kapena kukulitsa ubale wa latu. Gwalitsani Ayi Limodzi a Quran ndi ntchito ya ubale yomwe muntha kuyesera.",

  "promptPeaceAnxietyRelief": "Lembani kulingalira koona yosafika ka Islamic pa kupeza mtendere wamkati popela mu Dhikr ya Allah (Dhikr) ndi kutenga mtima kwa zoyenera zake. Menjani maphunziro a Quran pa mtendere wa mtima, mapipila, ndi kupereka mwachinsinsi kwa cholinga cha Allah. Sinthani njira gwiriti ndi gwalitsani Ayi Limodzi a Quran ndi ntchito imodzi yachangu ya Islamic.",

  "promptWisdomOfJesus": "Lembani nzeru yachangu ya Maporofeta yomwe ili mu Islamic. Menjani Quran kapena Hadith ndi kufotokozera mwachidule momwe ma Islamic scholarship amavetsetsa maphunziro. Sinthani mutu gwiriti: khalakha, kumwa mtima, kunyenyezeka, chikhulupiriro, kapena khalakha ya tsiku lonse. Gwalitsani Ayi a Quran kapena Hadith ndi kugwiritsa ntchito kamodzi.",

  "promptHumilityCharacter": "Lembani kulingalira koona ka Islamic pa kunyenyezeka (Tawadhu) ndi khalakha yabwino (Akhlaq). Menjani maphunziro a Quran, chitsanzo cha Maporofeta Muhammad, ndi nthano ya kukulitsa khalakha ya Islamic. Sinthani mutu gwiriti: kunyenyezeka mu chilamulo, kumvera zolakwa zanu, kumtalika anthu ena ndi chifuwa, kapena kulimba mwa kulingalira. Gwalitsani Ayi Limodzi a Quran ndi ntchito ya kumva.",

  "promptOvercomingTemptation": "Lembani kulingalira koona ka Islamic pa kukana manyasiro ndi kukhala mu njira yabwino. Menjani ndondomeko ya Quran, Dhikr ya Allah (Dhikr), mapipila (Salah), ndi zitsanzo za anthu okhulupirira omwe adakana miyoyoyo. Sinthani mawonekedwe gwiriti. Gwalitsani Ayi Limodzi a Quran ndi njira imodzi ya pomwe kwa maola 24 apitiliza.",

  "promptEveningReflection": "Lembani kulingalira koona yosafika ka Islamic kumakasinthu omwe ili mu nthano ya kumakasinthu (Adhkar al-Masaa'). Chikhulupirire kusiyidwa, kulingalira kwa paokha (Muhasabah), ndi kutenga mtima kwa Allah musanaphunzire. Gwalitsani mafunso 3–5 a kulingalira pa tsiku, pepho yachangu yomaliza, ndi Ayi Limodzi a Quran.",

