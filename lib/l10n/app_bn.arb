  "promptDailyGuidance": "সুন্নী ইসলামী বিশ্বাসের উপর ভিত্তি করে একটি ছোট, ব্যবহারিক দৈনিক দিকনির্দেশনা লিখুন — কুরআন, হাদীস এবং নবী মুহাম্মদ সাল্লাল্লাহু আলাইহি ওয়াসাল্লামের শিক্ষার উপর ভিত্তি করে। প্রতিটি বার তাজা দৃষ্টিভঙ্গি বেছে নিন: ইসলামী নৈতিকতার একটি গুণ, সুন্নাহ থেকে একটি সত্য, নবীর সাহাবীদের থেকে জ্ঞান, বা ইসলামী ঐতিহ্য থেকে একটি শান্ত অনুশীলন। একটি কুরআনের আয়াত অন্তর্ভুক্ত করুন (সূরা:আয়াত) এবং দিনের মাধ্যমে বহন করার জন্য ১–২ বাক্যের একটি প্রতিফলন। যদি প্রাসঙ্গিক হয় তবে ঐচ্ছিকভাবে এটি ইসলামী ক্যালেন্ডার বা একটি গুরুত্বপূর্ণ তারিখের সাথে সংযুক্ত করুন।",

  "promptFaithTrust": "ঈমান (ঈমান) এবং আল্লাহর পরিকল্পনায় আস্থা (তাওয়াক্কুল) সম্পর্কে একটি ছোট ইসলামী প্রতিফলন লিখুন। এটিকে কুরআন, নবী মুহাম্মদ সাল্লাল্লাহু আলাইহি ওয়াসাল্লামের উদাহরণ এবং সাহাবাদের ঈমানে নিহিত করুন। প্রতিটি বার থিম পরিবর্তন করুন: অনিশ্চয়তার সময় আল্লাহর উপর নির্ভর করা, দৈব জ্ঞানের উপর নির্ভর করা, পরীক্ষায় ধৈর্য, বা দৈনন্দিন জীবনে শান্ত অধ্যবসায়। একটি কুরআনের আয়াত এবং ইসলামী আধ্যাত্মিক জ্ঞান থেকে আজকের জন্য একটি সৎ পদক্ষেপ অন্তর্ভুক্ত করুন।",

  "promptPrayerReflection": "সালাত, দোয়া বা যিকরের উপর ভিত্তি করে একটি ছোট ইসলামী প্রার্থনা প্রতিফলন লিখুন। প্রতিটি বার ফর্ম পরিবর্তন করুন: একটি সকাল বা সন্ধ্যার স্মরণ (আধকার), পাঁচটি দৈনিক নামাজের প্রতিফলন, একটি কুরআনের আয়াতের চিন্তাভাবনা, বা একটি হৃদয়গ্রাহী দোয়া। একটি কুরআনের আয়াত অন্তর্ভুক্ত করুন এবং ব্যবহৃত প্রার্থনার ফর্ম সংক্ষিপ্তভাবে নাম দিন।",

  "promptHopeDifficultTimes": "কঠিন সময়ে ধৈর্য (সবর) এবং আশা সম্পর্কে একটি ইসলামী প্রতিফলন লিখুন। পরীক্ষা সম্পর্কে কুরআনিক শিক্ষা, নবীদের সহনশীলতা এবং কঠিন মুহূর্তে আল্লাহর দয়া থেকে আঁকুন। প্রতিটি বার কোণ পরিবর্তন করুন। একটি কুরআনের আয়াত এবং ইসলামী ঐতিহ্য থেকে একটি উৎসাহব্যঞ্জক দৃষ্টিভঙ্গি অন্তর্ভুক্ত করুন।",

  "promptForgiveness": "ক্ষমা চাওয়া (তাওবাহ) এবং আল্লাহর দয়া সম্পর্কে একটি জ্ঞানী ইসলামী প্রতিফলন লিখুন। তাওবার উপর কুরআনিক শিক্ষা, আল্লাহর সহানুভূতি এবং নবী মুহাম্মদ সাল্লাল্লাহু আলাইহি ওয়াসাল্লামের ক্ষমাশীল উদাহরণ থেকে আঁকুন। থিম পরিবর্তন করুন: আল্লাহের দিকে ফিরে যাওয়া, অন্যদের ক্ষমা করা, সম্পর্ক নিরাময় করা, বা ভুলের পরে আল্লাহর দয়ায় বিশ্বাস করা। একটি কুরআনের আয়াত এবং একটি বাস্তব পদক্ষেপ অন্তর্ভুক্ত করুন।",

  "promptLoveCompassion": "দৈনন্দিন জীবনে দয়া (রহমাহ) এবং সহানুভূতি সম্পর্কে একটি ছোট ইসলামী প্রতিফলন লিখুন। নবী মুহাম্মদ সাল্লাল্লাহু আলাইহি ওয়াসাল্লামের উদাহরণ, ইহসান (উৎকর্ষতা) এর ধারণা এবং পরিবার, প্রতিবেশী এবং দুর্বলদের প্রতি দয়ার ইসলামী শিক্ষা থেকে আঁকুন। একটি কুরআনের আয়াত এবং আজ অনুশীলন করার জন্য একটি ছোট সহানুভূতির কাজ অন্তর্ভুক্ত করুন।",

  "promptStrengthCourage": "বিশ্বাস-ভিত্তিক শক্তি এবং সাহস সম্পর্কে একটি ইসলামী প্রতিফলন লিখুন। নবীদের উদাহরণ, প্রাথমিক মুসলিম সম্প্রদায় এবং কঠিন পরিস্থিতিতে দৃঢ় থাকা বিশ্বাসীদের থেকে আঁকুন। প্রতিটি বার থিম পরিবর্তন করুন: বিশ্বাসের মাধ্যমে সাহস, প্রার্থনায় শক্তি, ভয়ের সময় আল্লাহর উপর আস্থা, বা কঠিনতায় স্থিতিস্থাপকতা। একটি কুরআনের আয়াত এবং একটি ছোট দোয়া বা স্মরণের বাক্য অন্তর্ভুক্ত করুন।",

  "promptGratitude": "আল্লাহর প্রতি কৃতজ্ঞতা (শুকর) সম্পর্কে একটি ইসলামী প্রতিফলন লিখুন। এটিকে কুরআনিক শিক্ষা এবং নবী ঐতিহ্যে নিহিত করুন। কোণ পরিবর্তন করুন: কঠিনতায় কৃতজ্ঞতা, ছোট আশীর্বাদের প্রশংসা করা, আল্লাহর প্রশংসার সাথে দিন শুরু করা, বা দৈনন্দিন জীবনে আল্লাহর নির্দেশনা স্বীকার করা। একটি কুরআনের আয়াত এবং একটি কৃতজ্ঞতা অনুশীলন অন্তর্ভুক্ত করুন।",

  "promptPurposeCalling": "আল্লাহকে ইবাদত করা এবং সঠিকভাবে জীবনযাপন করার জীবনের উদ্দেশ্য সম্পর্কে একটি ইসলামী প্রতিফলন লিখুন। উদ্দেশ্য সম্পর্কে কুরআনিক শিক্ষা, অন্যদের সেবা করা এবং ভালোর জন্য নিজের উপহার ব্যবহার করা থেকে আঁকুন। প্রতিটি বার থিম পরিবর্তন করুন: পরিবার এবং সম্প্রদায়ের সেবা করা, ইস্তিখারার মাধ্যমে নির্দেশনা খোঁজা, উদ্দেশ্য সহকারে বসবাস করা, বা সাধারণ কাজে অর্থ খুঁজে পাওয়া। একটি কুরআনের আয়াত এবং দুটি চিন্তা-উদ্দীপক প্রশ্ন অন্তর্ভুক্ত করুন।",

  "promptFamilyRelationships": "কুরআনিক শিক্ষা এবং নবী মুহাম্মদ সাল্লাল্লাহু আলাইহি ওয়াসাল্লামের উদাহরণে নিহিত পারিবারিক এবং সম্পর্ক সম্পর্কে জ্ঞানী ইসলামী নির্দেশনা লিখুন। প্রতিটি বার থিম পরিবর্তন করুন: পারিবারিক জীবনে দয়া, দ্বন্দ্বে ধৈর্য, পিতামাতার সম্মান করা, ঈমানে সন্তান লালনপালন করা, বা বিবাহ শক্তিশালী করা। একটি কুরআনের আয়াত এবং একটি সম্পর্কিত অনুশীলন চেষ্টা করতে অন্তর্ভুক্ত করুন।",

  "promptPeaceAnxietyRelief": "আল্লাহর স্মরণ (যিকর) এবং তাঁর পরিকল্পনায় আস্থার মাধ্যমে অন্তরের শান্তি খোঁজা সম্পর্কে একটি প্রশান্তিমূলক ইসলামী প্রতিফলন লিখুন। হৃদয়ের প্রশান্তি, প্রার্থনা এবং আল্লাহর ইচ্ছায় আত্মসমর্পণ সম্পর্কে কুরআনিক শিক্ষা থেকে আঁকুন। প্রতিটি বার পদ্ধতি পরিবর্তন করুন এবং একটি কুরআনের আয়াত এবং ইসলামী ঐতিহ্য থেকে একটি সহজ ভিত্তি অনুশীলন অন্তর্ভুক্ত করুন।",

  "promptWisdomOfJesus": "ইসলামে শেখানো হিসাবে নবীদের কাছ থেকে জ্ঞানের একটি ছোট অংশ লিখুন। কুরআন বা হাদীস থেকে আঁকুন এবং ইসলামী পণ্ডিতরা শিক্ষাটি কীভাবে বুঝেছেন তা সংক্ষিপ্তভাবে ব্যাখ্যা করুন। প্রতিটি বার বিষয় পরিবর্তন করুন: চরিত্র, ধৈর্য, বিনয়, ঈমান, বা দৈনন্দিন পরিচালনা। একটি কুরআনিক আয়াত বা হাদীস রেফারেন্স এবং একটি ব্যবহারিক প্রয়োগ অন্তর্ভুক্ত করুন।",

  "promptHumilityCharacter": "বিনয় (তাওয়াধু) এবং ভালো চরিত্র (আখলাক) সম্পর্কে একটি ইসলামী প্রতিফলন লিখুন। কুরআনিক শিক্ষা, নবী মুহাম্মদ সাল্লাল্লাহু আলাইহি ওয়াসাল্লামের উদাহরণ এবং ইসলামী চরিত্র উন্নয়নের ঐতিহ্য থেকে আঁকুন। থিম পরিবর্তন করুন: নেতৃত্বে বিনয়, ভুল স্বীকার করা, অন্যদের প্রতি সম্মান সহকারে আচরণ করা, বা আত্ম-প্রতিফলনের মাধ্যমে আধ্যাত্মিক বৃদ্ধি পাওয়া। একটি কুরআনের আয়াত এবং অনুশীলন করার জন্য একটি অভ্যাস অন্তর্ভুক্ত করুন।",

  "promptOvercomingTemptation": "প্রলোভন প্রতিরোধ এবং সঠিক পথে থাকা সম্পর্কে একটি ইসলামী প্রতিফলন লিখুন। কুরআনিক নির্দেশনা, আল্লাহর স্মরণ (যিকর), প্রার্থনা (সালাত) এবং সংগ্রামে পরাজিত হওয়া বিশ্বাসীদের উদাহরণ থেকে আঁকুন। প্রতিটি বার কোণ পরিবর্তন করুন। একটি কুরআনের আয়াত এবং পরবর্তী ২৪ ঘন্টার জন্য একটি ব্যবহারিক কৌশল অন্তর্ভুক্ত করুন।",

  "promptEveningReflection": "সন্ধ্যার স্মরণ (আধকার আল-মাসা) এর ঐতিহ্যে নিহিত একটি শান্ত ইসলামী সন্ধ্যা প্রতিফলন লিখুন। বিশ্রামের আগে কৃতজ্ঞতা, আত্ম-প্রতিফলন (মুহাসাবাহ) এবং আল্লাহর উপর আস্থা উৎসাহিত করুন। ৩–৫ টি ছোট প্রতিফলন দিনের বিষয়ে, একটি সংক্ষিপ্ত সমাপনী দোয়া এবং একটি কুরআনের আয়াত অন্তর্ভুক্ত করুন।",

