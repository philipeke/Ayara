  "promptDailyGuidance": "ڕێنمایێکی ڕۆژانە کورت و کاریگەر بنووسە لە بنەمای ئیمانی سونی - بنیاتی لەسەر قورئان، حەدیث و فێرکاری پێغەمبەری محمد صلى الله عليه وسلم. هەر جاран لە کۆری جیا بڕوانە: فیرد لە ئاخلاقی ئیسلام، ڕاستیێکی لە سوننەت، حیکمەتی ساحابەی پێغەمبەر یان چالاکێکی خاموش لە تێکەڵی ئیسلام. یەک ئایەتی قورئان (سورەت:ئایەت) دا بدۆزیتەوە و خۆڕاگرێکی 1-2 خاڵی بنووسە کە بە مێژوو بگات. بەچاوی ڕۆژی ئیسلامی یان ڕۆژێکی گرنگ پەیوەند دە.",

  "promptFaithTrust": "خۆڕاگری قسەیێکی ئیسلامی لە ئیمان و باوەڕ بە پلانی خودا (توکول) بنووسە. بنیاتی دا لەسەر قورئان، نموونەی پێغەمبەری محمد صلى الله عليه وسلم و ئیمانی ساحابە. هەر جاران سەبارەت بە واتا جیا: باوێری خودا لە نێو ئەنجومەرە، پشت بە حیکمەتی خودا، سابر لە تاڵی، یان ماندوبوونی خاموش لە ژیانی ڕۆژانە. یەک ئایەتی قورئان و یەک گام زۆر هێماتیدار بۆ ئەمرۆ.",

  "promptPrayerReflection": "خۆڕاگری نوێژی ئیسلامی کورت لە سەر سلاتی، دوادا یان ذیکری بنووسە. فۆڕمی جیا: یاداوەری بەیان یان ئێوار (ئەذکار)، خۆڕاگری سەبارەت بە پێنج نوێژی ڕۆژ، خۆڕاگری ئایەتێکی قورئان یان ئیلتیماسێکی دڵگریان. یەک ئایەتی قورئان دا بدۆزیتەوە و شێوەی نوێژ ناونووسیت.",

  "promptHopeDifficultTimes": "خۆڕاگری ئیسلامی سەبارەت بە سابری (صبر) و هیوا لە کاتی تێکەڵی بنووسە. فێرکاری قورئان سەبارەت بە تاڵی، ماندوبوونی پێغەمبەران و شفقەتی خودا لە کاتی قورستان. هەر جاران کۆری جیاتر. یەک ئایەتی قورئان و یەک لێهاتوو لە تێکەڵی ئیسلام.",

  "promptForgiveness": "خۆڕاگری حیکمتیانەی ئیسلام سەبارەت بە داواکاری لێبوردن (توبە) و شفقەتی خودا بنووسە. لە فێرکاری قورئان سەبارەت بە توبە، شفقەتی خودا و نموونەی لێبوردنێکی پێغەمبەری محمد صلى الله عليه وسلم. وات جیا: گێڕانەوەی نیگەی خودا، لێبوردنی کەسانی تر، چاکبوونی پەیوەندی یان باوێری شفقەتی خودا دوای هەڵە. یەک ئایەتی قورئان و یەک گام کاریگەر.",

  "promptLoveCompassion": "خۆڕاگری ئیسلامی کورت سەبارەت بە شفقەت (رحمە) و بێزاری لە ژیانی ڕۆژانە بنووسە. لە نموونەی پێغەمبەری محمد صلى الله عليه وسلم، تێگەیشتنی احسان (ئامیری باشتر) و فێرکاری ئیسلام سەبارەت بە سۆپاتی بۆ خێزان، جیران و بێدار. یەک ئایەتی قورئان و یەک کردارێکی بێزاری کورت بۆ ئەمرۆ.",

  "promptStrengthCourage": "خۆڕاگری ئیسلامی سەبارەت بە هێز بە ئیمان و بیرۆ بنووسە. لە نموونەی پێغەمبەران، جێگیری مسلمانانی سەرەتایی و باوێرمەندانی کە تێکەڵدا ماند. هەر جاران سەبارەت بە وات جیا: بیرۆ بە ئیمان، هێز لە نوێژ، باوێری خودا لە کاتی تڕس، یان مانیوو لە قورستان. یەک ئایەتی قورئان و دوادی کورت یان وشەی یادبێژ.",

  "promptGratitude": "خۆڕاگری ئیسلامی سەبارەت بە سپاس (شکر) بۆ خودا بنووسە. بنیاتی دا لەسەر فێرکاری قورئان و تێکەڵی پێغەمبەریێتی. کۆری جیا: سپاس لە کاتی تێکەڵی، بڕتێ دان بە یاریمەندییەکانی کورت، دەستپێکردنی ڕۆژ بە ستایشی خودا یان ناسینی ڕێنمایی خودا لە ژیانی ڕۆژانە. یەک ئایەتی قورئان و یەک چالاکیی سپاس.",

  "promptPurposeCalling": "خۆڕاگری ئیسلامی سەبارەت بە مەبەستی ژیان لە پەرستنی خودا و ژیانی درێژایی بنووسە. لە فێرکاری قورئان سەبارەت بە مەبەست، خزمەتی کەسانی تر و بەکارهێنانی تالەنتی خۆ بۆ باشیی. هەر جاران سەبارەت بە وات جیا: خزمەتی خێزان و کۆمەڵگە، تێگەیشتن بە راهێنان لە ئیستیخارە، ژیان بە مەبەست یان دۆزینەوەی واتای ژیان لە کاریگەری ساده. یەک ئایەتی قورئان و دوو پرسیاری خۆڕاگریانە.",

  "promptFamilyRelationships": "ڕێنمایی حیکمتیانەی ئیسلام سەبارەت بە خێزان و پەیوەندی بنیاتی لەسەر فێرکاری قورئان و نموونەی پێغەمبەری محمد صلى الله عليه وسلم. هەر جاران سەبارەت بە وات جیا: سۆپاتی لە ژیانی خێزان، سابری لە ئاختیڕانی، بڕگەی پاپۆڕان، پەروەردەی مندلان بە ئیمان یان قووتاندنی هاوسەرگیری. یەک ئایەتی قورئان و یەک چالاکیی پەیوەندیدار.",

  "promptPeaceAnxietyRelief": "خۆڕاگری ئیسلامی سەلماوە سەبارەت بە دۆزینەوەی ئاشتی ناخی لە ریگای یاداوەری خودا (ذیکر) و باوێری بە پلانی بنووسە. لە فێرکاری قورئان سەبارەت بە ئاشتی دڵ، نوێژ و تێپەڕبوون بە خوایی خودا. هەر جاران شێوازی جیا و یەک ئایەتی قورئان و یەک چالاکیی ساده لە تێکەڵی ئیسلام.",

  "promptWisdomOfJesus": "وتەیێکی حیکمتیانە لە پێغەمبەران وەک فێرکاری ئیسلام بنووسە. لە قورئان یان حەدیث و بریتی وردبینێ چۆن مێری ئیسلام فێرکاری تێگەیشتووە. سەبارەت بە وات جیاتر: توانادارێتی، سابری، ئێزی، ئیمان یان چالاکیی ڕۆژانە. یەک ئایەتی قورئان یان حەدیث و یەک بەکارهێنانی پراکتیکی.",

  "promptHumilityCharacter": "خۆڕاگری ئیسلامی سەبارەت بە ئێزی (تواضع) و توانادارێتی باشتر (اخلاق) بنووسە. لە فێرکاری قورئان، نموونەی پێغەمبەری محمد صلى الله عليه وسلم و تێکەڵی پەروەردەی توانادارێتی ئیسلام. وات جیا: ئێزی لە سەرانجامدانی، ڕازی کردن بە هەڵەی خۆ، ڕێزدانی بە کەسانی تر یان گەشەدان لە رۆحی ئیسلام. یەک ئایەتی قورئان و یەک خولقایی بۆ پراکتیکی.",

  "promptOvercomingTemptation": "خۆڕاگری ئیسلامی سەبارەت بە ڕەتکردنەوەی وە و ماندن لەسەر ڕێی ڕاست بنووسە. لە ڕێنمایی قورئان، یاداوەری خودا (ذیکر)، نوێژ (سلات) و نموونە باوێرمەندانی کە ڕەتی کردەوە. هەر جاران کۆری جیاتر. یەک ئایەتی قورئان و یەک سترجتێژی پراکتیکی بۆ 24 کاتژمێری داهاتوو.",

  "promptEveningReflection": "خۆڕاگری ئیسلامی سەلماوەی ئێوار بنیاتی لەسەر تێکەڵی یاداوەری ئێوار (اذكار المساء) بنووسە. سپاس، خۆڕاگری گونجاو (محاسبة) و باوێری خودا پێش خەو هاندان. 3-5 پرسیاری خۆڕاگری کورت سەبارەت بە ڕۆژ، دوادی قسەیێکی کورت و یەک ئایەتی قورئان.",

