  "promptDailyGuidance": "सुन्नी इस्लामिक विश्वासावर आधारित अल्पकालीन, व्यावहारिक दैनिक मार्गदर्शन लिहा — कुराणे शरीफ, हदीस आणि पैगंबर मुहम्मद सल्लल्लाहु अलैहि वस्सलाम यांच्या शिक्षणांच्या आधारे। प्रत्येक वेळी एक नवीन दृष्टिकोन निवडा: इस्लामिक नैतिकतेचा एक सद्गुण, सुन्नत मधील सत्य, पैगंबराच्या साथीचे ज्ञान किंवा इस्लामिक परंपरेतील एक शांत अभ्यास। एक कुरान श्लोक (सूरह:आयत) आणि दिनभर घेऊन जाण्यासाठी १-२ वाक्य चिंतन समाविष्ट करा। इस्लामिक कॅलेंडर किंवा महत्वाचे तारीख असल्यास वैकल्पिकरित्या संपर्क साधा।",

  "promptFaithTrust": "ईमान (विश्वास) आणि अल्लाहच्या योजनेवर विश्वास (तव्वक्कुल) वर एक अल्पकालीन इस्लामिक चिंतन लिहा। हे कुराणे शरीफ, पैगंबर मुहम्मद सल्लल्लाहु अलैहि वस्सलाम यांचे उदाहरण आणि साहाबेचे विश्वासावर आधारित असावे। प्रत्येक वेळी थीम भिन्न करा: अनिश्चिततेदरम्यान अल्लाहवर विश्वास, दैवीय ज्ञानावर अवलंबून राहणे, चाचणीमधील धैर्य किंवा दैनंदिन जीवनातील शांत अधिष्ठान। एक कुरान श्लोक आणि आजच्या लिए इस्लामिक अध्यात्मिक ज्ञानातून एक प्रामाणिक पाऊल समाविष्ट करा।",

  "promptPrayerReflection": "सलात (नमाज), दुआ किंवा जिक्र (अल्लाहचे स्मरण) यावर आधारित एक अल्पकालीन इस्लामिक प्रार्थना चिंतन लिहा। प्रत्येक वेळी फॉर्म भिन्न करा: सकाळ किंवा संध्याकालीन स्मरण (अधकार), पाच दैनिक नमाजांवर चिंतन, कुरानिक श्लोकाचा ध्यान किंवा एक हृदयस्पर्शी प्रार्थना। एक कुरान श्लोक आणि वापरलेल्या प्रार्थना फॉर्मचे संक्षिप्त नाम समाविष्ट करा।",

  "promptHopeDifficultTimes": "कठिण समयांत धैर्य (सब्र) आणि आशा यावर एक इस्लामिक चिंतन लिहा। चाचणीबद्दल कुरानिक शिक्षणा, संदेष्ट्यांचा अधिष्ठान आणि कठिण क्षणांमध्ये अल्लाहची कृपा यावरून काढा। प्रत्येक वेळी दृष्टिकोन भिन्न करा। एक कुरान श्लोक आणि इस्लामिक परंपरेतून एक प्रोत्साहक दृष्टिकोन समाविष्ट करा।",

  "promptForgiveness": "क्षमा शोधणे (तवबह) आणि अल्लाहची कृपा यावर एक बुद्धिमान इस्लामिक चिंतन लिहा। तपश्चर्या, अल्लाहची दया आणि पैगंबर मुहम्मद सल्लल्लाहु अलैहि वस्सलाम यांचे क्षमाशील उदाहरण याबद्दल कुरानिक शिक्षणातून काढा। थीम भिन्न करा: अल्लाहकडे परत जाणे, इतरांना क्षमा करणे, नातेसंबंध बरे करणे किंवा चुकीनंतर अल्लाहची दया मानणे। एक कुरान श्लोक आणि एक ठोस पाऊल समाविष्ट करा।",

  "promptLoveCompassion": "दैनंदिन जीवनातील दया (रहमह) आणि करुणा यावर एक अल्पकालीन इस्लामिक चिंतन लिहा। पैगंबर मुहम्मद सल्लल्लाहु अलैहि वस्सलाम यांचे उदाहरण, इहसान (उत्तमता) ही संकल्पना आणि कुटुंब, शेजारी आणि असुरक्षित लोकांच्या प्रती दया याबद्दल इस्लामिक शिक्षणातून काढा। एक कुरान श्लोक आणि आज अभ्यास करायचा एक छोटा दया-कर्म समाविष्ट करा।",

  "promptStrengthCourage": "विश्वास-आधारित शक्ती आणि साहस यावर एक इस्लामिक चिंतन लिहा। संदेष्ट्यांचे उदाहरण, प्रारंभिक मुस्लिम समाज आणि कष्ट सहन करत विश्वास ठेवणारे विश्वासू यांच्यातून काढा। प्रत्येक वेळी थीम भिन्न करा: विश्वासाद्वारे साहस, प्रार्थनेद्वारे शक्ती, भयादरम्यान अल्लाहवर विश्वास किंवा कठिणतेमध्ये दृढता। एक कुरान श्लोक आणि एक संक्षिप्त दुआ किंवा स्मरणचा वाक्यांश समाविष्ट करा।",

  "promptGratitude": "अल्लाहच्या प्रती कृतज्ञता (शुक्र) यावर एक इस्लामिक चिंतन लिहा। हे कुरानिक शिक्षणा आणि पैगंबरी परंपरेवर आधारित असावे। दृष्टिकोन भिन्न करा: कठिणतेमध्ये कृतज्ञता, छोट्या आशीर्वादांचे मूल्य, अल्लाहाच्या स्तुतीद्वारे दिन सुरू करणे किंवा दैनंदिन जीवनातील अल्लाहच्या मार्गदर्शनाचे मूल्य. एक कुरान श्लोक आणि एक कृतज्ञता-अभ्यास समाविष्ट करा।",

  "promptPurposeCalling": "अल्लाहास वंदन करणे आणि न्यायपूर्वक जीवन जगण्यासाठी जीवनाच्या उद्देश्य यावर एक इस्लामिक चिंतन लिहा। उद्देश्य, इतरांची सेवा आणि सत्कर्मासाठी आपल्या योग्यता वापरण्याबद्दल कुरानिक शिक्षणातून काढा। प्रत्येक वेळी थीम भिन्न करा: कौटुंबिक आणि सामुदायिक सेवा, इस्तिखारे (निर्णय दुआ) द्वारे मार्गदर्शन शोधणे, इरादेसह जीवन जगणे किंवा सामान्य कार्यातील अर्थ शोधणे। एक कुरान श्लोक आणि दोन विचारशील प्रश्न समाविष्ट करा।",

  "promptFamilyRelationships": "कुरानिक शिक्षणा आणि पैगंबर मुहम्मद सल्लल्लाहु अलैहि वस्सलाम यांच्या उदाहरणावर आधारित कुटुंब आणि नातेसंबंध याबद्दल बुद्धिमान इस्लामिक मार्गदर्शन लिहा। प्रत्येक वेळी थीम भिन्न करा: कौटुंबिक जीवनातील दया, संघर्षातील धैर्य, पालकांचे सन्मान, विश्वासातील मुलांचे पालन किंवा विवाह मजबूत करणे। एक कुरान श्लोक आणि एक नातेसंबंध-अभ्यास समाविष्ट करा।",

  "promptPeaceAnxietyRelief": "अल्लाहचे स्मरण (जिक्र) आणि त्याच्या योजनेवर विश्वास द्वारे आंतरिक शांती शोधण्याबद्दल एक शांत इस्लामिक चिंतन लिहा। हृदयाची शांती, प्रार्थना आणि अल्लाहच्या इच्छेच्या समर्पणाबद्दल कुरानिक शिक्षणातून काढा। प्रत्येक वेळी दृष्टिकोन भिन्न करा आणि एक कुरान श्लोक आणि इस्लामिक परंपरेतील एक सोपा अधिष्ठान-अभ्यास समाविष्ट करा।",

  "promptWisdomOfJesus": "इस्लामातून सिखवलेल्या संदेष्ट्यांचे ज्ञानचा एक अल्पकालीन तुकडा लिहा। कुरान किंवा हदीसातून काढा आणि इस्लामिक विद्वानांनी शिक्षण कसे समजले याचे संक्षिप्त स्पष्टीकरण द्या। प्रत्येक वेळी विषय भिन्न करा: सत्कर्तृत्व, धैर्य, विनम्रता, विश्वास किंवा दैनंदिन आचरण। एक कुरान श्लोक किंवा हदीस संदर्भ आणि एक व्यावहारिक अनुप्रयोग समाविष्ट करा।",

  "promptHumilityCharacter": "विनम्रता (तवाधु) आणि सत्कर्तृत्व (अखलाक) यावर एक इस्लामिक चिंतन लिहा। कुरानिक शिक्षणा, पैगंबर मुहम्मद सल्लल्लाहु अलैहि वस्सलाम यांचे उदाहरण आणि इस्लामिक सत्कर्तृत्व विकासाची परंपरा याबद्दल काढा। थीम भिन्न करा: नेतृत्वातील विनम्रता, चुकी स्वीकार करणे, इतरांच्या सम्मानार्थ व्यवहार किंवा आत्मचिंतनाद्वारे आध्यात्मिक वृद्धी। एक कुरान श्लोक आणि एक अभ्यास-सवयी समाविष्ट करा।",

  "promptOvercomingTemptation": "प्रलोभन प्रतिरोध करणे आणि सरळ मार्गावर राहणे याबद्दल एक इस्लामिक चिंतन लिहा। कुरानिक मार्गदर्शन, अल्लाहचे स्मरण (जिक्र), प्रार्थना (सलात) आणि संघर्ष जिंकणारे विश्वासू यांच्यातून काढा। प्रत्येक वेळी दृष्टिकोन भिन्न करा। एक कुरान श्लोक आणि पुढील २४ तासांसाठी एक व्यावहारिक धोरण समाविष्ट करा।",

  "promptEveningReflection": "संध्याकालीन स्मरणाच्या परंपरेवर आधारित एक शांत इस्लामिक संध्या चिंतन लिहा (अधकार अल-मसाया). आभार, आत्मचिंतन (मुहासबह) आणि विश्रामापूर्वी अल्लाहावर विश्वास प्रोत्साहित करा। ३-५ संक्षिप्त चिंतन प्रश्न, एक संक्षिप्त समाप्ति दुआ आणि एक कुरान श्लोक समाविष्ट करा।",

