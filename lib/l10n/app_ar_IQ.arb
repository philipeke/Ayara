  "dailyScripture0Text": "إن الذين آمنوا وعملوا الصالحات سيكون لهم جنات تجري من تحتها الأنهار",
  "dailyScripture0Ref": "القرآن الكريم 54:55",
  "dailyScripture1Text": "وما أرسلناك إلا رحمة للعالمين",
  "dailyScripture1Ref": "القرآن الكريم 21:107",
  "dailyScripture2Text": "أليس الله بكاف عبده ويخوفونك بالذين من دونه",
  "dailyScripture2Ref": "القرآن الكريم 39:36",
  "dailyScripture3Text": "عسى أن تكرهوا شيئاً وهو خير لكم وعسى أن تحبوا شيئاً وهو شر لكم والله يعلم وأنتم لا تعلمون",
  "dailyScripture3Ref": "القرآن الكريم 2:216",
  "dailyScripture4Text": "إن الله مع الصابرين",
  "dailyScripture4Ref": "القرآن الكريم 2:153",
  "dailyScripture5Text": "فاذكروني أذكركم واشكروا لي ولا تكفرون",
  "dailyScripture5Ref": "القرآن الكريم 2:152",
  "dailyScripture6Text": "إن أكرمكم عند الله أتقاكم",
  "dailyScripture6Ref": "القرآن الكريم 49:13",
  "dailyScripture7Text": "وقضى ربك ألا تعبدوا إلا إياه وبالوالدين إحساناً",
  "dailyScripture7Ref": "القرآن الكريم 17:23",
  "dailyScripture8Text": "فإن مع العسر يسراً",
  "dailyScripture8Ref": "القرآن الكريم 94:5-6",
  "dailyScripture9Text": "وهو معكم أينما كنتم والله بما تعملون بصير",
  "dailyScripture9Ref": "القرآن الكريم 57:4",
  "dailyScripture10Text": "لا يكلف الله نفساً إلا وسعها",
  "dailyScripture10Ref": "القرآن الكريم 2:286",
  "dailyScripture11Text": "ومن يتوكل على الله فهو حسبه",
  "dailyScripture11Ref": "القرآن الكريم 65:3",
  "dailyScripture12Text": "رحمتي وسعت كل شيء",
  "dailyScripture12Ref": "القرآن الكريم 7:156",
  "dailyScripture13Text": "وإذا سألك عبادي عني فإني قريب أجيب دعوة الداع إذا دعان",
  "dailyScripture13Ref": "القرآن الكريم 2:186",
  "dailyScripture14Text": "من عمل صالحاً من ذكر أو أنثى وهو مؤمن فلنحيينه حياة طيبة",
  "dailyScripture14Ref": "القرآن الكريم 16:97",
  "dailyScripture15Text": "إن الله لا يغير ما بقوم حتى يغيروا ما بأنفسهم",
  "dailyScripture15Ref": "القرآن الكريم 13:11",
  "dailyScripture16Text": "فلا تهنوا وتحزنوا وأنتم الأعلون إن كنتم مؤمنين",
  "dailyScripture16Ref": "القرآن الكريم 3:139",
  "dailyScripture17Text": "قل يا عبادي الذين أسرفوا على أنفسهم لا تقنطوا من رحمة الله إن الله يغفر الذنوب جميعاً",
  "dailyScripture17Ref": "القرآن الكريم 39:53",
  "dailyScripture18Text": "ومن يتق الله يجعل له مخرجاً ويرزقه من حيث لا يحتسب",
  "dailyScripture18Ref": "القرآن الكريم 65:2-3",
  "dailyScripture19Text": "لا تيأسوا من رحمة الله",
  "dailyScripture19Ref": "القرآن الكريم 12:87",
  "dailyScripture20Text": "ولقد يسرنا القرآن للذكر فهل من مدكر",
  "dailyScripture20Ref": "القرآن الكريم 54:17",
  "dailyScripture21Text": "ووجدك ضالاً فهدى",
  "dailyScripture21Ref": "القرآن الكريم 93:7",
  "dailyScripture22Text": "وقال ربكم ادعوني أستجب لكم",
  "dailyScripture22Ref": "القرآن الكريم 40:60",
  "dailyScripture23Text": "ولقد كرمنا بني آدم",
  "dailyScripture23Ref": "القرآن الكريم 17:70",
  "dailyScripture24Text": "واستعينوا بالصبر والصلاة",
  "dailyScripture24Ref": "القرآن الكريم 2:45",
  "dailyScripture25Text": "فمن يعمل مثقال ذرة خيراً يره",
  "dailyScripture25Ref": "القرآن الكريم 99:7",
  "dailyScripture26Text": "بلى إن نصر الله قريب",
  "dailyScripture26Ref": "القرآن الكريم 2:214",
  "dailyScripture27Text": "ومن شكر فإنما يشكر لنفسه",
  "dailyScripture27Ref": "القرآن الكريم 31:12",

  "dailyReflection0": "مع إطباق هذا اليوم، فكّر في لحظة أظهرت فيها رحمة الله.",
  "dailyReflection1": "اعرض على الله كل ما أثقل قلبك اليوم.",
  "dailyReflection2": "اذكر نعمة واحدة من هذا اليوم وعبّر شكرك لله.",
  "dailyReflection3": "استقر في معرفة أنك محفوظ برعاية الله اللامحدودة.",
  "dailyReflection4": "تأمل في اللحظات التي دعاك فيها الإحساس بالرحمة واللطف.",
  "dailyReflection5": "أطلق سراح ما لا تستطيع السيطرة عليه وثق في حكمة الله.",
  "dailyReflection6": "مع اقتراب الليل، استقبل السلام في ذكر الله.",
  "dailyReflection7": "تأمل في احترامك لصلواتك اليوم واشكر الله على كل صلاة.",
  "dailyReflection8": "فكّر في لحظة وجهك فيها الصبر اليوم.",
  "dailyReflection9": "اطلب المغفرة عن أي تقصير في هذا اليوم — رحمة الله لا نهاية لها.",
  "dailyReflection10": "اذكر شخصاً واحداً أظهرت له لطفاً وادع له.",
  "dailyReflection11": "اجلس مع الامتنان: ماذا وفر الله لك اليوم دون أن تطلبه؟",
  "dailyReflection12": "تأمل في آية من القرآن الكريم تتحدث عن حالك الحالية.",
  "dailyReflection13": "فكّر في كيفية استخدام وقتك اليوم — وسلّم غداً لله.",
  "dailyReflection14": "استقر مرتاحاً بأن أي شدة اليوم، كان الله معك فيها.",
  "dailyReflection15": "فكّر في طريقة واحدة خدمت بها أسرتك أو مجتمعك من أجل الله.",
  "dailyReflection16": "مع انجلاء الليل، توب إلى الله — إنه يحب من يعود إليه.",
  "dailyReflection17": "تأمل في الجمال الذي وضعه الله في يومك، مهما كان صغيراً.",
  "dailyReflection18": "فكّر في ما تعلمته اليوم وكيف يقربك من الله.",
  "dailyReflection19": "دع قلق اليوم يستقر مع الله — إنه يحمل ما لا تستطيع.",
  "dailyReflection20": "تذكر لحظة استطعت أن تختار الأفضل فيها، وتعلم منها برفق.",
  "dailyReflection21": "ادع لمن يعانون — دعاؤك هدية لهم.",
  "dailyReflection22": "استحضر نعمة تتجاهلها غالباً واستغرق لحظة شاكراً الله عليها.",
  "dailyReflection23": "تأمل في نياتك اليوم — هل كانت من أجل الله؟ ابدأ مجدداً غداً.",
  "dailyReflection24": "مع هدوء الليل، استمع لقرب الله في السكون.",
  "dailyReflection25": "فكّر في مكان وجدت فيه قوة اليوم — تلك القوة من الله.",
  "dailyReflection26": "اذكر شيئاً ستفعله غداً من أجل الله لم تفعله اليوم.",
  "dailyReflection27": "وأنت تستعد للراحة، استودع روحك الله — إنه خير الحافظين.",

