  "promptPurposeCalling": "សរសេរការឆ្លឹងម្នាក់ឯង Islamic លើគោលបំណងនៃជីវិតក្នុងការប្រឹក្សាក្រោយលោក Allah និងការរស់នៅថ្ងឹងលម្អិត។ ដកយកមកពីការបង្រៀន Quranic អំពីគោលបំណង, ការបម្រើផ្សេងទៀត នឹងការប្រើប្រាស់ល្អគុណរបស់ក្នុងល្អ។ ផ្លាស់ប្តូរប្រធានបទនីមួយៗ៖ ការបម្រើក្រុមគ្រួសារ និងសហគមន៍, ស្វាគមន៍មគ្គុទ្ធិឆ្លងកាត់ Istikhara, ការរស់នៅដោយលក្ខណៈដើម ឬការស្វាគមន៍ល័ក្ខន៍ក្នុងការងារប្រចាំថ្ងៃ។ រួមបញ្ចូល Qur'an verse មួយ និងសំណួរឆ្លឹងម្នាក់ឯងពីរ។",

  "promptFamilyRelationships": "សរសេរការណែនាំ Islamic ដ៏ល្អលើក្រុមគ្រួសារ និងទាក់ទងគ្នាមូលដ្ឋានលើការបង្រៀន Quranic និងឧទាហរណ៍របស់លោកគ្រូ Muhammad។ ផ្លាស់ប្តូរប្រធានបទនីមួយៗ៖ ល្អគុណក្នុងជីវិតក្រុមគ្រួសារ, ការស្ងប់ស្ងាប់ក្នុងសង្រ្គាម, ការគោរពឪពុកម្ដាយ, ការលូតលាស់កូន-ក្រមួលក្នុងព្រឹទ្ធិ ឬការរឹងមាំនៃការលាស់គ្នា។ រួមបញ្ចូល Qur'an verse មួយ និងវិធីសាស្ត្របង្គប់គ្នាដែលគួរព្យាយាម។",

  "promptPeaceAnxietyRelief": "សរសេរការឆ្លឹងម្នាក់ឯង Islamic ដែលស្ងប់ ស្ងាប់លើការស្វាគមន៍សន្តិភាពក្នុងដំណើរការចងចាំរបស់ Allah (Dhikr) និងការឈឹងលើផែនការរបស់គាត់។ ដកយកមកពីការបង្រៀន Quranic អំពីវត្ថុម្នាក់ឯងកំរិតក្នុងចិត្ត,祷告 និងការប៉ាន់ងាក់ទៅលើ Allah។ ផ្លាស់ប្តូរវិធីសាស្ត្រនីមួយៗ រួមបញ្ចូល Qur'an verse មួយ និងលម្អិតដ៏សាមញ្ញមួយពីបាំង Islamic។",

  "promptWisdomOfJesus": "សរសេរចម្រាលប្រជ្ញាមួយពីលោកគ្រូនពនៅក្នុងនិយាយលើ Islam។ ដកយកមកពី Qur'an ឬ Hadith និងពន្យល់ដោយមិនយូរក្រឺង কীរីរបៀបដែលអ្នកសិក្សា Islamic បានយល់ការបង្រៀន។ ផ្លាស់ប្តូរប្រធានបទនីមួយៗ៖ ចរិយាលក្ខណ៍, ការស្ងប់ស្ងាប់, កង្វល់, ព្រឹទ្ធិ ឬលម្អិតប្រចាំថ្ងៃ។ រួមបញ្ចូល Quranic verse ឬ Hadith reference និងកម្មវិធីលម្អិតមួយ។",

  "promptHumilityCharacter": "សរសេរការឆ្លឹងម្នាក់ឯង Islamic លើកង្វល់ (Tawadhu) និងចរិយាលក្ខណ៍ល្អ (Akhlaq)។ ដកយកមកពីការបង្រៀន Quranic, ឧទាហរណ៍របស់លោកគ្រូ Muhammad និងប្រពៃណីនៃការអភិវឌ្ឍលក្ខណៈ Islamic។ ផ្លាស់ប្តូរប្រធានបទ៖ កង្វល់ក្នុងការដឹងនាំ, ការទទួលស្គាល់កំហុស, ការព្យាបាលអ្នកដទៃដោយរាប់រង ឬការចូលទៅយល់ដឹងក្នុងសារមួយឯង។ រួមបញ្ចូល Qur'an verse មួយ និងវិធីសាស្ត្រដែលត្រូវប្រតិបត្តិ។",

  "promptOvercomingTemptation": "សរសេរការឆ្លឹងម្នាក់ឯង Islamic លើការទប់ស្កាប់ការចង់បាន និងនៅលើផ្លូវត្រង់។ ដកយកមកពីការណែនាំ Quranic, ការចងចាំរបស់ Allah (Dhikr),祷告 (Salah) និងឧទាហរណ៍របស់អ្នកចូលសាសនាដែលលើកសឹងឡើងវិញ។ ផ្លាស់ប្តូរមុំនីមួយៗ។ រួមបញ្ចូល Qur'an verse មួយ និងយុទ្ធសាស្រ្តលម្អិតមួយសម្រាប់ 24 ម៉ោងបន្ទាប់។",

  "promptEveningReflection": "សរសេរការឆ្លឹងម្នាក់ឯង Islamic ល្ងាចដែលសីលប៉ាន់ងាក់លើប្រពៃណីនៃការឆ្លឹងម្នាក់ឯងល្ងាច (Adhkar al-Masaa')។ ក្ដើងលើការកោតសរសើរ, ការឆ្លឹងម្នាក់ឯង (Muhasabah) និងការឈឹងលើ Allah មុនពេលឈប់។ រួមបញ្ចូល 3–5 សំណួរឆ្លឹងម្នាក់ឯងខ្លីៗលើថ្ងៃមួយ, supplication ដែលឡើងទៅលើ និង Qur'an verse មួយ។",

