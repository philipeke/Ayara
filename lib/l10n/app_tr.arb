  "dailyGraceTitle": "Günlük Rehberlik",
  "dailyGraceScriptureLabel": "GÜNÜN AYETİ",
  "dailyGraceSaintLabel": "HAFTANIN ALİMİ",
  "dailyGraceReflectionLabel": "AKŞAM TEFEKKÜRü",
