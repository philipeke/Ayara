  "promptDailyGuidance": "Kọ itọsọna ojo-ojo ti o kurẹ, oloro, ti o ni ipilẹ ninu Iman Sunni — ti o ju ipilẹ ninu Qur'anu, Hadisi, ati ako ẹkọ Nabii Muhammad. Yan ọjọ tuntun kọọkan: ẹwa ewa Iman, otitọ ninu Sunnah, ogbon lati ọwọ Sahaba, tabi ise ti a gbe jade ninu ẹkọ Iman. Pele kan Adura Qur'anu (Surah:Ayah) ati iponju ọkọọkan - mejeeji ọkọ aiye igba ati irosun. Bawo ni o le ti sokan si Akalejọ Iman tabi ojo pataki ti o ba jẹ ohun ti o yẹ.",

  "promptFaithTrust": "Kọ iponju Iman nipa Iman ati igbẹkẹle ninu ọna Allah (Tawakkul). Ju ipilẹ ninu Qur'anu, apẹrẹ Nabii Muhammad, ati Iman Sahaba. Yi ite kọọkan: igbẹkẹle Allah ni akoko airotẹlẹ, gbigba asiko Allah, suburu ninu idipọn, tabi suburu airotẹlẹ ninu ise ojo-ojo. Pele kan Adura Qur'anu ati ise ti a ba le ṣe loo lati ọwọ ogbon Iman.",

  "promptPrayerReflection": "Kọ iponju adura ti o ju ipilẹ ninu Salat, Adura, tabi Dhikr. Yi ọna kọọkan: iponju owurọ tabi alẹ (Adhkar), iponju adura marun ojo-ojo, ifọkọ-iponju Adura Qur'anu, tabi itura alorinka. Pele kan Adura Qur'anu ati lo oruko ọna adura ti a lo.",

  "promptHopeDifficultTimes": "Kọ iponju Iman nipa suburu (Sabr) ati aniyan ni akoko ẹlẹru. Gba ninu ẹkọ Qur'anu nipa idipọn, suburu Nabii, ati iyanu Allah ni akoko ẹlẹru. Yi itu kọọkan. Pele kan Adura Qur'anu ati ojulẹ ti o ba gba inu ninu ẹkọ Iman.",

  "promptForgiveness": "Kọ iponju ogbon Iman nipa ẹtọ (Tawbah) ati iyanu Allah. Gba ninu ẹkọ Qur'anu nipa ipadabọ si Allah, iyanu Allah, ati apẹrẹ iṣalẹ Nabii Muhammad. Yi ite: yiyipada si Allah, fijiyan awọn ẹlọmọ, ituna onisokan, tabi gbigba ni iyanu Allah lẹhin aṣiṣe. Pele kan Adura Qur'anu ati ise ti o ba le ṣe.",

  "promptLoveCompassion": "Kọ iponju Iman ti o kurẹ nipa iyonu (Rahmah) ati iferan ni ise ojo-ojo. Gba ninu apẹrẹ Nabii Muhammad, iṣe Ihsan (ewa), ati ẹkọ Iman nipa alaanu si ebi, aladugbo, ati awọn ti a ba lo. Pele kan Adura Qur'anu ati ise alaanu ti o ba le ṣe loni.",

  "promptStrengthCourage": "Kọ iponju Iman nipa agbara ti o jẹ lati ọwọ Iman ati iwa agbara. Gba ninu apẹrẹ Nabii, awọn oludagba Iman, ati awọn olumọ ti o duro ni iro ni akoko ẹlẹru. Yi ite kọọkan: iwa agbara nipa Iman, agbara nipa adura, igbẹkẹle ni akoko ibẹru, tabi suburu ninu ẹlẹru. Pele kan Adura Qur'anu ati arosọ tabi ọkọ ẹkọ.",

  "promptGratitude": "Kọ iponju Iman nipa dupe (Shukr) si Allah. Ju ipilẹ ninu ẹkọ Qur'anu ati ẹkọ Nabii. Yi itu: dupe nipa ẹlẹru, dupe fun awọn ẹbun kekere, gbigba owurọ pẹlu oyinbo Allah, tabi mọ ọna Allah ni ise ojo-ojo. Pele kan Adura Qur'anu ati ise dupe.",

  "promptPurposeCalling": "Kọ iponju Iman nipa idi aye ninu gbigbonise Allah ati gbigbe ewa. Gba ninu ẹkọ Qur'anu nipa idi aye, ṣiṣẹ fun awọn miiran, ati lo ẹru fun ewa. Yi ite kọọkan: ṣiṣẹ fun ebi ati agbegbe, wọlẹ Istikhara, gbigbe pẹlu ero, tabi mọ ọna ninu ise ipinilẹ. Pele kan Adura Qur'anu ati ibeere meji ti o ba le ṣiyan.",

  "promptFamilyRelationships": "Kọ itọsọna Iman ti o lagbara nipa ebi ati onisokan ti o ju ipilẹ ninu Qur'anu ati apẹrẹ Nabii Muhammad. Yi ite kọọkan: alaanutara ni ile, suburu nipa ariyanjiyan, ọya awọn baba, mẹkọrun awọn ọmọ ninu Iman, tabi mu iyalẹ dun. Pele kan Adura Qur'anu ati ise onisokan ti o ba le ṣe.",

  "promptPeaceAnxietyRelief": "Kọ iponju Iman ti o dara para ni alafiaara inu nipa iṣẹ adura Allah (Dhikr) ati igbẹkẹle ninu ọna Allah. Gba ninu ẹkọ Qur'anu nipa aalafia ọkàn, adura, ati yinyinje si ero Allah. Yi ọna kọọkan ati pele kan Adura Qur'anu ati ise aalafia ninu ẹkọ Iman.",

  "promptWisdomOfJesus": "Kọ ala ogbon lati ọwọ Nabii bi a ti kọ ninu Iman. Gba ninu Qur'anu tabi Hadisi ati ṣalaye iṣeganladuni awọn onimọ Iman. Yi ko nje: ewa, suburu, ibajanipa, Iman, tabi ṣiṣe ojo-ojo. Pele kan Qur'anu tabi Hadisi ati lo kan.",

  "promptHumilityCharacter": "Kọ iponju Iman nipa ibajanipa (Tawadhu) ati ewa eniyan (Akhlaq). Gba ninu ẹkọ Qur'anu, apẹrẹ Nabii Muhammad, ati ẹkọ isọdipọ ewa eniyan ninu Iman. Yi ite: ibajanipa nipa ilana, ya aṣiṣe, tẹ awọn miiran pẹlu ọrọ-ọrọ, tabi iyika nipa iponju. Pele kan Adura Qur'anu ati ise ti o ba le ṣe.",

  "promptOvercomingTemptation": "Kọ iponju Iman nipa kọ itẹ ati duro ninu ọna ti o dara. Gba ninu iṣagbonisọna Qur'anu, iṣẹ adura Allah (Dhikr), adura (Salah), ati apẹrẹ awọn olumọ ti o ja ẹlẹru. Yi itu kọọkan. Pele kan Adura Qur'anu ati ise aladilika fun ọdun-ọdu.",

  "promptEveningReflection": "Kọ iponju Iman ti o dara fun alẹ ti o ju ipilẹ ninu ẹkọ iṣẹ adura alẹ (Adhkar al-Masaa'). Ṣokan dupe, iponju ara (Muhasabah), ati igbẹkẹle si Allah idaduro. Pele kan ibeere iponju mẹta tabi marun nipa ojo, adura oloro, ati Adura Qur'anu kan.",

