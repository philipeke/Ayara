  "dailyGraceTitle": "Itọsọna Ojo-ojo",
  "dailyGraceScriptureLabel": "ADURA ỌJỌ",
  "dailyGraceSaintLabel": "OLIMỌ ỌSẸ",
  "dailyGraceReflectionLabel": "IPONJU ALẸ",
  "dailyGraceCopiedToast": "Adura daakọ si ọkọ iṣiro",

  "dailyScripture0Text": "Lẹẹkan, awọn ti o daba wa ni awọn ibadandun ati awọn odo, ni apẹjọ ti ara ẹni laṭu ọba agbara.",
  "dailyScripture0Ref": "Qur'anu 54:54-55",
  "dailyScripture1Text": "Ati a ko ti ṣe iranlọwọ rẹ (Muhammad) ilẹ po ju bi iyanu si gbogbo aye.",
  "dailyScripture1Ref": "Qur'anu 21:107",
  "dailyScripture2Text": "Sẹ Allah ko tobi fun ara ẹni rẹ? Sibẹsibẹ wọn ba rẹ nipa awọn miiran lọwọ rẹ.",
  "dailyScripture2Ref": "Qur'anu 39:36",
  "dailyScripture3Text": "Bawo ni o ṣe fi agbara ijiyan ohun kan ti o jẹ bẹ fun rẹ; ati bawo ni o ṣe ni ifẹ ohun kan ti o jẹ bukun fun rẹ. Ati Allah mọ, ati ẹ ko mọ.",
  "dailyScripture3Ref": "Qur'anu 2:216",
  "dailyScripture4Text": "Lẹẹkan, Allah wa pẹlu awọn ti o suburu.",
  "dailyScripture4Ref": "Qur'anu 2:153",
  "dailyScripture5Text": "Nitorinaa ranti mi; emi naa yoo ranti yyin. Ati dupẹ mi ati o ma ṣe layọ.",
  "dailyScripture5Ref": "Qur'anu 2:152",
  "dailyScripture6Text": "Lẹẹkan, ti nla ju ti yyin ni ọwọ Allah ni ti o tọ ju ninu guningun.",
  "dailyScripture6Ref": "Qur'anu 49:13",
  "dailyScripture7Text": "Ati olurọ rẹ ti ṣe ẹkọ pe o orisa ẹka rẹ, ati pe e ṣe ọpẹ si awọn baba yyin.",
  "dailyScripture7Ref": "Qur'anu 17:23",
  "dailyScripture8Text": "Lẹẹkan, pẹlu ikole ọsẹ ti wa loore.",
  "dailyScripture8Ref": "Qur'anu 94:6",
  "dailyScripture9Text": "Ati o wa pẹlu yyin nibikibii ti yyin ba wa. Ati Allah ti ohun ti yyin ṣe jẹ olukani.",
  "dailyScripture9Ref": "Qur'anu 57:4",
  "dailyScripture10Text": "Allah ko fi iṣẹ lẹ ẹru ti o ju ohun ti o le gbẹ.",
  "dailyScripture10Ref": "Qur'anu 2:286",
  "dailyScripture11Text": "Ati sinaan ti o gbẹkẹle Allah — yii yalọ fun u.",
  "dailyScripture11Ref": "Qur'anu 65:3",
  "dailyScripture12Text": "Iyanu mi yo gbogbo nkan.",
  "dailyScripture12Ref": "Qur'anu 7:156",
  "dailyScripture13Text": "Ati nigba ti awọn iṣọ mi beere rẹ nipa mi — lẹẹkan, emi ni isunmọ. Emi gбa onibẹru nigba ti o pe mi.",
  "dailyScripture13Ref": "Qur'anu 2:186",
  "dailyScripture14Text": "Sinaan ti o ṣe ewa, boya obinrin tabi akọ, ni igbagbọ — a yoo yanlẹ kaa fun gbigbe aiye to dara.",
  "dailyScripture14Ref": "Qur'anu 16:97",
  "dailyScripture15Text": "Lẹẹkan, Allah ko yipada ẹdun ti awọn eniyan, akọtọ ti wọn yipada ohun ti o wa ninu awọn ara wọn.",
  "dailyScripture15Ref": "Qur'anu 13:11",
  "dailyScripture16Text": "Nitorinaa o ma ṣe dinku, o ma ṣe inurẹ, ati ẹ yoo ti niyiye ti ẹ ba jẹ olumọ ọtọtọ.",
  "dailyScripture16Ref": "Qur'anu 3:139",
  "dailyScripture17Text": "O awọ iṣọ mi ti o ti ṣe aṣiṣe fun wọn-ara wọn, o ma ṣe aironu nipa iyanu Allah. Lẹẹkan, Allah yoo fi ẹtọ gbogbo.",
  "dailyScripture17Ref": "Qur'anu 39:53",
  "dailyScripture18Text": "Ati sinaan ti o ba korira Allah — yii yalọ ọna fun u, ati yoo pese fun u nibo ti o ko ro.",
  "dailyScripture18Ref": "Qur'anu 65:2-3",
  "dailyScripture19Text": "O ma ṣe aironu nipa iyanu Allah.",
  "dailyScripture19Ref": "Qur'anu 12:87",
  "dailyScripture20Text": "Ati a ti jẹ ki Qur'anu rọrun lati ranti. Nitorinaa se akọ to ba ti gbe oju inu?",
  "dailyScripture20Ref": "Qur'anu 54:17",
  "dailyScripture21Text": "Ati o ri ẹ lọju, ati o ti gbaṣe yi.",
  "dailyScripture21Ref": "Qur'anu 93:7",
  "dailyScripture22Text": "Ati olurọ rẹ sọ: Pe mi; emi yoo gba iṣeji rẹ.",
  "dailyScripture22Ref": "Qur'anu 40:60",
  "dailyScripture23Text": "Ati a ti jẹ ki awọn ọmọ Adam, a gba ọlà.",
  "dailyScripture23Ref": "Qur'anu 17:70",
  "dailyScripture24Text": "Ati wa fun iranlọwọ nipẹ suburu ati adura.",
  "dailyScripture24Ref": "Qur'anu 2:45",
  "dailyScripture25Text": "Sinaan ti o ba ṣe iṣẹ ti iwọ oniwa si wi ọna.",
  "dailyScripture25Ref": "Qur'anu 99:7",
  "dailyScripture26Text": "Aribi ti iranlọwọ Allah wa ni isunmọ.",
  "dailyScripture26Ref": "Qur'anu 2:214",
  "dailyScripture27Text": "Ati sinaan ti o ba dupe — dupe rẹ nilo fun onire ara rẹ.",
  "dailyScripture27Ref": "Qur'anu 31:12",

  "dailyReflection0": "Bi ojo yii ba n pari, ka akoko kan nibo ti iyanu Allah ji han.",
  "dailyReflection1": "Mu gbogbo ohun ti o na ọkan rẹ loni si ọdọ Allah.",
  "dailyReflection2": "Yan bẹẹ ẹbun nikan loni ati dupẹ Allah.",
  "dailyReflection3": "Subọ ninu imọ pe o wa ninu iyanu Allah.",
  "dailyReflection4": "Ṣiyan nibo ti o ti ṣe iferan ati alaanutara loni.",
  "dailyReflection5": "Yi awe ohun ti o kọ le ṣe ati gbẹkẹle ọna Allah.",
  "dailyReflection6": "Bi alẹ ba n de, gba aalafia nipa iṣẹ adura Allah.",
  "dailyReflection7": "Ṣiyan bawo ni o ti bọwọ adura rẹ loni.",
  "dailyReflection8": "Ṣiyan nibo ti suburu (Sabr) ti faya iṣẹ rẹ loni.",
  "dailyReflection9": "Beere ẹtọ fun ohun ti o ṣe kiko loni — iyanu Allah ko ni opin.",
  "dailyReflection10": "Yan ẹnikan ti o ṣe alaanutara si loni, ati pe adura fun won.",
  "dailyReflection11": "Jọka pẹlu dupe — kilo ni Allah ti fun rẹ loni ti o ko beere?",
  "dailyReflection12": "Ṣiyan nipa adura Qur'anu kan ti o ba sọ ohun ti o wa ni.",
  "dailyReflection13": "Ṣiyan bawo ni o ti lo akoko rẹ loni — ati fikan si Allah fun ola.",
  "dailyReflection14": "Subọ ninu imọ pe idipọn nkan ti o ba de, Allah pẹ rẹ.",
  "dailyReflection15": "Ṣiyan nipa ọna kan ti o ṣe ire si ebi tabi agbegbe fun Allah.",
  "dailyReflection16": "Bi alẹ ba n de, ṣe ipadabọ — Allah nifẹ awọn ti o ba padabọ.",
  "dailyReflection17": "Ṣiyan nipa ewa ti Allah fi ni ojo rẹ, paapaa ni kekere.",
  "dailyReflection18": "Ṣiyan nipa ohun ti o ko ẹkọ loni ati bawo ni o ba sojumu si Allah.",
  "dailyReflection19": "Yi awọn aniyan ojo rẹ si Allah — o lo ohun ti o kọ le lo.",
  "dailyReflection20": "Ṣiyan nipa akoko ti o ṣe ọna ti o daru, ati ko ẹkọ rẹ.",
  "dailyReflection21": "Pe adura fun awọn ti o n ja adura — ona yii jẹ ẹbun ti o fun wọn.",
  "dailyReflection22": "Ranti ẹbun kan ti o ko ji ọkan rẹ ati dupe Allah.",
  "dailyReflection23": "Ṣiyan nipa ero rẹ loni — sẹ wọn jẹ fun Allah? Jẹkọ lọla.",
  "dailyReflection24": "Bi alẹ ba n pipo, gba jẹ isunmọ Allah ninu orotuú.",
  "dailyReflection25": "Ṣiyan nibo ti o ri agbara loni — agbara yii ti wa ninu Allah.",
  "dailyReflection26": "Yan ohun kan ti o yoo ṣe ola, fun Allah, ti o ko ṣe igbere.",
  "dailyReflection27": "Bi o ba lo lati sinmi, fi ara rẹ si Allah — o jẹ olubere ti o ta ju.",

