  "dailyGraceTitle": "Mwongozo wa Kila Siku",
  "dailyGraceScriptureLabel": "AYAT YA SIKU",
  "dailyGraceSaintLabel": "MWANALIMU WA WIKI",
  "dailyGraceReflectionLabel": "TAFAKARI YA JIONI",
  "dailyGraceCopiedToast": "Ayat kinakiliwa kwenye ubao",

  "dailyScripture0Text": "Hakika wenye haki watakuwa katika bustani na mito, katika kiti cha heshima karibu na Mfalme Qadiri.",
  "dailyScripture0Ref": "Quraan 54:54-55",
  "dailyScripture1Text": "Na hatukutuma wewe ila kama rehema kwa ulimwengu.",
  "dailyScripture1Ref": "Quraan 21:107",
  "dailyScripture2Text": "Yalipi Allah haitoshi kwa mtumishi wake? Lakini wanakukaka kwa wengine bila naye.",
  "dailyScripture2Ref": "Quraan 39:36",
  "dailyScripture3Text": "Labda unachukia kitu na kilo nzuri kwako; na labda unayapenda kitu na kilo mbaya kwako. Na Allah anajua, na wewe hujui.",
  "dailyScripture3Ref": "Quraan 2:216",
  "dailyScripture4Text": "Hakika Allah ana wasubira.",
  "dailyScripture4Ref": "Quraan 2:153",
  "dailyScripture5Text": "Kwa hiyo nikumbuke mimi; nikumbuke ninyi. Na shukrani kwangu, wala msikane.",
  "dailyScripture5Ref": "Quraan 2:152",
  "dailyScripture6Text": "Hakika wenye heshima zaidi kwa Allah ndio wenye takwa zaidi kwenu.",
  "dailyScripture6Ref": "Quraan 49:13",
  "dailyScripture7Text": "Na Rabb yako amefanya amri kwamba msijadini ila yeye tu, na kwamba mtambue wazazi.",
  "dailyScripture7Ref": "Quraan 17:23",
  "dailyScripture8Text": "Hakika na kupigania kumo rahisi.",
  "dailyScripture8Ref": "Quraan 94:6",
  "dailyScripture9Text": "Na yeye ana ninyi popote munavyokuwa. Na Allah, waliochukua, anauona.",
  "dailyScripture9Ref": "Quraan 57:4",
  "dailyScripture10Text": "Allah haimtakaki nafsi ila kile inachoweza.",
  "dailyScripture10Ref": "Quraan 2:286",
  "dailyScripture11Text": "Na yeyote anayetegemea Allah — basi yeye anamsumbua.",
  "dailyScripture11Ref": "Quraan 65:3",
  "dailyScripture12Text": "Rehema yangu inatanisha mambo yote.",
  "dailyScripture12Ref": "Quraan 7:156",
  "dailyScripture13Text": "Na mtumishi wangu wakikuuliza kuhusu mimi — hakika mimi ni karibu. Najibu malombo ya mungu yeye akaniita.",
  "dailyScripture13Ref": "Quraan 2:186",
  "dailyScripture14Text": "Yeyote anatenda sawa, iyoakwe mwanamume au mwanamke, na mwamini — hakika tutamfanya kuishi maisha mazuri.",
  "dailyScripture14Ref": "Quraan 16:97",
  "dailyScripture15Text": "Hakika Allah hatakabadili hali ya watu hata waitabadili wenyewe waliomo ndani yao.",
  "dailyScripture15Ref": "Quraan 13:11",
  "dailyScripture16Text": "Kwa hiyo wala msiwe na wazimu, na msisikitike, na mtakuwa mkuu kama mmuamini wenye imani.",
  "dailyScripture16Ref": "Quraan 3:139",
  "dailyScripture17Text": "Ay mtumishi wangu waliotenda madhalimu juu ya nafsi zao, msichafuke kutoka rehema ya Allah. Hakika Allah anasamehe dhanbi zote.",
  "dailyScripture17Ref": "Quraan 39:53",
  "dailyScripture18Text": "Na yeyote anayekataa Allah — atamfanya njia ya kutoka, na atamtaji kutoka mahali hajatarajia.",
  "dailyScripture18Ref": "Quraan 65:2-3",
  "dailyScripture19Text": "Wala msiwe na matamaini katika rehema ya Allah.",
  "dailyScripture19Ref": "Quraan 12:87",
  "dailyScripture20Text": "Na hakika tumerahisisha Quraan kwa kumkumbuka. Kwa hiyo je, kuna mtu atakayekumbuka?",
  "dailyScripture20Ref": "Quraan 54:17",
  "dailyScripture21Text": "Na akakupata wewe bila mwongozo, akakuongoza.",
  "dailyScripture21Ref": "Quraan 93:7",
  "dailyScripture22Text": "Na Rabb yako akasema: Nitaliza mimi; nitajikubali ninyi.",
  "dailyScripture22Ref": "Quraan 40:60",
  "dailyScripture23Text": "Na hakika tumekamatia watoto wa Adamu.",
  "dailyScripture23Ref": "Quraan 17:70",
  "dailyScripture24Text": "Na tafuta msaada kwa njia ya subira na sala.",
  "dailyScripture24Ref": "Quraan 2:45",
  "dailyScripture25Text": "Yeyote anatenda uzani wa atomi ya wema atakayaona.",
  "dailyScripture25Ref": "Quraan 99:7",
  "dailyScripture26Text": "Bila swali, msaada wa Allah una karibu.",
  "dailyScripture26Ref": "Quraan 2:214",
  "dailyScripture27Text": "Na yeyote anaye shukri — shukri yake ni tu kwa faida ya binafsi yake.",
  "dailyScripture27Ref": "Quraan 31:12",

  "dailyReflection0": "Wakati siku hii inapoishia, fikiria dakika moja ambapo rehema ya Allah ilionekana.",
  "dailyReflection1": "Leta kwa Allah yote iliyokusumbua moyo wako leo.",
  "dailyReflection2": "Jina baraka moja kutoka siku hii na shukria Allah.",
  "dailyReflection3": "Pumzika katika ujuzi kwamba unafanywa katika kuzindua isimu wa Allah.",
  "dailyReflection4": "Fikiria mahali alipokupa kuitwa kuonyesha huruma na wema leo.",
  "dailyReflection5": "Wacha yalicho hayuwezi kuzalisha na tawakali katika mpango kamili wa Allah.",
  "dailyReflection6": "Saa siku inapokaribia kumalizia, pokea amani katika ukumbusho wa Allah.",
  "dailyReflection7": "Fikiria jinsi ulivoheshimu sala zako leo, na shukria Allah kwa kila moja.",
  "dailyReflection8": "Fikiria dakika iliyokuongeza subira leo kwa njia yako.",
  "dailyReflection9": "Omba msamaha kwa kila upungufu leo — rehema ya Allah haina kikomo.",
  "dailyReflection10": "Jina mtu mmoja ukamuonyesha wema leo na fanya dua kwa ajili yake.",
  "dailyReflection11": "Kusimama na shukrani: Allah alitoa nini leo ambalo haukuomba?",
  "dailyReflection12": "Fikiria ayat kutoka kwa Quraan inayozungumza mahali unapokuwa.",
  "dailyReflection13": "Fikiria jinsi ulivotumia muda wako leo — na kutoa kesho kwa Allah.",
  "dailyReflection14": "Pumzika kwa ujuzi kwamba hadharani mahali kupigania leo, Allah alikuwa nawe.",
  "dailyReflection15": "Fikiria njia moja ulivosaidii familia au jamii yako leo kwa ajili ya Allah.",
  "dailyReflection16": "Saa giza likakuja, fanya Tawbah — Allah anapenda walio shugulikataka kwenye yeye.",
  "dailyReflection17": "Fikiria uzuri Allah alioacha katika siku yako, kama ilivyokuwa ndogo.",
  "dailyReflection18": "Fikiria unachojifunza leo na jinsi inavyokukaribia zaidi kwa Allah.",
  "dailyReflection19": "Wacha burudani za siku iweze na Allah — yeye hubeba unacho hawezi.",
  "dailyReflection20": "Fikiria wakati leo ulipotaka kuchagua nzuri, na jifunze kutoka kwa upole.",
  "dailyReflection21": "Fanya dua kwa wenye janga — dua yako ni zawadi kwa ajili yao.",
  "dailyReflection22": "Kumbuka baraka unayozipuuza mara kwa mara na chukua wakati ili shukria Allah.",
  "dailyReflection23": "Fikiria maka yako leo — ilikuwa kwa Allah? Kesho, anza tena.",
  "dailyReflection24": "Saa giza linalonyamaza, sikiliza karibu kwa Allah katika kunyamaa.",
  "dailyReflection25": "Fikiria mahali ulipokuta nguvu leo — hiyo nguvu inatoka Allah.",
  "dailyReflection26": "Jina kitu moja kutafanya kesho, kwa ajili ya Allah, ambalo haujafanya leo.",
  "dailyReflection27": "Saa unajiandaa kupumzika, tia roho yako na Allah — yeye ni mlinzi bora.",

