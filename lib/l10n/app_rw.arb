  "dailyGraceReflectionLabel": "IMUNIRANE Y'IJORO",
  "dailyGraceCopiedToast": "Icyitonderezwa kopiyemo ku kiganiro",

  "dailyScripture0Text": "Umuntu w'Imana arashobora kubanikeza mu Isivu n'Amajyaruguru, mu Kifo cy'Ubwiyunge hafi y'Imana Nyamahoro.",
  "dailyScripture0Ref": "Qur'an 54:54-55",
  "dailyScripture1Text": "N'Ntabwo twakumenya ngo kworeka gusa Imana nzira y'Ubwiyunge kwa Isi yose.",
  "dailyScripture1Ref": "Qur'an 21:107",
  "dailyScripture2Text": "Imana ntiyari Igihugu cy'Ubwiyunge? Ariko Imana cyose iguhiro cyangwa Andi.",
  "dailyScripture2Ref": "Qur'an 39:36",
  "dailyScripture3Text": "Mahoro ari yo ubwiyunge: Icyo cyawe no Imana Ica. Imana yibimerire, ariko wowe ntiyimerire.",
  "dailyScripture3Ref": "Qur'an 2:216",
  "dailyScripture4Text": "Imana arimo Abantu ba Sabr.",
  "dailyScripture4Ref": "Qur'an 2:153",
  "dailyScripture5Text": "Noneho kukunganira Imana, Nanjye Nzakukunganira. N'Kwishingira, n'Kutajijisa.",
  "dailyScripture5Ref": "Qur'an 2:152",
  "dailyScripture6Text": "Imana Nyamahoro, Umuntu Wizewe kuri Imana ni ubwiyunge bwawe.",
  "dailyScripture6Ref": "Qur'an 49:13",
  "dailyScripture7Text": "N'Imana yacu iraba ibarikisha kuvuga itamari Ariki, n'Kwishingira Ababyeyi.",
  "dailyScripture7Ref": "Qur'an 17:23",
  "dailyScripture8Text": "Kwiyokubwira, ibuguzi rihitanira amahoro.",
  "dailyScripture8Ref": "Qur'an 94:6",
  "dailyScripture9Text": "N'Ari Wanyu Aho Mwahari. N'Imana Nyamahoro yabonye Icyo gikora cyacu.",
  "dailyScripture9Ref": "Qur'an 57:4",
  "dailyScripture10Text": "Imana ntagufika Umuntu imishinga y'ubuyago bwacu.",
  "dailyScripture10Ref": "Qur'an 2:286",
  "dailyScripture11Text": "N'Ujijizira Imana, Imana ni Igihugu cyawe.",
  "dailyScripture11Ref": "Qur'an 65:3",
  "dailyScripture12Text": "Ihanga ryacu ryatanze Icyo cyose.",
  "dailyScripture12Ref": "Qur'an 7:156",
  "dailyScripture13Text": "N'Iyo Abajijija bawe babanzirikiza Imana — Nanjye Nari hafi. Nsubira Uw'ubwiyunge iyo ayama.",
  "dailyScripture13Ref": "Qur'an 2:186",
  "dailyScripture14Text": "Ujijiza Ubwiyunge, mubyoba cyangwa mubyikazi, mu Imana — Twazamushoboza Ubuzima Bwacu.",
  "dailyScripture14Ref": "Qur'an 16:97",
  "dailyScripture15Text": "Imana ntiyahindura Ubunaruko bw'Abantu kugira ngo Bahindure Icyo cya Mu Bwitso bwabo.",
  "dailyScripture15Ref": "Qur'an 13:11",
  "dailyScripture16Text": "Nkuko Ntugire nta Mahoro, n'Ntuhira, ariko Muzakweza niba Muri Abantu ba Imana.",
  "dailyScripture16Ref": "Qur'an 3:139",
  "dailyScripture17Text": "O Abajijija bacu baakoreye Ubwiyunge, Ntumahoro mu Ihanga ry'Imana. Imana ireba icyo Cyose.",
  "dailyScripture17Ref": "Qur'an 39:53",
  "dailyScripture18Text": "N'Ujijizira Imana — Imana azamushoboza Inzira, n'Azamukira Aho atamanya.",
  "dailyScripture18Ref": "Qur'an 65:2-3",
  "dailyScripture19Text": "N'Nta gwiyokubwira mu Ihanga ry'Imana.",
  "dailyScripture19Ref": "Qur'an 12:87",
  "dailyScripture20Text": "N'Twateje Qur'an ngo ibwire. Noneho Ni Nde ujijizira?",
  "dailyScripture20Ref": "Qur'an 54:17",
  "dailyScripture21Text": "N'Yataguhakana akakya, akakwita.",
  "dailyScripture21Ref": "Qur'an 93:7",
  "dailyScripture22Text": "N'Imana yacu iraba Yama kwa Nanjye, Nzasubira.",
  "dailyScripture22Ref": "Qur'an 40:60",
  "dailyScripture23Text": "N'Twahakana Abaana ba Adamu.",
  "dailyScripture23Ref": "Qur'an 17:70",
  "dailyScripture24Text": "N'Gushaka Imbaraga mu Sabr n'Inamahoro.",
  "dailyScripture24Ref": "Qur'an 2:45",
  "dailyScripture25Text": "Ujijiza Ubwiyunge Bwa Atomi, Azabona.",
  "dailyScripture25Ref": "Qur'an 99:7",
  "dailyScripture26Text": "Imana Igihugu cy'Ubwiyunge nari Hafi.",
  "dailyScripture26Ref": "Qur'an 2:214",
  "dailyScripture27Text": "N'Ujijizira — Ubwiyunge bwawe ni Ubwiyunge bwawe.",
  "dailyScripture27Ref": "Qur'an 31:12",

  "dailyReflection0": "Iyo Ijoro rihiza, Sobanura Umunsi Umwe aho Ihanga ry'Imana ryagezeyo.",
  "dailyReflection1": "Letani kwa Imana Icyo cyawe cy'Umutima mu Munsi.",
  "dailyReflection2": "Kurira Imihango Imwe y'Olo, n'Kwishingira kwa Imana.",
  "dailyReflection3": "Kuryama mu Biziranye bw'Imana Nyamahoro.",
  "dailyReflection4": "Sobanura Aho wabimerire Kwiyokubwira n'Ubuntu.",
  "dailyReflection5": "Kwegereza Icyo Utashobora Gusimba n'Kwishingira Imana.",
  "dailyReflection6": "Iyo Ijoro rihiza, Pata Amahoro mu Kukunganira Imana.",
  "dailyReflection7": "Sobanura Nk'ihe wabarikisha Inamahoro zawe Olo.",
  "dailyReflection8": "Sobanura Umunsi Umwe aho Sabr yabarikisha.",
  "dailyReflection9": "Gusaba Imbabazi mu Mahoro y'Olo — Ihanga ry'Imana ntiyaripfa.",
  "dailyReflection10": "Kirira Umuntu Umwe wabarikisha Olo, n'Gusaba kwa Imana.",
  "dailyReflection11": "Sobanura: Ni Ikintu ki Imana yatanze Olo Ntagusaza?",
  "dailyReflection12": "Sobanura Icyitonderezwa cy'Imana Giriko Aho Wari.",
  "dailyReflection13": "Sobanura Nk'ihe Wakoresha Umunsi n'Fata Olo kwa Imana.",
  "dailyReflection14": "Ryama Twazamanya Icyo gikora cy'Olo, Imana Yari Wanye.",
  "dailyReflection15": "Sobanura Nk'ihe Wabarira Imbere cyangwa Abantu Olo.",
  "dailyReflection16": "Iyo Ijoro rihiza, Gusaba Tawbah — Imana ireba Abantu ba Tawbah.",
  "dailyReflection17": "Sobanura Ubuntu bwa Olo bwa Imana.",
  "dailyReflection18": "Sobanura Icyo wabuboneye Olo n'Nk'ihe byakukwiza Imana.",
  "dailyReflection19": "Deka Mahoro y'Olo kwa Imana — Imana igikurura Icyo Utashobora.",
  "dailyReflection20": "Sobanura Umwanya Umwe Olo Ushobora Kubwina, n'Jifata Mahoro.",
  "dailyReflection21": "Gusaba kwa Imana Abantu ba Mahoro — Idomicilo ryacu ni Ihango.",
  "dailyReflection22": "Kurira Ihango Rimwe Ryamahoro y'Olo Rshakura, n'Kwishingira Imana.",
  "dailyReflection23": "Sobanura Intego zawe z'Olo — Zarimo kwa Imana? Olo gusubira.",
  "dailyReflection24": "Iyo Ijoro rihiza, Shukiza Ubwiyunge bw'Imana mu Mahoro.",
  "dailyReflection25": "Sobanura Aho wahamagara Imbaraga Olo — Imana ni Imbaraga.",
  "dailyReflection26": "Kirira Ikintu Cyawe Cyo Gutukura Olo Gitakorwa Ibisonga.",
  "dailyReflection27": "Iyo Guriguhawira, Deka Umutima wawe kwa Imana — Imana ni Umwirinda.",

