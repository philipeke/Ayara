  "dailyScripture0Text": "إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَنَهَرٍ فِي مَقْعَدِ صِدْقٍ عِندَ مَلِيكٍ مُّقْتَدِرٍ.",
  "dailyScripture0Ref": "القرآن الكريم 54:54-55",
  "dailyScripture1Text": "وَمَا أَرْسَلْنَاكَ إِلَّا رَحْمَةً لِّلْعَالَمِينَ.",
  "dailyScripture1Ref": "القرآن الكريم 21:107",
  "dailyScripture2Text": "أَلَيْسَ اللَّهُ بِكَافٍ عَبْدَهُ وَيُخَوِّفُونَكَ بِالَّذِينَ مِن دُونِهِ.",
  "dailyScripture2Ref": "القرآن الكريم 39:36",
  "dailyScripture3Text": "وَعَسَىٰ أَن تَكْرَهُوا شَيْئًا وَهُوَ خَيْرٌ لَّكُمْ وَعَسَىٰ أَن تُحِبُّوا شَيْئًا وَهُوَ شَرٌّ لَّكُمْ وَاللَّهُ يَعْلَمُ وَأَنتُمْ لَا تَعْلَمُونَ.",
  "dailyScripture3Ref": "القرآن الكريم 2:216",
  "dailyScripture4Text": "إِنَّ اللَّهَ مَعَ الصَّابِرِينَ.",
  "dailyScripture4Ref": "القرآن الكريم 2:153",
  "dailyScripture5Text": "فَاذْكُرُونِي أَذْكُرْكُمْ وَاشْكُرُوا لِي وَلَا تَكْفُرُونِ.",
  "dailyScripture5Ref": "القرآن الكريم 2:152",
  "dailyScripture6Text": "إِنَّ أَكْرَمَكُمْ عِندَ اللَّهِ أَتْقَاكُمْ.",
  "dailyScripture6Ref": "القرآن الكريم 49:13",
  "dailyScripture7Text": "وَقَضَىٰ رَبُّكَ أَلَّا تَعْبُدُوا إِلَّا إِيَّاهُ وَبِالْوَالِدَيْنِ إِحْسَانًا.",
  "dailyScripture7Ref": "القرآن الكريم 17:23",
  "dailyScripture8Text": "إِنَّ مَعَ الْعُسْرِ يُسْرًا.",
  "dailyScripture8Ref": "القرآن الكريم 94:6",
  "dailyScripture9Text": "وَهُوَ مَعَكُمْ أَيْنَ مَا كُنتُمْ وَاللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ.",
  "dailyScripture9Ref": "القرآن الكريم 57:4",
  "dailyScripture10Text": "لَا يُكَلِّفُ اللَّهُ نَفْسًا إِلَّا وُسْعَهَا.",
  "dailyScripture10Ref": "القرآن الكريم 2:286",
  "dailyScripture11Text": "وَمَن يَتَوَكَّلْ عَلَى اللَّهِ فَهُوَ حَسْبُهُ.",
  "dailyScripture11Ref": "القرآن الكريم 65:3",
  "dailyScripture12Text": "وَرَحْمَتِي وَسِعَتْ كُلَّ شَيْءٍ.",
  "dailyScripture12Ref": "القرآن الكريم 7:156",
  "dailyScripture13Text": "وَإِذَا سَأَلَكَ عِبَادِي عَنِّي فَإِنِّي قَرِيبٌ أُجِيبُ دَعْوَةَ الدَّاعِ إِذَا دَعَانِ.",
  "dailyScripture13Ref": "القرآن الكريم 2:186",
  "dailyScripture14Text": "مَنْ عَمِلَ صَالِحًا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌ فَلَنُحْيِيَنَّهُ حَيَاةً طَيِّبَةً.",
  "dailyScripture14Ref": "القرآن الكريم 16:97",
  "dailyScripture15Text": "إِنَّ اللَّهَ لَا يُغَيِّرُ مَا بِقَوْمٍ حَتَّىٰ يُغَيِّرُوا مَا بِأَنفُسِهِمْ.",
  "dailyScripture15Ref": "القرآن الكريم 13:11",
  "dailyScripture16Text": "وَلَا تَهِنُوا وَلَا تَحْزَنُوا وَأَنتُمُ الْأَعْلَوْنَ إِن كُنتُم مُّؤْمِنِينَ.",
  "dailyScripture16Ref": "القرآن الكريم 3:139",
  "dailyScripture17Text": "يَا عِبَادِيَ الَّذِينَ أَسْرَفُوا عَلَىٰ أَنفُسِهِمْ لَا تَقْنَطُوا مِن رَّحْمَةِ اللَّهِ إِنَّ اللَّهَ يَغْفِرُ الذُّنُوبَ جَمِيعًا.",
  "dailyScripture17Ref": "القرآن الكريم 39:53",
  "dailyScripture18Text": "وَمَن يَتَّقِ اللَّهَ يَجْعَل لَّهُ مَخْرَجًا وَيَرْزُقْهُ مِنْ حَيْثُ لَا يَحْتَسِبُ.",
  "dailyScripture18Ref": "القرآن الكريم 65:2-3",
  "dailyScripture19Text": "لَا تَيْأَسُوا مِن رَّوْحِ اللَّهِ.",
  "dailyScripture19Ref": "القرآن الكريم 12:87",
  "dailyScripture20Text": "وَلَقَدْ يَسَّرْنَا الْقُرْآنَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍ.",
  "dailyScripture20Ref": "القرآن الكريم 54:17",
  "dailyScripture21Text": "وَوَجَدَكَ ضَالًّا فَهَدَىٰ.",
  "dailyScripture21Ref": "القرآن الكريم 93:7",
  "dailyScripture22Text": "وَقَالَ رَبُّكُمُ ادْعُونِي أَسْتَجِبْ لَكُمْ.",
  "dailyScripture22Ref": "القرآن الكريم 40:60",
  "dailyScripture23Text": "وَلَقَدْ كَرَّمْنَا بَنِي آدَمَ.",
  "dailyScripture23Ref": "القرآن الكريم 17:70",
  "dailyScripture24Text": "وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ.",
  "dailyScripture24Ref": "القرآن الكريم 2:45",
  "dailyScripture25Text": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُ.",
  "dailyScripture25Ref": "القرآن الكريم 99:7",
  "dailyScripture26Text": "أَلَا إِنَّ نَصْرَ اللَّهِ قَرِيبٌ.",
  "dailyScripture26Ref": "القرآن الكريم 2:214",
  "dailyScripture27Text": "وَمَن يَشْكُرْ فَإِنَّمَا يَشْكُرُ لِنَفْسِهِ.",
  "dailyScripture27Ref": "القرآن الكريم 31:12",

  "dailyReflection0": "وأنت تودّع هذا اليوم، تأمّل في لحظة واحدة كانت رحمة الله فيها جليّة.",
  "dailyReflection1": "اعرض على الله ما أثقل قلبك اليوم.",
  "dailyReflection2": "سمِّ نعمة واحدة من نعم هذا اليوم واحمد الله عليها.",
  "dailyReflection3": "استقرّ في اطمئنان أنك في رعاية الله اللانهائية.",
  "dailyReflection4": "تأمّل في المواقف التي شعرت فيها بدعوة الرحمة والعطف اليوم.",
  "dailyReflection5": "أسلم ما لا تملكه وتوكّل على تدبير الله الحكيم.",
  "dailyReflection6": "مع اختتام اليوم، استقبل السكينة بذكر الله.",
  "dailyReflection7": "تأمّل في كيفية أدائك للصلوات اليوم، واشكر الله على كل صلاة.",
  "dailyReflection8": "تأمّل في لحظة وجّه فيها الصبر تصرفاتك اليوم.",
  "dailyReflection9": "استغفر الله عن أي تقصير اليوم — رحمته لا حدود لها.",
  "dailyReflection10": "تذكّر شخصاً أسديت إليه معروفاً اليوم وادعُ له بالخير.",
  "dailyReflection11": "اجلس مع الشكر: ماذا رزقك الله اليوم دون أن تطلب؟",
  "dailyReflection12": "تأمّل في آية قرآنية تُعبّر عمّا تمرّ به الآن.",
  "dailyReflection13": "فكّر في كيفية استثمارك لوقتك اليوم — وأهدِ غدك لله.",
  "dailyReflection14": "استرح وأنت تعلم أن الله كان معك في كل شدة مرّت اليوم.",
  "dailyReflection15": "فكّر في طريقة واحدة خدمت بها أسرتك أو مجتمعك اليوم لوجه الله.",
  "dailyReflection16": "مع حلول الليل، تُب إلى الله — فالله يحب التوّابين.",
  "dailyReflection17": "تأمّل في جمال ما وضعه الله في يومك، مهما بدا صغيراً.",
  "dailyReflection18": "فكّر فيما تعلّمته اليوم وكيف يقرّبك من الله.",
  "dailyReflection19": "أودِع هموم يومك عند الله — فهو يحمل ما لا تستطيع حمله.",
  "dailyReflection20": "فكّر في لحظة كان بإمكانك فيها أن تتصرف بشكل أفضل، وتعلّم منها برفق.",
  "dailyReflection21": "ادعُ لمن يعانون — دعاؤك هدية لهم.",
  "dailyReflection22": "تذكّر نعمة كثيراً ما تغفل عنها وتوقّف لتشكر الله عليها.",
  "dailyReflection23": "راجع نياتك اليوم — هل كانت لله؟ ابدأ غداً من جديد.",
  "dailyReflection24": "مع سكون الليل، اصغِ إلى قرب الله في هذا الصمت.",
  "dailyReflection25": "تأمّل في مصدر قوتك اليوم — تلك القوة من الله.",
  "dailyReflection26": "سمِّ شيئاً واحداً ستفعله غداً لوجه الله لم تفعله اليوم.",
  "dailyReflection27": "وأنت تستعد للنوم، استودع روحك الله — فهو خير الحافظين.",

