  "dailyScripture14Text": "جو کوئی نیکی کا عمل کرے، خواہ مرد ہو یا عورت، اور وہ مومن ہو — ہم اسے اچھی زندگی دیں گے۔",
  "dailyScripture14Ref": "قرآن 16:97",
  "dailyScripture15Text": "بے شک اللہ کسی قوم کی حالت تبدیل نہیں کرتا جب تک وہ خود اپنے آپ میں تبدیلی نہیں کرتے۔",
  "dailyScripture15Ref": "قرآن 13:11",
  "dailyScripture16Text": "سو ضعیف مت پڑو اور غم مت کرو، اور اگر تم سچے مومن ہو تو تم ہی غالب ہو۔",
  "dailyScripture16Ref": "قرآن 3:139",
  "dailyScripture17Text": "اے میرے بندوں جنہوں نے اپنی روحوں پر ظلم کیا، اللہ کی رحمت کی مایوسی مت کرو۔ بے شک اللہ تمام گناہوں کو معاف کرتا ہے۔",
  "dailyScripture17Ref": "قرآن 39:53",
  "dailyScripture18Text": "اور جو اللہ سے ڈرتا ہے — وہ اس کے لیے ایک راستہ نکال دے گا اور اسے اس جگہ سے رزق دے گا جہاں سے وہ توقع نہیں رکھتا۔",
  "dailyScripture18Ref": "قرآن 65:2-3",
  "dailyScripture19Text": "اللہ کی رحمت میں مایوس مت ہو۔",
  "dailyScripture19Ref": "قرآن 12:87",
  "dailyScripture20Text": "اور ہم نے بے شک قرآن کو یاد رکھنا آسان بنا دیا ہے۔ تو کیا کوئی ہے جو غور و فکر کرے؟",
  "dailyScripture20Ref": "قرآن 54:17",
  "dailyScripture21Text": "اور اس نے تمہیں گمراہ پایا اور تمہیں راہ دکھائی۔",
  "dailyScripture21Ref": "قرآن 93:7",
  "dailyScripture22Text": "اور تمہارا رب کہتا ہے: مجھے پکارو، میں تمہاری سنوں گا۔",
  "dailyScripture22Ref": "قرآن 40:60",
  "dailyScripture23Text": "اور ہم نے بے شک بنی آدم کو عزت دی۔",
  "dailyScripture23Ref": "قرآن 17:70",
  "dailyScripture24Text": "اور صبر اور نماز کے ذریعے مدد مانگو۔",
  "dailyScripture24Ref": "قرآن 2:45",
  "dailyScripture25Text": "جو ریت کے ذرے کے برابر بھی نیکی کرے گا وہ اسے دیکھے گا۔",
  "dailyScripture25Ref": "قرآن 99:7",
  "dailyScripture26Text": "بے شک اللہ کی مدد قریب ہے۔",
  "dailyScripture26Ref": "قرآن 2:214",
  "dailyScripture27Text": "اور جو شکر ادا کرے تو وہ شکر اپنے ہی فائدے کے لیے ہے۔",
  "dailyScripture27Ref": "قرآن 31:12",

  "dailyReflection0": "جیسے یہ دن ختم ہو رہا ہے، ایک لمحے پر غور کریں جہاں اللہ کی رحمت واضح تھی۔",
  "dailyReflection1": "جو بھی آج آپ کے دل کو ستایا، اسے اللہ کے سامنے لائیں۔",
  "dailyReflection2": "آج کی ایک برکت کا نام بتائیں اور اللہ کو شکر دیں۔",
  "dailyReflection3": "اللہ کی لامحدود دیکھ بھال میں رہنے کے علم میں سکون حاصل کریں۔",
  "dailyReflection4": "اس بات پر غور کریں کہ آپ آج ہمدردی اور شفقت دکھانے کے لیے کہاں بلایا گیا۔",
  "dailyReflection5": "اس سے آزاد ہو جائیں جو آپ کنٹرول نہیں کر سکتے اور اللہ کے کامل منصوبے پر اعتماد کریں۔",
  "dailyReflection6": "جیسے دن ختم ہو رہا ہے، اللہ کی یاد میں سکون حاصل کریں۔",
  "dailyReflection7": "اس بات پر غور کریں کہ آپ نے آج اپنی نمازوں کا احترام کیسے کیا اور ہر ایک کے لیے اللہ کو شکر دیں۔",
  "dailyReflection8": "ایک لمحے پر غور کریں جہاں صبر نے آج آپ کے اعمال کی رہنمائی کی۔",
  "dailyReflection9": "آج کی کسی کمی کے لیے معافی مانگیں — اللہ کی رحمت بے حد ہے۔",
  "dailyReflection10": "ایک شخص کا نام بتائیں جس کے ساتھ آپ نے آج شفقت دکھائی اور ان کے لیے دعا کریں۔",
  "dailyReflection11": "شکری کے ساتھ بیٹھیں: اللہ نے آج کیا فراہم کیا جس کے لیے آپ نے نہیں پوچھا؟",
  "dailyReflection12": "قرآن کی آیت پر غور کریں جو آپ کے موجودہ حال سے بات کرتی ہے۔",
  "dailyReflection13": "اس بات پر غور کریں کہ آپ نے آج اپنا وقت کیسے استعمال کیا — اور کل اللہ کو سونپ دیں۔",
  "dailyReflection14": "جانیں کہ آج کی کوئی بھی مشکل ایسی نہیں جس میں اللہ آپ کے ساتھ نہ تھا۔",
  "dailyReflection15": "ایک طریقے کی سوچیں جس سے آپ نے آج اللہ کے لیے اپنے خاندار یا معاشرے کی خدمت کی۔",
  "dailyReflection16": "رات پڑتی ہے، توبہ کریں — اللہ ان لوگوں کو پیار کرتا ہے جو اس کی طرف واپس آتے ہیں۔",
  "dailyReflection17": "اللہ نے اپنے دن میں جو خوبصورتی رکھی، خواہ کتنی ہی چھوٹی ہو، اس پر غور کریں۔",
  "dailyReflection18": "اس بات پر غور کریں کہ آپ نے آج کیا سیکھا اور یہ کیسے آپ کو اللہ کے قریب لاتا ہے۔",
  "dailyReflection19": "دن کی فکریں اللہ کے ساتھ چھوڑ دیں — وہ وہ نہ اٹھا سکتے ہیں اسے نہ سہتا ہے۔",
  "dailyReflection20": "آج کے ایک لمحے کے بارے میں سوچیں جہاں آپ بہتر کر سکتے تھے، اور نرمی سے اس سے سیکھیں۔",
  "dailyReflection21": "جو لوگ مشکل میں ہیں ان کے لیے دعا کریں — آپ کی دعا ان کے لیے ایک تحفہ ہے۔",
  "dailyReflection22": "ایک برکت کو یاد کریں جو آپ اکثر نظر انداز کرتے ہیں اور اللہ کو اس کے لیے شکر دیں۔",
  "dailyReflection23": "آج اپنی نیتوں پر غور کریں — کیا وہ اللہ کے لیے تھیں؟ کل دوبارہ شروع کریں۔",
  "dailyReflection24": "جیسے رات خاموش ہو رہی ہے، خاموشی میں اللہ کی نزدیکی سنیں۔",
  "dailyReflection25": "اس جگہ پر غور کریں جہاں آپ نے آج طاقت پائی — یہ طاقت اللہ کی طرف سے ہے۔",
  "dailyReflection26": "ایک چیز کا نام بتائیں جو آپ کل کریں گے، اللہ کی خاطر، جو آپ نے آج نہیں کی۔",
  "dailyReflection27": "جیسے آپ آرام کے لیے تیار ہو رہے ہیں، اپنی روح اللہ کے حوالے کریں — وہ سب سے اچھا محافظ ہے۔",

