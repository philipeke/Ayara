  "promptDailyGuidance": "سنی اسلامی ایمان پر مبنی ایک مختصر، عملی روزانہ کی رہنمائی لکھیں جو قرآن، حدیث اور نبی محمد صلی اللہ علیہ وسلم کی تعلیمات سے جڑی ہو۔ ہر بار ایک نیا زاویہ منتخب کریں: اسلامی اخلاقیات سے ایک فضیلت، سنت سے ایک حقیقت، صحابہ کرام کی حکمت، یا اسلامی روایت سے ایک خاموش عمل۔ ایک قرآن کی آیت شامل کریں اور دن کے ذریعے لے جانے کے لیے ایک یا دو جملے کی تاثر پذیری دیں۔ اگر متعلقہ ہو تو اسے اسلامی تقویم سے یا اہم تاریخ سے جوڑیں۔",

  "promptFaithTrust": "ایمان اور اللہ کے منصوبے پر توکل کے بارے میں ایک مختصر اسلامی تاثر پذیری لکھیں۔ اسے قرآن، نبی محمد صلی اللہ علیہ وسلم کی مثال اور صحابہ کے ایمان میں جڑیں۔ ہر بار موضوع میں تنوع لائیں: غیر یقینی حالات میں اللہ پر توکل، الہی حکمت پر انحصار، آزمائشوں میں صبر، یا روزمرہ کی زندگی میں خاموش استقامت۔ ایک قرآن کی آیت اور آج کے لیے اسلامی روحانی حکمت سے ایک ایمانداری کے ساتھ قدم شامل کریں۔",

  "promptPrayerReflection": "نماز، دعا یا ذکر پر مبنی ایک مختصر اسلامی نماز کی تاثر پذیری لکھیں۔ ہر بار شکل میں تنوع لائیں: صبح یا شام کی یاد الذکر، پنجوقتہ نمازوں پر غور و فکر، قرآن کی آیت کی تفکر، یا دل کی سچی دعا۔ ایک قرآن کی آیت شامل کریں اور مختصر طور پر استعمال کی گئی نماز کی شکل کا نام بتائیں۔",

  "promptHopeDifficultTimes": "مشکل وقت میں صبر اور امید کے بارے میں ایک اسلامی تاثر پذیری لکھیں۔ آزمائشوں کے بارے میں قرآنی تعلیمات، انبیاء کی استقامت اور مشکل لمحوں میں اللہ کی رحمت سے لیں۔ ہر بار زاویہ میں تنوع لائیں۔ ایک قرآن کی آیت اور اسلامی روایت سے ایک حوصلہ افزا نقطہ نظر شامل کریں۔",

  "promptForgiveness": "معافی کی طلب اور اللہ کی رحمت کے بارے میں ایک دانائی بخش اسلامی تاثر پذیری لکھیں۔ توبہ کے بارے میں قرآنی تعلیمات، اللہ کی شفقت اور نبی محمد صلی اللہ علیہ وسلم کی معافی دینے والی مثال سے لیں۔ موضوع میں تنوع لائیں: اللہ کی طرف واپسی، دوسروں کو معاف کرنا، رشتے دوبارہ بنانا، یا غلطیوں کے بعد اللہ کی رحمت پر یقین۔ ایک قرآن کی آیت اور ایک ٹھوس قدم شامل کریں۔",

  "promptLoveCompassion": "روزمرہ کی زندگی میں رحمت اور ہمدردی کے بارے میں ایک مختصر اسلامی تاثر پذیری لکھیں۔ نبی محمد صلی اللہ علیہ وسلم کی مثال، احسان کے تصور اور خاندان، پڑوسیوں اور کمزوروں کے ساتھ سلوک کی اسلامی تعلیمات سے لیں۔ ایک قرآن کی آیت اور آج کرنے کے لیے ہمدردی کا ایک چھوٹا عمل شامل کریں۔",

  "promptStrengthCourage": "ایمان پر مبنی طاقت اور ہمت کے بارے میں ایک اسلامی تاثر پذیری لکھیں۔ انبیاء، ابتدائی مسلم معاشرے اور ایسے لوگوں کی مثالیں لیں جو مشکل حالات میں ثابت رہے۔ ہر بار موضوع میں تنوع لائیں: ایمان کے ذریعے ہمت، نماز میں طاقت، خوف میں اللہ پر اعتماد، یا مشکل حالات میں لچکداری۔ ایک قرآن کی آیت اور یاد کا ایک مختصر دعا یا جملہ شامل کریں۔",

  "promptGratitude": "اللہ کے ساتھ شکر اور شکری کے بارے میں ایک اسلامی تاثر پذیری لکھیں۔ اسے قرآنی تعلیم اور نبوی روایت میں جڑیں۔ زاویہ میں تنوع لائیں: مشکل حالات میں شکر، چھوٹی برکتوں کی تعریف، اللہ کی تسبیح کے ساتھ دن کا آغاز، یا روزمرہ کی زندگی میں اللہ کی رہنمائی کو سمجھنا۔ ایک قرآن کی آیت اور ایک شکری کا عمل شامل کریں۔",

  "promptPurposeCalling": "اللہ کی عبادت کرنے اور نیکی کے ساتھ زندگی گزارنے کے مقصد کے بارے میں ایک اسلامی تاثر پذیری لکھیں۔ مقصد کے بارے میں قرآنی تعلیمات، دوسروں کی خدمت اور بھلائی کے لیے اپنے ہنر استعمال کرنے سے لیں۔ ہر بار موضوع میں تنوع لائیں: خاندان اور معاشرے کی خدمت، استخارے کے ذریعے رہنمائی کی تلاش، نیت کے ساتھ زندگی گزارنا، یا روزمرہ کے کام میں معنی تلاش کرنا۔ ایک قرآن کی آیت اور دو سوچنے والے سوالات شامل کریں۔",

  "promptFamilyRelationships": "خاندار اور رشتوں کے بارے میں دانائی بخش اسلامی رہنمائی لکھیں جو قرآنی تعلیم اور نبی محمد صلی اللہ علیہ وسلم کی مثال پر مبنی ہو۔ ہر بار موضوع میں تنوع لائیں: خاندار میں شفقت، تنازعات میں صبر، والدین کا احترام، بچوں کی ایمان کے ساتھ تربیت، یا شادی کو مضبوط کرنا۔ ایک قرآن کی آیت اور ایک تعلق کا عمل شامل کریں۔",

  "promptPeaceAnxietyRelief": "اللہ کی یاد اور اس کے منصوبے پر اعتماد کے ذریعے اندرونی سکون تلاش کرنے کے بارے میں ایک تسکین بخش اسلامی تاثر پذیری لکھیں۔ دل کے سکون، نماز اور اللہ کی مرضی پر سپرمی کے بارے میں قرآنی تعلیمات سے لیں۔ ہر بار طریقہ میں تنوع لائیں اور ایک قرآن کی آیت اور اسلامی روایت سے ایک سادہ سکون دہ عمل شامل کریں۔",

  "promptWisdomOfJesus": "اسلام میں سکھائے گئے انبیاء کی حکمت کا ایک مختصر حصہ لکھیں۔ قرآن یا حدیث سے لیں اور مختصر طور پر وضاحت کریں کہ اسلامی علماء نے تعلیم کو کیسے سمجھا۔ ہر بار موضوع میں تنوع لائیں: کردار، صبر، عاجزی، ایمان یا روزمرہ کا سلوک۔ ایک قرآن کی آیت یا حدیث کا حوالہ اور ایک عملی اطلاق شامل کریں۔",

  "promptHumilityCharacter": "عاجزی اور اچھے کردار کے بارے میں ایک اسلامی تاثر پذیری لکھیں۔ قرآنی تعلیمات، نبی محمد صلی اللہ علیہ وسلم کی مثال اور اسلامی کردار کی تربیت کی روایت سے لیں۔ موضوع میں تنوع لائیں: قیادت میں عاجزی، غلطیوں کو تسلیم کرنا، دوسروں کے ساتھ احترام کے ساتھ سلوک، یا روحانی خود غورو فکر کے ذریعے بڑھنا۔ ایک قرآن کی آیت اور ایک عادت شامل کریں۔",

  "promptOvercomingTemptation": "فتنے کے مقابلے اور سیدھی راہ پر رہنے کے بارے میں ایک اسلامی تاثر پذیری لکھیں۔ قرآنی رہنمائی، اللہ کی یاد، نماز اور مشکلات پر کامیاب ہونے والے مومنین کی مثالوں سے لیں۔ ہر بار زاویہ میں تنوع لائیں۔ ایک قرآن کی آیت اور اگلے 24 گھنٹے کے لیے ایک عملی حکمت عملی شامل کریں۔",

  "promptEveningReflection": "شام کی یاد کی روایت پر مبنی ایک پرسرار اسلامی شام کی تاثر پذیری لکھیں۔ شکری، خود کے حساب اور سونے سے پہلے اللہ پر اعتماد کی حوصلہ افزائی کریں۔ دن کے بارے میں 3 سے 5 مختصر غور و فکر کے سوالات، ایک مختصر بند دعا اور ایک قرآن کی آیت شامل کریں۔",

