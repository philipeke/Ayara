  "promptDailyGuidance": "குர்‍ஆன், ஹதீஸ் மற்றும் நபிமுஹம்மத் ﷺ இன் கற்பனைகளை அடிப்படையாக கொண்ட சுன்னி இஸ்லாமிய நம்பிக்கையில் வேரூன்றிய குறுகிய, நடைமுறை தினசரி வழிகாட்டுதல் எழுதவும். ஒவ்வொரு முறையும் புதிய கோணத்தைத் தேர்ந்தெடுக்கவும்: இஸ்லாமிய நெறிமுறைகளின் ஒரு சாரியாணை, சুன্னாவிலிருந்து ஒரு உண்மை, நபியின் சஹாபாக்களின் ஞானம், அல்லது இஸ்லாமிய परम்परையிலிருந்து ஒரு அமைதியான செயல்முறை. ஒரு குர்‍ஆன் வசனம் (சூரா:ஆயா) மற்றும் பகலெங்கும் கொண்டு செல்ல 1-2 வாக்கியமான சிந்தனை சேர்க்கவும். விரும்பினால் இஸ்லாமிய நாட்காட்டி அல்லது ஒரு முக்கியமான தேதியுடன் இணைக்கவும்.",

  "promptFaithTrust": "ஈமান் (நம்பிக்கை) மற்றும் அல்லாஹ்வின் திட்டத்தில் நம்பிக்கை (தவக்கুல்) பற்றி குர்‍ஆன், நபிமுஹம்மத் ﷺ இன் உதாரணம் மற்றும் சஹாபாக்களின் ஈமாநை அடிப்படையாக கொண்ட குறுகிய இஸ்லாமிய சிந்தனை எழுதவும். ஒவ்வொரு முறையும் தீம் மாற்றவும்: நிச்சயமற்ற காலத்தில் அல்லாஹ்வின் மீது நம்பிக்கை, தெய்வீய ஞானத்தில் நம்பிக்கை, சோதனையில் பொறுமை, அல்லது அன்றாட வாழ்க்கையில் அமைதியான நிலைத்தன்மை. ஒரு குர்‍ஆன் வசனம் மற்றும் இஸ்லாமிய ஆன்மீக ஞாணத்திலிருந்து பெறப்பட்ட இன்றைய ஒரு நேர்மையான படி சேர்க்கவும்.",

  "promptPrayerReflection": "சலாத், தুஆ, அல்லது திக்ர்-ஐ அடிப்படையாக கொண்ட குறுகிய இஸ்லாமிய தொழுகை சிந்தனை எழுதவும். ஒவ்வொரு முறையும் வடிவ மாற்றவும்: ஒரு காலை அல்லது மாலை நினைவுக்கு (அத்கார்), ஐந்து தினசரி தொழுகைகளின் சிந்தனை, குர்‍ஆন் வசனத்தின் தியானம், அல்லது ஒரு உள்ளமான பிரার্த்தனை. ஒரு குர்‍ஆன் வசனம் மற்றும் பயன்படுத்தப்பட்ட தொழுகை வடிவத்தை சுருக்கமாக பெயரிடவும்.",

  "promptHopeDifficultTimes": "சோதனையின் கால இஸ்லாமிய சிந்தனை பற்றி குர்‍ஆன், நபிமுஹம்மத் ﷺ இன் பொறுமை (சப்ர்) மற்றும் நம்பிக்கை பற்றி எழுதவும். சோதனையைப் பற்றிய குர்‍ஆன் கற்பனைகள், நবிமுஹம்மத் ﷺ இன் நிலைத்தன்மை மற்றும் கடுமையான தருணங்களில் அல்லாஹ்வின் இரக்கம் பற்றி உள்ளடக்கம் உள்ளது. ஒவ்வொரு முறையும் கோணம் மாற்றவும். ஒரு குர்‍ஆன் வசனம் மற்றும் இஸ்லாமிய परम्परையிலிருந்து ஒரு ஊக்கமளிக்கும் கண்ணோட்டம் சேர்க்கவும்.",

  "promptForgiveness": "மன்னிப்பு (தவ்பா) மற்றும் அல்லாஹ்வின் இரக்கம் பற்றி ஞானமான இஸ்லாமிய சிந்தனை எழுதவும். குர்‍ஆன் கற்பனைகளில் பாவம் செய்தவர்களை மாற்றல், அல்லாஹ்வின் இரக்கம் மற்றும் நபிமுஹம்மத் ﷺ இன் மன்னிப்புக்கான உதாரணத்திலிருந்து வரவும். தீம் மாற்றவும்: அல்லாஹ்வின் மீது திரும்பி வரல், பிறரை மன்னித்தல், உறவுகளை குணப்படுத்தல், அல்லது பிழைகளுக்குப் பின் அல்லாஹ்வின் இரக்கத்தில் நம்பிக்கை கொள்ளல். ஒரு குர்‍ஆன் வசனம் மற்றும் ஒரு கான்கிரீட் படி சேர்க்கவும்.",

  "promptLoveCompassion": "அன்றாட வாழ்க்கையில் இரக்கம் (ரஹ்மா) மற்றும் கருணை பற்றி குறுகிய இஸ்லாமிய சிந்தனை எழுதவும். நபிமுஹம்மத் ﷺ இன் உதாரணம், இহ்சான் (சிறப்பு) கோட்பாடு, மற்றும் குடும்பம், அண்டை வீட்டுக்காரர் மற்றும் பலவீனமானவர்களுக்கான இஸ்லாமிய கருணை பற்றிய கற்பனைகளிலிருந்து உள்ளடக்கம் உள்ளது. ஒரு குர்‍ஆன் வசனம் மற்றும் இன்று பயிற்சி செய்ய ஒரு சிறிய கருணை செயல் சேர்க்கவும்.",

  "promptStrengthCourage": "ஈமான் அடிப்படையிலான வலிமை மற்றும்담courage பற்றி இஸ்லாமிய சிந்தனை எழுதவும். நபிமுஹம்மத் ﷺ இன் உதாரணம், ஆரம்பகால முஸ்லிம் சமூகம் மற்றும் கடுமையான வேளைகளில் உறுதியாக இருந்த விசுவாசীகளிலிருந்து வரவும். ஒவ்வொரு முறையும் தீம் மாற்றவும்: ஈமாந மூலம்담courage, தொழுகையின் மூலம் வலிமை, பயத்தின் போது அல்லாஹ்வில் நம்பிக்கை, அல்லது சோதனையில் நிலைத்தன்மை. ஒரு குர்‍ஆன் வசனம் மற்றும் ஒரு குறுகிய பிரার்த்தனை அல்லது நினைவுக்கான சொல் சேர்க்கவும்.",

  "promptGratitude": "அல்லாஹ்வின் மீது நன்றி (ஷுக்ர்) பற்றி இஸ்லாமிய சிந்தனை எழுதவும். குர்‍ஆன் பாடம் மற்றும் நபி परम्पரையில் அடிப்படை. கோணம் மாற்றவும்: சோதனையில் நன்றி, சிறிய ஆசீர்வாதங்களுக்கு நன்றி, அல்லாஹ்வின் புகழ்ச்சியுடன் பகலை தொடங்குதல், அல்லது அன்றாட வாழ்க்கையில் அல்லாஹ்வின் வழிகாட்டுதலை அங்கீகரித்தல். ஒரு குர்‍ஆன் வசனம் மற்றும் ஒரு நன்றி பயிற்சி சேர்க்கவும்.",

  "promptPurposeCalling": "அல்லாஹ்வை வணங்குதல் மற்றும் நேர்மையுடன் வாழ்தல் பற்றி வாழ்க்கையின் நோக்கத்தைப் பற்றி இஸ்லாமிய சிந்தனை எழுதவும். குர்‍ஆன் கற்பனைகளில் நோக்கம், பிறரைப் பணிதல் மற்றும் ஒருவரின் திறன்களை நன்றாக பயன்படுத்துதல் பற்றி உள்ளடக்கம் உள்ளது. ஒவ்வொரு முறையும் தீம் மாற்றவும்: குடும்பம் மற்றும் சமூகத்தை பணிதல், ইஸ்திखारா மூலம் வழிகாட்டுதல் நாடல், நோக்கத்துடன் வாழ்தல், அல்லது வழக்கமான வேலையில் அர্த்தம் கண்டறிதல். ஒரு குர்‍ஆன் வசனம் மற்றும் இரண்டு சிந்தனைத் தொடர்ந்த கேள்விகள் சேர்க்கவும்.",

  "promptFamilyRelationships": "குர்‍ஆன் பாடம் மற்றும் நபிமுஹம்மத் ﷺ இன் உதாரணத்தை அடிப்படையாக கொண்ட குடும்பம் மற்றும் உறவுகள் பற்றி ஞானமான இஸ்லாமிய வழிகாட்டுதல் எழுதவும். ஒவ்வொரு முறையும் தீம் மாற்றவும்: குடும்ப வாழ்க்கையில் கருணை, மோதலில் பொறுமை, பெற்றோர்களின் மீது மரியாதை, ஈமாநுடன் குழந்தைகளை வளர்த்தல், அல்லது திருமணத்தைப் பலப்படுத்துதல். ஒரு குர்‍ஆன் வசனம் மற்றும் ஒரு உறவுத் தொடர்ந்த பயிற்சி சேர்க்கவும்.",

  "promptPeaceAnxietyRelief": "அல்லாஹ்வின் நினைவு (திक्र்) மற்றும் அவனுடைய திட்டத்தில் நம்பிக்கை மூலம் உள் அமைதி கண்டறிதல் பற்றி ஒரு ஆறுதலளிக்கும் இஸ்லாமிய சிந்தனை எழுதவும். இதயத்தின் அமைதி, தொழுகை மற்றும் அல்லாஹ்வின் விரும்புதலுக்கு பொருத்தம் பற்றிய குர்‍ஆன் பாடங்களிலிருந்து உள்ளடக்கம் உள்ளது. ஒவ்வொரு முறையும் அணுகுமுறை மாற்றவும் மற்றும் ஒரு குர்‍ஆன் வசனம் மற்றும் இஸ்லாமிய परम्परையிலிருந்து ஒரு எளிய மூலக்கூறு பயிற்சி சேர்க்கவும்.",

  "promptWisdomOfJesus": "இஸ்லாமில் கற்பிக்கப்பட்ட நபிமுஹம்மத் ﷺ இன் ஞானத்தின் ஒரு குறுகிய பகுதி எழுதவும். குர்‍ஆன் அல்லது ஹதீஸ்களிலிருந்து வரவும் மற்றும் இஸ்லாமிய விद்வத்ஸ் பாடங்களை எப்படி புரிந்துகொண்டுள்ளனர் என்பதை சுருக்கமாக விளக்கவும். ஒவ்வொரு முறையும் விஷயம் மாற்றவும்: குணம், பொறுமை,�னிய்தை, ஈமான், அல்லது அன்றாட நடத்தை. ஒரு குர்‍ஆன் வசனம் அல்லது ஹதீஸ் கையெழுத்து மற்றும் ஒரு நடைமுறை பயன்பாடு சேர்க்கவும்.",

  "promptHumilityCharacter": "கனிய்தை (தவாதுஆ) மற்றும் நல்ல குணம் (அக்லாக்) பற்றி இஸ்லாமிய சிந்தனை எழுதவும். குர்‍ஆன் பாடங்கள், நபிமுஹம்மத் ﷺ இன் உதாரணம் மற்றும் இஸ்லாமிய குணம் வளர்ச்சির परम्परையிலிருந்து வரவும். தீம் மாற்றவும்: தலைமையில் கனிய்தை, பிழைகளை ஒப்புக்கொள்ளல், மற்றவர்களுக்கு மரியாதை மாநோ, அல்லது தன்-சிந்தனை மூலம் ஆன்மீகமாக வளர்தல். ஒரு குர்‍ஆன் வசனம் மற்றும் ஒரு பயிற்சி செய்ய ஒரு வழக்கம் சேர்க்கவும்.",

  "promptOvercomingTemptation": "சோதனைகளை எதிர்க்கல் மற்றும் நேர்மையான பாதையில் நிலைத்தன்மை பற்றி இஸ்லாமிய சிந்தனை எழுதவும். குர்‍ஆன் வழிகாட்டுதல், அல்லாஹ்வின் நினைவு (திక्र्), தொழுகை (சலாத்) மற்றும் சோதனைகளை கடந்த விசுவாசীகளின் உதாரணங்களிலிருந்து வரவும். ஒவ்வொரு முறையும் கோணம் மாற்றவும். ஒரு குர்‍ஆன் வசனம் மற்றும் அடுத்த 24 மணி நேரத்திற்கு ஒரு நடைமுறை உபாயம் சேர்க்கவும்.",

  "promptEveningReflection": "மாலை நினைவு (அத்கார் அல்-மசாஆ) के परम्परையில் அடிப்படை ஒரு அமைதியான இஸ்லாமிய மாலை சிந்தனை எழுதவும். நன்றி, தன்-விமர্சம் (முஹாசபா), மற்றும் ஓய்வுக்கு முன் அல்லாஹ்வுக்கு நம்பிக்கை ஊக்குவிக்கவும். பகைபள்ளி பற்றி 3-5 குறுகிய சிந்தனை உரவுகள், ஒரு சுருக்கமான மூடிய பிரார்த்தனை, மற்றும் ஒரு குர்‍ஆன் வசனம் சேர்க்கவும்.",

