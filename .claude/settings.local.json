      "Bash(python3 -c \":*)",
      "Bash(node -e \":*)",
      "Bash(flutter gen-l10n)",
      "Bash(flutter analyze lib/features/chat/presentation/screens/category_screen.dart)",
      "Bash(xargs grep -l -i \"nuria\")",
      "Bash(firebase projects:list)",
      "Bash(firebase apps:sdkconfig ios --project nuria-mobile-app)",
      "Bash(firebase deploy --only functions)",
      "Bash(python:*)"
